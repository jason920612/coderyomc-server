diff --git a/com/coderyo/region/RegionLifecycle.java b/com/coderyo/region/RegionLifecycle.java
new file mode 100644
index 0000000000000000000000000000000000000000..31aab02cf63b3be41733dbbc46ed8f2bd136ac74
--- /dev/null
+++ b/com/coderyo/region/RegionLifecycle.java
@@ -0,0 +1,126 @@
+/*
+ * coderyoMC — regionized multithreading core. Clean-room independent
+ * implementation; Folia (GPL-3.0) studied as concept only, never copied.
+ */
+package com.coderyo.region;
+
+import com.coderyo.region.merge.RegionDelta;
+import com.coderyo.region.merge.RegionMerger;
+import java.util.Map;
+import java.util.StringJoiner;
+import java.util.concurrent.ConcurrentHashMap;
+import net.minecraft.resources.ResourceKey;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.Level;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+/**
+ * Live entry point that drives region formation from the real Moonrise chunk
+ * lifecycle (P1.2a). The single upstream patch point (a tiny delegation inside
+ * {@code NewChunkHolder}'s full-status transition) calls {@link #onChunkFullLoad}
+ * when a chunk reaches FULL status and {@link #onChunkFullUnload} when it drops
+ * below FULL.
+ *
+ * <p><b>Dormancy contract:</b> both entry points return immediately when
+ * {@link RegionConfig#isEnabled()} is false. The patch call sites are ALSO gated on
+ * that flag, so with {@code region.enabled=false} not even this class is touched and
+ * the chunk system runs byte-for-byte vanilla. When enabled, each load/unload feeds
+ * the per-dimension {@link RegionMerger} and the resulting {@link RegionDelta} is
+ * logged (gated on {@link RegionConfig#isDebug()}).
+ *
+ * <p>This is the P1.2a increment: it proves the {@link RegionIndex} forms correctly
+ * against the live chunk system. It does NOT yet change the tick loop — the
+ * {@link RegionScheduler} stays sequential/dormant (P1.2b).
+ *
+ * <p>Threading: Moonrise invokes the full-status transition on the level's tick
+ * thread (it asserts {@code TickThread.ensureTickThread}). Different dimensions may
+ * tick on different threads, but each {@link RegionMerger} is owned by exactly one
+ * dimension, so per-merger access is single-threaded. The merger map itself is a
+ * {@link ConcurrentHashMap} to make first-touch creation safe across dimensions.
+ */
+public final class RegionLifecycle {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger("coderyoMC/region");
+
+    private static final RegionIndex INDEX = new RegionIndex();
+
+    private static final Map<ResourceKey<Level>, RegionMerger> MERGERS = new ConcurrentHashMap<>();
+
+    private RegionLifecycle() {
+    }
+
+    /** The global chunk->region index. */
+    public static RegionIndex index() {
+        return INDEX;
+    }
+
+    private static RegionMerger mergerFor(final ServerLevel level) {
+        return MERGERS.computeIfAbsent(level.dimension(),
+            dim -> new RegionMerger(dim, INDEX, RegionConfig.mergeRadius()));
+    }
+
+    /**
+     * A chunk reached FULL status (border-loaded / ticking): add it to its dimension's
+     * region model and merge with adjacent loaded chunks. No-op unless the subsystem is
+     * enabled. Must be called on the owning level's tick thread.
+     */
+    public static void onChunkFullLoad(final ServerLevel level, final int chunkX, final int chunkZ) {
+        if (!RegionConfig.isEnabled()) {
+            return;
+        }
+        final RegionMerger merger = mergerFor(level);
+        final RegionDelta delta = merger.addLoadedChunk(ChunkPos.pack(chunkX, chunkZ));
+        logDelta(level, "load", chunkX, chunkZ, merger, delta);
+    }
+
+    /**
+     * A chunk dropped below FULL status (unloading): remove it from its dimension's
+     * region model, which may split a region if it disconnected a cluster. No-op unless
+     * the subsystem is enabled. Must be called on the owning level's tick thread.
+     */
+    public static void onChunkFullUnload(final ServerLevel level, final int chunkX, final int chunkZ) {
+        if (!RegionConfig.isEnabled()) {
+            return;
+        }
+        final RegionMerger merger = mergerFor(level);
+        final RegionDelta delta = merger.removeLoadedChunk(ChunkPos.pack(chunkX, chunkZ));
+        logDelta(level, "unload", chunkX, chunkZ, merger, delta);
+    }
+
+    private static void logDelta(final ServerLevel level, final String cause,
+                                 final int chunkX, final int chunkZ,
+                                 final RegionMerger merger, final RegionDelta delta) {
+        if (!RegionConfig.isDebug() || delta.isEmpty()) {
+            return;
+        }
+        final String dim = level.dimension().identifier().toString();
+        for (final RegionDelta.Formed f : delta.formed()) {
+            LOGGER.info("region R{} formed ({} chunks) [{}] (chunk {},{} {})",
+                f.id().value(), f.chunkCount(), dim, chunkX, chunkZ, cause);
+        }
+        for (final RegionDelta.Merged m : delta.merged()) {
+            final StringJoiner sources = new StringJoiner("+R", "R", "");
+            for (final RegionId src : m.sources()) {
+                sources.add(Long.toString(src.value()));
+            }
+            LOGGER.info("merged {} -> R{} ({} chunks) [{}] (chunk {},{} {})",
+                sources, m.result().value(), m.chunkCount(), dim, chunkX, chunkZ, cause);
+        }
+        for (final RegionDelta.Split s : delta.splits()) {
+            final StringJoiner parts = new StringJoiner(",", "", "");
+            for (final RegionDelta.RegionRef ref : s.parts()) {
+                parts.add("R" + ref.id().value() + "(" + ref.chunkCount() + ")");
+            }
+            LOGGER.info("split R{} -> {} [{}] (chunk {},{} {})",
+                s.source().value(), parts, dim, chunkX, chunkZ, cause);
+        }
+        for (final RegionId d : delta.dissolved()) {
+            LOGGER.info("region R{} dissolved (0 chunks) [{}] (chunk {},{} {})",
+                d.value(), dim, chunkX, chunkZ, cause);
+        }
+        LOGGER.info("[{}] now {} region(s), {} loaded chunk(s)",
+            dim, merger.regionCount(), merger.loadedChunkCount());
+    }
+}
diff --git a/com/coderyo/region/merge/RegionDelta.java b/com/coderyo/region/merge/RegionDelta.java
new file mode 100644
index 0000000000000000000000000000000000000000..a3b7097fc9358a18d45b0ce46a31e87bf1d7dd94
--- /dev/null
+++ b/com/coderyo/region/merge/RegionDelta.java
@@ -0,0 +1,55 @@
+/*
+ * coderyoMC — regionized multithreading core. Clean-room independent
+ * implementation; Folia (GPL-3.0) studied as concept only, never copied.
+ */
+package com.coderyo.region.merge;
+
+import com.coderyo.region.RegionId;
+import java.util.List;
+
+/**
+ * The structural change produced by one {@link RegionMerger#recompute()} — the set of
+ * region lifecycle events caused by a single chunk load or unload. This is the
+ * observability surface the live Moonrise hook turns into log lines (P1.2a §2).
+ *
+ * <p>An {@link #isEmpty() empty} delta means the recompute changed no region structure
+ * (e.g. a chunk simply joined an existing region without forming/merging/splitting it,
+ * which produces no lifecycle event but still reassigns index ownership).
+ *
+ * @param formed    regions that appeared with no predecessor (new disjoint clusters)
+ * @param merged    ≥2 predecessor regions that collapsed into one surviving region
+ * @param splits    a predecessor region that fragmented into ≥2 successor regions
+ * @param dissolved predecessor regions whose every chunk unloaded (now gone)
+ */
+public record RegionDelta(List<Formed> formed,
+                          List<Merged> merged,
+                          List<Split> splits,
+                          List<RegionId> dissolved) {
+
+    /** The no-change delta. */
+    public static final RegionDelta EMPTY =
+        new RegionDelta(List.of(), List.of(), List.of(), List.of());
+
+    public boolean isEmpty() {
+        return this.formed.isEmpty()
+            && this.merged.isEmpty()
+            && this.splits.isEmpty()
+            && this.dissolved.isEmpty();
+    }
+
+    /** A region that newly formed from previously-unowned chunks. */
+    public record Formed(RegionId id, int chunkCount) {
+    }
+
+    /** A reference to a region plus its post-change chunk count (for split parts). */
+    public record RegionRef(RegionId id, int chunkCount) {
+    }
+
+    /** ≥2 source regions collapsed into {@code result}. */
+    public record Merged(List<RegionId> sources, RegionId result, int chunkCount) {
+    }
+
+    /** A {@code source} region fragmented into {@code parts} (≥2). */
+    public record Split(RegionId source, List<RegionRef> parts) {
+    }
+}
