From: jason920612 <jasonya2206@gmail.com>
Date: Thu, 25 Jun 2026 18:01:27 +0800
Subject: [PATCH] GPU #19: offload BlendedNoise at interpolator cell batch
 (stock terrain hot path)


diff --git a/com/coderyo/compute/Ap2GpuBridge.java b/com/coderyo/compute/Ap2GpuBridge.java
new file mode 100644
index 0000000000000000000000000000000000000000..081ee8765af1a9f78cde6eaa5087d613c0fff618
--- /dev/null
+++ b/com/coderyo/compute/Ap2GpuBridge.java
@@ -0,0 +1,135 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import net.minecraft.world.level.levelgen.DensityFunction;
+import net.minecraft.world.level.levelgen.DensityFunctions;
+
+/**
+ * Makes the {@code BlendedNoise} GPU offload actually reach the stock 3D terrain hot
+ * path (issue #19).
+ *
+ * <p><b>Why this exists.</b> On stock overworld worldgen the heavy {@code BlendedNoise}
+ * ({@code base_3d_noise}) is wired so it is reached only through a per-point
+ * {@code compute()} call, never a batched {@code fillArray}: the terrain slide is built
+ * from {@code DensityFunctions.lerp}, which expands to {@code mul(factor, add(noise,
+ * const))}. Vanilla {@code Ap2.fillArray} for {@code MUL}/{@code MIN}/{@code MAX}
+ * batch-fills only {@code argument1}; {@code argument2} (the side carrying
+ * {@code base_3d_noise}) is evaluated <em>per cell corner</em> via {@code compute()}.
+ * So {@code BlendedNoise.fillArray} — the batched cell-corner entry the GPU bridge hooks
+ * — never fires. Verified empirically with entry probes.
+ *
+ * <p><b>What this does.</b> When GPU worldgen is enabled, this batch-fills
+ * {@code argument2} over the WHOLE cell-corner lattice via its own {@code fillArray}
+ * (which propagates down to {@code BlendedNoise.fillArray} → the GPU dispatch), then
+ * applies the exact same per-corner combine ({@code *} / {@code min} / {@code max}) with
+ * the identical short-circuit semantics. This is bit-identical to vanilla: each operand
+ * value at a corner is independent of the short-circuit, so batching {@code argument2}
+ * cannot change the output — it only does throwaway work for the short-circuited corners
+ * (off the tick path, on the chunk-gen worker pool).
+ *
+ * <p>With {@code gpu.worldgen.enabled=false} (default) this delegates straight to the
+ * EXACT upstream per-point combine — byte-for-byte vanilla, no extra allocation.
+ */
+public final class Ap2GpuBridge {
+
+    private Ap2GpuBridge() {
+    }
+
+    /**
+     * Batched {@code Ap2.fillArray}. {@code argument1} is filled into {@code output}
+     * first (exactly as upstream); the combine with {@code argument2} is then done
+     * per-corner — batched via {@code fillArray} when GPU is enabled, else exactly as
+     * upstream per-point.
+     */
+    public static void fillArray(final double[] output,
+                                 final DensityFunction.ContextProvider contextProvider,
+                                 final DensityFunctions.TwoArgumentSimpleFunction.Type type,
+                                 final DensityFunction argument1,
+                                 final DensityFunction argument2) {
+        argument1.fillArray(output, contextProvider);
+
+        // ADD already batch-fills argument2 in vanilla; nothing to gain by re-routing.
+        if (type == DensityFunctions.TwoArgumentSimpleFunction.Type.ADD || !ComputeConfig.isEnabled()) {
+            combinePerPoint(output, contextProvider, type, argument2);
+            return;
+        }
+
+        // GPU on: batch-fill argument2 over the whole lattice (reaches BlendedNoise.fillArray
+        // → one GPU dispatch), then combine per corner with identical short-circuit results.
+        final int n = output.length;
+        final double[] v2 = new double[n];
+        argument2.fillArray(v2, contextProvider);
+        switch (type) {
+            case MUL:
+                for (int i = 0; i < n; i++) {
+                    final double v = output[i];
+                    output[i] = v == 0.0 ? 0.0 : v * v2[i];
+                }
+                break;
+            case MIN: {
+                final double min = argument2.minValue();
+                for (int i = 0; i < n; i++) {
+                    final double v = output[i];
+                    output[i] = v < min ? v : Math.min(v, v2[i]);
+                }
+                break;
+            }
+            case MAX: {
+                final double max = argument2.maxValue();
+                for (int i = 0; i < n; i++) {
+                    final double v = output[i];
+                    output[i] = v > max ? v : Math.max(v, v2[i]);
+                }
+                break;
+            }
+            default:
+                // Unreachable (ADD handled above); keep exact upstream as a safety net.
+                combinePerPoint(output, contextProvider, type, argument2);
+        }
+    }
+
+    /** Exact upstream {@code Ap2.fillArray} per-point combine. */
+    private static void combinePerPoint(final double[] output,
+                                        final DensityFunction.ContextProvider contextProvider,
+                                        final DensityFunctions.TwoArgumentSimpleFunction.Type type,
+                                        final DensityFunction argument2) {
+        final int n = output.length;
+        switch (type) {
+            case ADD: {
+                final double[] v2 = new double[n];
+                argument2.fillArray(v2, contextProvider);
+                for (int i = 0; i < n; i++) {
+                    output[i] += v2[i];
+                }
+                break;
+            }
+            case MUL:
+                for (int i = 0; i < n; i++) {
+                    final double v = output[i];
+                    output[i] = v == 0.0 ? 0.0 : v * argument2.compute(contextProvider.forIndex(i));
+                }
+                break;
+            case MIN: {
+                final double min = argument2.minValue();
+                for (int i = 0; i < n; i++) {
+                    final double v = output[i];
+                    output[i] = v < min ? v : Math.min(v, argument2.compute(contextProvider.forIndex(i)));
+                }
+                break;
+            }
+            case MAX: {
+                final double max = argument2.maxValue();
+                for (int i = 0; i < n; i++) {
+                    final double v = output[i];
+                    output[i] = v > max ? v : Math.max(v, argument2.compute(contextProvider.forIndex(i)));
+                }
+                break;
+            }
+            default:
+                throw new IllegalStateException("unknown Ap2 type: " + type);
+        }
+    }
+}
diff --git a/com/coderyo/compute/BlendedNoiseGpuBridge.java b/com/coderyo/compute/BlendedNoiseGpuBridge.java
new file mode 100644
index 0000000000000000000000000000000000000000..a17bd8088f7e17a0087e7b68fbacb09c561f2c04
--- /dev/null
+++ b/com/coderyo/compute/BlendedNoiseGpuBridge.java
@@ -0,0 +1,169 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import java.util.concurrent.atomic.AtomicLong;
+import net.minecraft.world.level.levelgen.DensityFunction;
+import net.minecraft.world.level.levelgen.synth.BlendedNoise;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+/**
+ * Production hook for the stock 3D terrain density noise — {@code BlendedNoise}
+ * (issue #19, design-spec §6.2). This is the dominant per-cell-corner compute on
+ * stock overworld worldgen: the final density function sampled by the
+ * {@code NoiseChunk} interpolator at a coarse cell-corner lattice wraps a
+ * {@code BlendedNoise} ({@code BASE_3D_NOISE_OVERWORLD}) deep in its tree, and the
+ * interpolator's {@code fillArray} tree-walk reaches {@code BlendedNoise.fillArray}
+ * for each cell-corner column (the live, batched entry point — unlike the
+ * {@code DensityFunctions.Noise.fillArray} hook of issue #14, which is dormant on
+ * stock gen because stock wraps its climate {@code Noise} nodes in {@code FlatCache}).
+ *
+ * <p>{@code BlendedNoise} is a {@code SimpleFunction}: its default {@code fillArray}
+ * loops {@code compute()} per cell corner. We override {@code fillArray} to batch the
+ * cell-corner sample points and evaluate them in one OpenCL dispatch that reproduces
+ * {@code compute()} bit-exactly (three {@code PerlinNoise} octave stacks —
+ * {@code mainNoise}/{@code minLimitNoise}/{@code maxLimitNoise} — the y-smear fudge,
+ * the {@code clampedLerp} blend, and the final {@code /128.0}).
+ *
+ * <p><b>Routing (correctness-first):</b>
+ * <ul>
+ *   <li>{@code gpu.worldgen.enabled=false} (default) or CPU backend selected →
+ *       delegate to the EXACT upstream {@code contextProvider.fillAllDirectly(output,
+ *       node)}. Byte-for-byte vanilla; no allocation, no GPU probe beyond the one-time
+ *       backend selection.</li>
+ *   <li>GPU backend selected AND the lattice clears the batch threshold AND the
+ *       {@code BlendedNoise} is GPU-offloadable → batch the cell-corner coordinates and
+ *       route through {@link ComputeBackend#sampleNoise}. The backend reproduces
+ *       {@code BlendedNoise.compute()} bit-exactly (parity-gated at startup); any
+ *       per-job failure degrades transparently to CPU via the registry's fallback.</li>
+ *   <li>Otherwise → exact upstream fill.</li>
+ * </ul>
+ */
+public final class BlendedNoiseGpuBridge {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger("coderyo-compute");
+    private static volatile ComputeBackend backend;
+    /** Diagnostic: number of BlendedNoise cell-corner batches seen (entry probe). */
+    private static final AtomicLong ENTRIES = new AtomicLong();
+    /** Diagnostic: number of BlendedNoise lattices actually dispatched to the GPU. */
+    private static final AtomicLong GPU_DISPATCHES = new AtomicLong();
+
+    private BlendedNoiseGpuBridge() {
+    }
+
+    private static ComputeBackend backend() {
+        ComputeBackend local = backend;
+        if (local == null) {
+            synchronized (BlendedNoiseGpuBridge.class) {
+                local = backend;
+                if (local == null) {
+                    local = ComputeBackendRegistry.get().select();
+                    backend = local;
+                }
+            }
+        }
+        return local;
+    }
+
+    /**
+     * Fill {@code output} with {@code BlendedNoise.compute()} at every cell-corner
+     * described by {@code contextProvider}. Always produces values identical to the
+     * vanilla per-point fill; only the compute engine differs, gated on the flag and
+     * selected backend.
+     */
+    public static void fillArray(final BlendedNoise node,
+                                 final double[] output,
+                                 final DensityFunction.ContextProvider contextProvider) {
+        // Default & CPU path: byte-for-byte vanilla.
+        if (!ComputeConfig.isEnabled()) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+
+        // Entry probe (debug): confirm the hook is LIVE on stock gen — i.e. that
+        // BlendedNoise.fillArray is actually reached during real forceload worldgen,
+        // not just at startup (issue #19 verifies #14's dormant-hook mistake is fixed).
+        if (ComputeConfig.isDebug()) {
+            final long e = ENTRIES.incrementAndGet();
+            if (e == 1L || (e % 5000L) == 0L) {
+                LOGGER.info("[compute] BlendedNoise.fillArray ENTRY probe — batch #{} (cellCorners={}) — stock terrain hook is LIVE",
+                    e, output.length);
+            }
+        }
+
+        final ComputeBackend active = backend();
+        if (active == null || "cpu".equals(active.name())) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+
+        final int count = output.length;
+        if (count < ComputeConfig.batchThreshold()) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+
+        final BlendedNoiseSpec spec = BlendedNoiseSpec.from(node);
+        if (spec == null) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+
+        final int[] bx = new int[count];
+        final int[] by = new int[count];
+        final int[] bz = new int[count];
+        for (int i = 0; i < count; i++) {
+            final DensityFunction.FunctionContext ctx = contextProvider.forIndex(i);
+            bx[i] = ctx.blockX();
+            by[i] = ctx.blockY();
+            bz[i] = ctx.blockZ();
+        }
+
+        // CPU fallback / parity sampler: EXACTLY the vanilla BlendedNoise.compute arithmetic.
+        final NoiseJob.Sampler scalar = i ->
+            node.compute(new DensityFunction.SinglePointContext(bx[i], by[i], bz[i]));
+
+        final NoiseJob job = NoiseJob.blendedNoise(count, bx, by, bz, spec, scalar);
+        final NoiseResult result;
+        try {
+            result = active.sampleNoise(job);
+        } catch (final Throwable t) {
+            // Never let a compute error escape into worldgen — exact upstream fill.
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+        final double[] raw = result.raw();
+
+        if (ComputeConfig.isDebug()) {
+            final long n = GPU_DISPATCHES.incrementAndGet();
+            // Runtime bit-exact parity audit on the REAL production cell-corner batch:
+            // every Nth dispatch, re-evaluate the vanilla scalar (BlendedNoise.compute)
+            // and assert GPU == vanilla bit-for-bit (Double.doubleToLongBits). Proves the
+            // stock-terrain offload is bit-exact on the actual data, not just at startup.
+            if (n == 1L || (n % 1000L) == 0L) {
+                int mismatches = 0;
+                int firstBad = -1;
+                for (int i = 0; i < count; i++) {
+                    if (Double.doubleToLongBits(raw[i]) != Double.doubleToLongBits(scalar.sampleAt(i))) {
+                        if (firstBad < 0) {
+                            firstBad = i;
+                        }
+                        mismatches++;
+                    }
+                }
+                if (mismatches == 0) {
+                    LOGGER.info("[compute] BlendedNoise GPU offload active — dispatch #{} (cellCorners={}, mainOct={}, limitOct={}, backend={}) — runtime parity OK (bit-exact vs vanilla)",
+                        n, count, spec.mainOctaveCount(), spec.limitOctaveCount(), result.producedBy());
+                } else {
+                    LOGGER.warn("[compute] BlendedNoise GPU dispatch #{} runtime parity MISMATCH: {}/{} corners differ (first @corner {})",
+                        n, mismatches, count, firstBad);
+                }
+            }
+        }
+
+        System.arraycopy(raw, 0, output, 0, count);
+    }
+}
diff --git a/com/coderyo/compute/BlendedNoiseSpec.java b/com/coderyo/compute/BlendedNoiseSpec.java
new file mode 100644
index 0000000000000000000000000000000000000000..63bd22f5010b8afdf4a0a9d8406183ad68e50054
--- /dev/null
+++ b/com/coderyo/compute/BlendedNoiseSpec.java
@@ -0,0 +1,183 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import net.minecraft.world.level.levelgen.synth.BlendedNoise;
+import net.minecraft.world.level.levelgen.synth.ImprovedNoise;
+import net.minecraft.world.level.levelgen.synth.PerlinNoise;
+
+/**
+ * Flattened, GPU-offloadable descriptor of a vanilla {@code BlendedNoise} — the stock
+ * 3D terrain density noise (issue #19, design-spec §6.2).
+ *
+ * <p>It captures the EXACT private state {@code BlendedNoise.compute()} reads — the
+ * three {@code PerlinNoise} octave stacks ({@code mainNoise} up to 8 octaves,
+ * {@code minLimitNoise}/{@code maxLimitNoise} up to 16 octaves each), each octave's
+ * 256-byte permutation table and offsets, plus the derived multipliers
+ * ({@code xzMultiplier}/{@code yMultiplier}), the {@code xzFactor}/{@code yFactor}
+ * divisors, and the {@code smearScaleMultiplier} — so the
+ * {@link com.coderyo.compute.opencl.BlendedNoiseKernel} reproduces
+ * {@code compute()} bit-exactly. The CPU parity oracle re-evaluates the very same
+ * {@code BlendedNoise} object, so the comparison is GPU-vs-vanilla.
+ *
+ * <p><b>Octave layout.</b> Each stack is flattened in {@code compute()} iteration
+ * order: octave {@code i} corresponds to {@code stack.getOctaveNoise(i)} (which is
+ * {@code noiseLevels[len-1-i]}) and uses {@code pow = 2^-i}. The kernel walks
+ * {@code i = 0 .. count} mirroring the {@code pow /= 2.0} accumulation. A
+ * null/zero-amplitude octave is marked {@code present[i]==0} and contributes nothing,
+ * exactly as {@code compute()} skips a null {@code ImprovedNoise}.
+ *
+ * <p>Note {@code compute()} does NOT pre-multiply per-octave amplitudes (unlike
+ * {@code PerlinNoise.getValue}): it divides each octave's noise by {@code pow} and
+ * sums. So the kernel needs only the permutation/offsets and {@code present}; the
+ * scalar {@code pow} ladder is recomputed in-kernel identically.
+ */
+public final class BlendedNoiseSpec {
+
+    private final int mainOctaveCount;   // octaves of mainNoise (loop runs 0..8 in vanilla)
+    private final int limitOctaveCount;  // octaves of min/max stacks (loop runs 0..16)
+
+    // mainNoise stack
+    private final int[] mainPerm;        // mainOctaveCount * 256
+    private final double[] mainXo;
+    private final double[] mainYo;
+    private final double[] mainZo;
+    private final int[] mainPresent;
+
+    // minLimitNoise stack
+    private final int[] minPerm;
+    private final double[] minXo;
+    private final double[] minYo;
+    private final double[] minZo;
+    private final int[] minPresent;
+
+    // maxLimitNoise stack
+    private final int[] maxPerm;
+    private final double[] maxXo;
+    private final double[] maxYo;
+    private final double[] maxZo;
+    private final int[] maxPresent;
+
+    private final double xzMultiplier;
+    private final double yMultiplier;
+    private final double xzFactor;
+    private final double yFactor;
+    private final double smearScaleMultiplier;
+
+    private BlendedNoiseSpec(final int mainOctaveCount, final int limitOctaveCount,
+                             final int[] mainPerm, final double[] mainXo, final double[] mainYo, final double[] mainZo, final int[] mainPresent,
+                             final int[] minPerm, final double[] minXo, final double[] minYo, final double[] minZo, final int[] minPresent,
+                             final int[] maxPerm, final double[] maxXo, final double[] maxYo, final double[] maxZo, final int[] maxPresent,
+                             final double xzMultiplier, final double yMultiplier, final double xzFactor, final double yFactor,
+                             final double smearScaleMultiplier) {
+        this.mainOctaveCount = mainOctaveCount;
+        this.limitOctaveCount = limitOctaveCount;
+        this.mainPerm = mainPerm;
+        this.mainXo = mainXo;
+        this.mainYo = mainYo;
+        this.mainZo = mainZo;
+        this.mainPresent = mainPresent;
+        this.minPerm = minPerm;
+        this.minXo = minXo;
+        this.minYo = minYo;
+        this.minZo = minZo;
+        this.minPresent = minPresent;
+        this.maxPerm = maxPerm;
+        this.maxXo = maxXo;
+        this.maxYo = maxYo;
+        this.maxZo = maxZo;
+        this.maxPresent = maxPresent;
+        this.xzMultiplier = xzMultiplier;
+        this.yMultiplier = yMultiplier;
+        this.xzFactor = xzFactor;
+        this.yFactor = yFactor;
+        this.smearScaleMultiplier = smearScaleMultiplier;
+    }
+
+    /** Extract a GPU spec from a live {@code BlendedNoise}; never null for a standard layout. */
+    public static BlendedNoiseSpec from(final BlendedNoise noise) {
+        // Vanilla compute() loops main over [0,8) and min/max over [0,16), using
+        // getOctaveNoise(i) = noiseLevels[len-1-i]. We extract exactly those counts.
+        final Stack main = extractStack(noise.coderyoMainNoise(), 8);
+        final Stack min = extractStack(noise.coderyoMinLimitNoise(), 16);
+        final Stack max = extractStack(noise.coderyoMaxLimitNoise(), 16);
+        if (main == null || min == null || max == null) {
+            return null;
+        }
+        return new BlendedNoiseSpec(
+            8, 16,
+            main.perm, main.xo, main.yo, main.zo, main.present,
+            min.perm, min.xo, min.yo, min.zo, min.present,
+            max.perm, max.xo, max.yo, max.zo, max.present,
+            noise.coderyoXzMultiplier(), noise.coderyoYMultiplier(),
+            noise.coderyoXzFactor(), noise.coderyoYFactor(), noise.coderyoSmearScaleMultiplier());
+    }
+
+    private static final class Stack {
+        final int[] perm;
+        final double[] xo;
+        final double[] yo;
+        final double[] zo;
+        final int[] present;
+
+        Stack(final int count) {
+            this.perm = new int[count * 256];
+            this.xo = new double[count];
+            this.yo = new double[count];
+            this.zo = new double[count];
+            this.present = new int[count];
+        }
+    }
+
+    /**
+     * Extract {@code count} octaves in {@code compute()} iteration order: octave
+     * {@code i} = {@code perlin.getOctaveNoise(i)}. A null octave (zero amplitude) is
+     * marked absent, exactly as {@code compute()} skips it.
+     */
+    private static Stack extractStack(final PerlinNoise perlin, final int count) {
+        final Stack s = new Stack(count);
+        for (int i = 0; i < count; i++) {
+            final ImprovedNoise octave = perlin.getOctaveNoise(i);
+            if (octave != null) {
+                final int[] p = octave.coderyoPermutationUnsigned();
+                System.arraycopy(p, 0, s.perm, i * 256, 256);
+                s.xo[i] = octave.xo;
+                s.yo[i] = octave.yo;
+                s.zo[i] = octave.zo;
+                s.present[i] = 1;
+            } else {
+                s.present[i] = 0;
+            }
+        }
+        return s;
+    }
+
+    public int mainOctaveCount() { return this.mainOctaveCount; }
+    public int limitOctaveCount() { return this.limitOctaveCount; }
+
+    public int[] mainPerm() { return this.mainPerm; }
+    public double[] mainXo() { return this.mainXo; }
+    public double[] mainYo() { return this.mainYo; }
+    public double[] mainZo() { return this.mainZo; }
+    public int[] mainPresent() { return this.mainPresent; }
+
+    public int[] minPerm() { return this.minPerm; }
+    public double[] minXo() { return this.minXo; }
+    public double[] minYo() { return this.minYo; }
+    public double[] minZo() { return this.minZo; }
+    public int[] minPresent() { return this.minPresent; }
+
+    public int[] maxPerm() { return this.maxPerm; }
+    public double[] maxXo() { return this.maxXo; }
+    public double[] maxYo() { return this.maxYo; }
+    public double[] maxZo() { return this.maxZo; }
+    public int[] maxPresent() { return this.maxPresent; }
+
+    public double xzMultiplier() { return this.xzMultiplier; }
+    public double yMultiplier() { return this.yMultiplier; }
+    public double xzFactor() { return this.xzFactor; }
+    public double yFactor() { return this.yFactor; }
+    public double smearScaleMultiplier() { return this.smearScaleMultiplier; }
+}
diff --git a/com/coderyo/compute/NoiseJob.java b/com/coderyo/compute/NoiseJob.java
index 1c13f335a92a19c140d9d4c0b92dcb6d5d7fe0b6..f9388e6409b711480be04dba39b0e561d83a0287 100644
--- a/com/coderyo/compute/NoiseJob.java
+++ b/com/coderyo/compute/NoiseJob.java
@@ -63,6 +63,7 @@ public final class NoiseJob {
     private final Sampler sampler;
     private final Primitive primitive;          // nullable
     private final NormalNoiseSpec normalNoise;  // nullable (issue #14 NormalNoise offload)
+    private final BlendedNoiseSpec blendedNoise; // nullable (issue #19 stock-terrain BlendedNoise offload)
 
     /**
      * @param count   number of sample points
@@ -75,12 +76,12 @@ public final class NoiseJob {
      */
     public NoiseJob(final int count, final int[] blockX, final int[] blockY, final int[] blockZ,
                     final long seed, final Sampler sampler, final Primitive primitive) {
-        this(count, blockX, blockY, blockZ, seed, sampler, primitive, null);
+        this(count, blockX, blockY, blockZ, seed, sampler, primitive, null, null);
     }
 
     private NoiseJob(final int count, final int[] blockX, final int[] blockY, final int[] blockZ,
                      final long seed, final Sampler sampler, final Primitive primitive,
-                     final NormalNoiseSpec normalNoise) {
+                     final NormalNoiseSpec normalNoise, final BlendedNoiseSpec blendedNoise) {
         if (count < 0) {
             throw new IllegalArgumentException("count < 0: " + count);
         }
@@ -95,12 +96,13 @@ public final class NoiseJob {
         this.sampler = Objects.requireNonNull(sampler, "sampler");
         this.primitive = primitive;
