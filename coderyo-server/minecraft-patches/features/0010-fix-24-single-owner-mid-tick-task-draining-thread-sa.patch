@@ -352,7 +363,30 @@ public class ServerLevel extends Level implements WorldGenLevel, ServerEntityGet
 
     @Override
     public final void moonrise$midTickTasks() {
+        // coderyoMC start - issue #24: single-owner mid-tick task draining.
+        // The mid-tick task queue lives on each ServerChunkCache's MainThreadExecutor (one
+        // shared BlockableEventLoop per level). Vanilla drains it from guardEntityTick after
+        // every entity. Under region.enabled, entity ticking fans out across region worker
+        // threads, so MULTIPLE workers would call chunkSource.pollTask() on the SAME shared
+        // queue concurrently. BlockableEventLoop.pollTask is peek-then-remove (TOCTOU); two
+        // workers race and one hits AbstractQueue.remove() on an empty queue ->
+        // NoSuchElementException -> the whole region tick aborts (the profiling §1 crash).
+        //
+        // Worse, executing a mid-tick chunk-system task on region B's worker could run work
+        // targeting region A's chunks (cross-region write). So we make the drain SINGLE-OWNER:
+        // ONLY the orchestrator (main) thread polls the level's shared mid-tick queue. Region
+        // workers skip it — the orchestrator already drains these tasks heavily before the
+        // parallel phase (runAllTasksAtTickStart), inside its own suppressed level.tick(), and
+        // after the barrier / while waiting for the next tick. Mid-tick draining is a chunk-
+        // progression OPTIMISATION (keep chunk-system tasks flowing during the tick), not a
+        // correctness requirement for the entity tick: chunk loads still complete at the tick
+        // boundary, so skipping it on workers cannot deadlock. region.enabled=false =>
+        // RegionWorkerThread.isCurrent() is always false => byte-for-byte vanilla drain.
+        if (com.coderyo.region.RegionWorkerThread.isCurrent()) {
+            return;
+        }
         ((ca.spottedleaf.moonrise.patches.chunk_system.server.ChunkSystemMinecraftServer)this.server).moonrise$executeMidTickTasks();
+        // coderyoMC end - issue #24
     }
 
     @Override
