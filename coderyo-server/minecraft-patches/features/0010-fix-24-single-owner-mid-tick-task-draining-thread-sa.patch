diff --git a/com/coderyo/region/RegionWorkerThread.java b/com/coderyo/region/RegionWorkerThread.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffe80bf4a621a38b34706eb2d28311dfefd348d3
--- /dev/null
+++ b/com/coderyo/region/RegionWorkerThread.java
@@ -0,0 +1,34 @@
+/*
+ * coderyoMC — regionized multithreading core. Clean-room independent
+ * implementation; Folia (GPL-3.0) studied as concept only, never copied.
+ */
+package com.coderyo.region;
+
+import ca.spottedleaf.moonrise.common.util.TickThread;
+
+/**
+ * The worker thread that the {@link WorkStealingRegionScheduler} ticks regions on.
+ *
+ * <p>It IS a {@link TickThread} so Moonrise's tick-thread assertions (fired throughout
+ * entity / block-entity ticking) pass on region workers — the assertion reads
+ * {@code instanceof TickThread}. We reuse only that public, non-Folia identity check and
+ * NONE of Folia's region threading.
+ *
+ * <p><b>Why this is a top-level public type (issue #24).</b> The parallel region tick
+ * re-enters per-level shared state that must be drained / mutated on a single owner (e.g.
+ * the {@code ServerChunkCache} mid-tick task queue). The discriminator "am I on a region
+ * worker, not the orchestrator?" is {@link #isCurrent()} — so the shared mid-tick queue is
+ * polled only by the orchestrator (single-owner draining), never by a region worker. This
+ * preserves single-writer-per-target without changing the disabled (vanilla) path.
+ */
+public final class RegionWorkerThread extends TickThread {
+
+    RegionWorkerThread(final Runnable run, final int idx) {
+        super(run, "coderyo-region-worker-" + idx);
+    }
+
+    /** True iff the calling thread is a region scheduler worker (not the orchestrator/main). */
+    public static boolean isCurrent() {
+        return Thread.currentThread() instanceof RegionWorkerThread;
+    }
+}
