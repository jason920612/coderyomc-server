@@ -0,0 +1,53 @@
+/*
+ * coderyoMC — regionized multithreading core. Clean-room independent
+ * implementation; Folia (GPL-3.0) studied as concept only, never copied.
+ */
+package com.coderyo.region.transfer;
+
+import com.coderyo.region.RegionId;
+import java.util.UUID;
+import net.minecraft.resources.ResourceKey;
+import net.minecraft.world.entity.Entity;
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.Level;
+
+/**
+ * Minimal hand-off descriptor for an entity crossing a region boundary
+ * (design-spec §4.4).
+ *
+ * <p>Unlike the design-spec sketch (which serialized NBT for a fully detached
+ * teleport), this conservative P1.2c implementation keeps the live {@link Entity}
+ * object — Moonrise's per-level entity storage already owns the object's lifecycle
+ * and its placement in the destination chunk. What "ownership transfer" changes here
+ * is purely <b>which region is allowed to tick the entity</b>: the source region
+ * detaches it (stops ticking it, marks it {@code IN_FLIGHT}) and the destination
+ * region re-attaches it (resumes ticking it on its next tick). No NBT round-trip is
+ * needed because the entity never leaves the world; it only changes owning region.
+ *
+ * <p>The payload records the source/destination {@link RegionId}, the destination
+ * dimension + chunk (so re-attach can re-validate ownership at drain time, in case
+ * regions merged/split in between), and the server-tick the transfer was posted on
+ * (diagnostics / fail-loud accounting).
+ */
+public record TransferPayload(
+    Entity entity,
+    UUID entityId,
+    RegionId from,
+    RegionId to,
+    ResourceKey<Level> destDimension,
+    long destChunkKey,
+    long postedAtTick) {
+
+    public ChunkPos destChunkPos() {
+        return ChunkPos.unpack(this.destChunkKey);
+    }
+
+    @Override
+    public String toString() {
+        return "TransferPayload[entity=" + this.entityId
+            + " R" + this.from.value() + "->R" + this.to.value()
+            + " dim=" + this.destDimension.identifier()
+            + " chunk=" + this.destChunkPos()
+            + " tick=" + this.postedAtTick + "]";
+    }
+}
