         return this.sampler.sampleAt(i);
diff --git a/com/coderyo/compute/NormalNoiseSpec.java b/com/coderyo/compute/NormalNoiseSpec.java
new file mode 100644
index 0000000000000000000000000000000000000000..815938be8cf3838d3d12f1075871e15f3593f0c8
--- /dev/null
+++ b/com/coderyo/compute/NormalNoiseSpec.java
@@ -0,0 +1,185 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import net.minecraft.world.level.levelgen.synth.ImprovedNoise;
+import net.minecraft.world.level.levelgen.synth.NormalNoise;
+import net.minecraft.world.level.levelgen.synth.PerlinNoise;
+
+/**
+ * Flattened, GPU-offloadable descriptor of a vanilla {@code NormalNoise} as used by
+ * the worldgen {@code DensityFunctions.Noise} node (issue #14, design-spec §6.2).
+ *
+ * <p>It captures the EXACT private state of {@code NormalNoise} — both
+ * {@code PerlinNoise} octave stacks (each octave's 256-byte permutation table, the
+ * three offsets, the per-octave input/value coefficients) plus the node's
+ * {@code xzScale}/{@code yScale}, the {@code INPUT_FACTOR}, and the final
+ * {@code valueFactor} — so the {@link com.coderyo.compute.opencl.NormalNoiseKernel}
+ * can reproduce {@code NormalNoise.getValue(x*xzScale, y*yScale, z*xzScale)}
+ * bit-exactly. The CPU parity oracle re-evaluates the very same {@code NormalNoise}
+ * object, so the comparison is GPU-vs-vanilla.
+ *
+ * <p>Octaves of the first stack occupy indices {@code [0, firstOctaveCount)}; the
+ * second stack occupies {@code [firstOctaveCount, octaveCount)}. A {@code null}
+ * (zero-amplitude) octave is marked {@code present[i]==0} and contributes nothing,
+ * exactly as {@code PerlinNoise.getValue} skips it.
+ */
+public final class NormalNoiseSpec {
+
+    private final int octaveCount;
+    private final int firstOctaveCount;
+    private final int[] perm;            // octaveCount * 256, unsigned 0..255
+    private final double[] xo;           // octaveCount
+    private final double[] yo;
+    private final double[] zo;
+    private final int[] present;         // octaveCount (0/1)
+    private final double[] inputFactor;  // octaveCount
+    private final double[] valueAmp;     // octaveCount
+    private final double xzScale;
+    private final double yScale;
+    private final double inputScale;     // NormalNoise INPUT_FACTOR
+    private final double valueFactor;    // NormalNoise valueFactor
+
+    private NormalNoiseSpec(final int octaveCount, final int firstOctaveCount, final int[] perm,
+                            final double[] xo, final double[] yo, final double[] zo, final int[] present,
+                            final double[] inputFactor, final double[] valueAmp, final double xzScale,
+                            final double yScale, final double inputScale, final double valueFactor) {
+        this.octaveCount = octaveCount;
+        this.firstOctaveCount = firstOctaveCount;
+        this.perm = perm;
+        this.xo = xo;
+        this.yo = yo;
+        this.zo = zo;
+        this.present = present;
+        this.inputFactor = inputFactor;
+        this.valueAmp = valueAmp;
+        this.xzScale = xzScale;
+        this.yScale = yScale;
+        this.inputScale = inputScale;
+        this.valueFactor = valueFactor;
+    }
+
+    /**
+     * Extract a GPU spec from a live {@code NormalNoise}, scaled for a
+     * {@code DensityFunctions.Noise} node with the given {@code xzScale}/{@code yScale}.
+     * Returns {@code null} when the noise is not GPU-offloadable in this cut (e.g. a
+     * stack carrying the deprecated legacy initialisation cannot be distinguished
+     * here, so we conservatively require the standard layout).
+     */
+    public static NormalNoiseSpec from(final NormalNoise noise, final double xzScale, final double yScale) {
+        final PerlinNoise first = noise.coderyoFirst();
+        final PerlinNoise second = noise.coderyoSecond();
+        final ImprovedNoise[] firstLevels = first.coderyoNoiseLevels();
+        final ImprovedNoise[] secondLevels = second.coderyoNoiseLevels();
+        final int firstCount = firstLevels.length;
+        final int total = firstCount + secondLevels.length;
+        if (total == 0) {
+            return null;
+        }
+
+        final int[] perm = new int[total * 256];
+        final double[] xo = new double[total];
+        final double[] yo = new double[total];
+        final double[] zo = new double[total];
+        final int[] present = new int[total];
+        final double[] inputFactor = new double[total];
+        final double[] valueAmp = new double[total];
+
+        if (!fillStack(first, firstLevels, 0, perm, xo, yo, zo, present, inputFactor, valueAmp)) {
+            return null;
+        }
+        if (!fillStack(second, secondLevels, firstCount, perm, xo, yo, zo, present, inputFactor, valueAmp)) {
+            return null;
+        }
+
+        return new NormalNoiseSpec(total, firstCount, perm, xo, yo, zo, present, inputFactor, valueAmp,
+            xzScale, yScale, NormalNoise.coderyoInputFactor(), noise.coderyoValueFactor());
+    }
+
+    /**
+     * Replays {@code PerlinNoise(...).getValue}'s per-octave {@code factor*=2 /
+     * valueFactor/=2} loop to pre-compute, for octave {@code i}, the input factor
+     * ({@code lowestFreqInputFactor * 2^i}) and the pre-multiplied value amplitude
+     * ({@code amplitude[i] * lowestFreqValueFactor / 2^i}). Octaves with a null
+     * {@code ImprovedNoise} (zero amplitude) are marked absent.
+     */
+    private static boolean fillStack(final PerlinNoise perlin, final ImprovedNoise[] levels, final int base,
+                                     final int[] perm, final double[] xo, final double[] yo, final double[] zo,
+                                     final int[] present, final double[] inputFactor, final double[] valueAmp) {
+        double factor = perlin.coderyoLowestFreqInputFactor();
+        double valueFactor = perlin.coderyoLowestFreqValueFactor();
+        for (int i = 0; i < levels.length; i++) {
+            final int oct = base + i;
+            final ImprovedNoise noise = levels[i];
+            if (noise != null) {
+                final int[] p = noise.coderyoPermutationUnsigned();
+                System.arraycopy(p, 0, perm, oct * 256, 256);
+                xo[oct] = noise.xo;
+                yo[oct] = noise.yo;
+                zo[oct] = noise.zo;
+                present[oct] = 1;
+                inputFactor[oct] = factor;
+                valueAmp[oct] = perlin.coderyoAmplitude(i) * valueFactor;
+            } else {
+                present[oct] = 0;
+            }
+            factor *= 2.0;
+            valueFactor /= 2.0;
+        }
+        return true;
+    }
+
+    public int octaveCount() {
+        return this.octaveCount;
+    }
+
+    public int firstOctaveCount() {
+        return this.firstOctaveCount;
+    }
+
+    public int[] perm() {
+        return this.perm;
+    }
+
+    public double[] xo() {
+        return this.xo;
+    }
+
+    public double[] yo() {
+        return this.yo;
+    }
+
+    public double[] zo() {
+        return this.zo;
+    }
+
+    public int[] present() {
+        return this.present;
+    }
+
+    public double[] inputFactor() {
+        return this.inputFactor;
+    }
+
+    public double[] valueAmp() {
+        return this.valueAmp;
+    }
+
+    public double xzScale() {
+        return this.xzScale;
+    }
+
+    public double yScale() {
+        return this.yScale;
+    }
+
+    public double inputScale() {
+        return this.inputScale;
+    }
+
+    public double valueFactor() {
+        return this.valueFactor;
+    }
+}
diff --git a/com/coderyo/compute/ParitySelfCheck.java b/com/coderyo/compute/ParitySelfCheck.java
index 222f17541f8189726964f038cb422ecaf7efe9f6..af148ff514bac93f498cb5f3f2d8e40e22dae8f8 100644
--- a/com/coderyo/compute/ParitySelfCheck.java
+++ b/com/coderyo/compute/ParitySelfCheck.java
@@ -7,6 +7,8 @@ package com.coderyo.compute;
 import com.coderyo.compute.opencl.ImprovedNoiseReference;
 import com.coderyo.compute.opencl.OpenClComputeBackend;
 import com.coderyo.compute.cpu.CpuComputeBackend;
+import net.minecraft.world.level.levelgen.XoroshiroRandomSource;
+import net.minecraft.world.level.levelgen.synth.NormalNoise;
 
 /**
  * Startup GPU↔CPU parity self-check (design-spec §6.1, §8.3). Samples the vanilla
@@ -23,8 +25,25 @@ final class ParitySelfCheck {
     private ParitySelfCheck() {
     }
 
-    /** Returns {@code null} on parity success, else a human-readable mismatch description. */
+    /**
+     * Runs BOTH parity gates: the P2 single {@code ImprovedNoise} leaf and the
+     * issue-#14 full {@code NormalNoise} multi-octave node. Returns {@code null} only
+     * if every sample of both matches within tolerance; else the first mismatch.
+     */
     static String run(final CpuComputeBackend cpu, final OpenClComputeBackend opencl, final double tolerance) {
+        final String leaf = runImprovedNoise(opencl, tolerance);
+        if (leaf != null) {
+            return "ImprovedNoise-leaf parity: " + leaf;
+        }
+        final String normal = runNormalNoise(opencl, tolerance);
+        if (normal != null) {
+            return "NormalNoise-node parity: " + normal;
+        }
+        return null;
+    }
+
+    /** Returns {@code null} on parity success, else a human-readable mismatch description. */
+    private static String runImprovedNoise(final OpenClComputeBackend opencl, final double tolerance) {
         // Deterministic permutation table from a fixed seed (vanilla XOROSHIRO path).
         final long seed = 0x6024D5F1C0DE600DL;
         final ImprovedNoiseReference ref = ImprovedNoiseReference.fromSeed(seed);
@@ -78,4 +97,75 @@ final class ParitySelfCheck {
         }
         return null;
     }
+
+    /**
+     * issue #14: full {@code NormalNoise} multi-octave parity. Builds a deterministic
+     * {@code NormalNoise} (fixed seed + a representative octave layout), samples a
+     * lattice on the GPU via the {@code NormalNoiseSpec} path, and asserts every value
+     * matches the vanilla {@code NormalNoise.getValue(x*xzScale, y*yScale, z*xzScale)}
+     * bit-for-bit. The vanilla object IS the oracle — this proves the kernel replays
+     * both PerlinNoise stacks, the per-octave factors, the node scales, and the value
+     * factor exactly before any real terrain is generated.
+     */
+    private static String runNormalNoise(final OpenClComputeBackend opencl, final double tolerance) {
+        final long seed = 0x4E0F12A7C0DE14L;
+        // A representative multi-octave layout (firstOctave=-7, several amplitudes,
+        // including a zero to exercise the "absent octave" path).
+        final NormalNoise.NoiseParameters params =
+            new NormalNoise.NoiseParameters(-7, 1.0, 1.0, 0.0, 2.0, 1.0, 0.5, 0.25, 0.125);
+        final NormalNoise noise = NormalNoise.create(new XoroshiroRandomSource(seed), params);
+        final double xzScale = 0.25;
+        final double yScale = 0.5;
+
+        final int n = 16 * 16 * 8; // 2048 points, deterministic lattice
+        final int[] bx = new int[n];
+        final int[] by = new int[n];
+        final int[] bz = new int[n];
+        int idx = 0;
+        for (int x = 0; x < 16; x++) {
+            for (int z = 0; z < 16; z++) {
+                for (int y = 0; y < 8; y++) {
+                    bx[idx] = x * 4 - 13;
+                    by[idx] = y * 7 + 2;
+                    bz[idx] = z * 3 - 5;
+                    idx++;
+                }
+            }
+        }
+
+        final double[] cpuVals = new double[n];
+        for (int i = 0; i < n; i++) {
+            cpuVals[i] = noise.getValue(bx[i] * xzScale, by[i] * yScale, bz[i] * xzScale);
+        }
+
+        final NormalNoiseSpec spec = NormalNoiseSpec.from(noise, xzScale, yScale);
+        if (spec == null) {
+            return "NormalNoiseSpec extraction returned null (not GPU-offloadable layout)";
+        }
+
+        final NoiseResult gpu;
+        try {
+            final NoiseJob job = NoiseJob.normalNoise(n, bx, by, bz, spec,
+                i -> noise.getValue(bx[i] * xzScale, by[i] * yScale, bz[i] * xzScale));
+            gpu = opencl.sampleNoise(job);
+        } catch (final Throwable t) {
+            return "GPU sampleNoise(normal) threw " + t.getClass().getSimpleName() + ": " + t.getMessage();
+        }
+
+        if (gpu.count() != n) {
+            return "result count mismatch: expected " + n + " got " + gpu.count();
+        }
+        for (int i = 0; i < n; i++) {
+            final double a = cpuVals[i];
+            final double b = gpu.value(i);
+            final boolean ok = tolerance == 0.0
+                ? Double.doubleToLongBits(a) == Double.doubleToLongBits(b)
+                : Math.abs(a - b) <= tolerance;
+            if (!ok) {
+                return String.format("sample %d at (%d,%d,%d): cpu=%s gpu=%s (tol=%s)",
+                    i, bx[i], by[i], bz[i], a, b, tolerance);
+            }
+        }
+        return null;
+    }
 }
diff --git a/com/coderyo/compute/opencl/NormalNoiseKernel.java b/com/coderyo/compute/opencl/NormalNoiseKernel.java
new file mode 100644
index 0000000000000000000000000000000000000000..f158847736ff4aeb82e407398b5bf002dd7d5e4a
--- /dev/null
+++ b/com/coderyo/compute/opencl/NormalNoiseKernel.java
@@ -0,0 +1,174 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute.opencl;
+
+/**
+ * OpenCL C kernel for the vanilla {@code NormalNoise} node (issue #14, design-spec
+ * §6.2) — the dominant heavy noise-sampling leaf of worldgen density functions.
+ *
+ * <p>This expands the GPU offload from the single {@code ImprovedNoise} leaf
+ * ({@link ImprovedNoiseKernel}) to the full multi-octave stack that actually
+ * dominates worldgen compute: a {@code NormalNoise} evaluates <em>two</em>
+ * {@code PerlinNoise} stacks, each summing many {@code ImprovedNoise} octaves, and
+ * folds in the per-octave doubling/halving arithmetic plus the final value factor.
+ * One GPU dispatch evaluates {@code NormalNoise.getValue(x*xzScale, y*yScale,
+ * z*xzScale)} for a whole lattice of sample points.
+ *
+ * <p><b>Bit-exactness (§6.2 / R6):</b> the kernel mirrors, in {@code double}
+ * precision, the EXACT arithmetic of {@code PerlinNoise.getValue} →
+ * {@code ImprovedNoise.noise(yScale=0)} → {@code Mth.lerp3}/{@code smoothstep}, and
+ * {@code NormalNoise.getValue}'s {@code (first + second) * valueFactor}. The same
+ * gradient table, the same {@code PerlinNoise.wrap} (long floor), the same per-octave
+ * {@code factor *= 2 / valueFactor /= 2} accumulation order. {@code FP_CONTRACT OFF}
+ * keeps {@code a*b+c} as two IEEE-754 ops, so the result is bit-identical to the CPU
+ * twin ({@link NormalNoiseReference}).
+ *
+ * <p><b>Layout.</b> Both PerlinNoise stacks are flattened into one contiguous run of
+ * {@code octaveCount} octaves (first stack's octaves, then second stack's). Per
+ * octave the host supplies: a 256-byte permutation table ({@code perm[oct*256..]}),
+ * the three offsets ({@code xo/yo/zo[oct]}), a {@code present} flag (0 for a
+ * null/zero-amplitude octave, which contributes nothing), and the pre-multiplied
+ * coefficients {@code inputFactor[oct]} (= {@code lowestFreqInputFactor * 2^localIdx})
+ * and {@code valueAmp[oct]} (= {@code amplitude[localIdx] * lowestFreqValueFactor /
+ * 2^localIdx}). {@code firstOctaveCount} marks where the second stack begins; the
+ * second stack's input coordinates are pre-scaled by {@code INPUT_FACTOR} in the
+ * kernel exactly as vanilla does.
+ *
+ * <p>Requires {@code cl_khr_fp64}; if a device lacks it the backend reports
+ * unavailable and the registry falls back to CPU.
