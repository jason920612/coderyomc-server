diff --git a/com/coderyo/compute/NoiseGpuBridge.java b/com/coderyo/compute/NoiseGpuBridge.java
new file mode 100644
index 0000000000000000000000000000000000000000..0079b8bcafbbfee441272fd98fd5fb06c0d0ef49
--- /dev/null
+++ b/com/coderyo/compute/NoiseGpuBridge.java
@@ -0,0 +1,147 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import java.util.concurrent.atomic.AtomicLong;
+import net.minecraft.world.level.levelgen.DensityFunction;
+import net.minecraft.world.level.levelgen.synth.NormalNoise;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+/**
+ * Production hook for the {@code DensityFunctions.Noise} density node (issue #14) —
+ * the dominant heavy noise-sampling leaf of worldgen density functions. It expands
+ * the GPU offload from the single {@code ImprovedNoise} leaf wired in P2
+ * ({@link DensityComputeBridge}) to the FULL {@code NormalNoise} multi-octave stack
+ * that actually dominates compute (two {@code PerlinNoise} stacks summing many
+ * {@code ImprovedNoise} octaves), folding in the node's {@code xzScale}/{@code yScale}
+ * arithmetic and the value factor over a whole sample lattice in one GPU dispatch.
+ *
+ * <p><b>Routing (correctness-first):</b>
+ * <ul>
+ *   <li>{@code gpu.worldgen.enabled=false} (default) or CPU backend selected →
+ *       delegate to the EXACT upstream {@code contextProvider.fillAllDirectly(output,
+ *       node)}. Byte-for-byte vanilla; no allocation, no GPU probe beyond the one-time
+ *       backend selection.</li>
+ *   <li>GPU backend selected AND the lattice clears the batch threshold AND the
+ *       node's {@code NormalNoise} is GPU-offloadable → batch the lattice's
+ *       coordinates and route through {@link ComputeBackend#sampleNoise}. The
+ *       backend reproduces {@code NormalNoise.getValue(x*xzScale, y*yScale,
+ *       z*xzScale)} bit-exactly (parity-gated at startup); any per-job failure
+ *       degrades transparently to CPU via the registry's fallback wrapper.</li>
+ *   <li>Otherwise (no live {@code NormalNoise}, sub-threshold lattice, unsupported
+ *       layout) → exact upstream fill.</li>
+ * </ul>
+ *
+ * <p>Other density node types (arithmetic {@code Ap2}, {@code Clamp}, {@code Spline},
+ * {@code WeirdScaledSampler}, {@code RangeChoice}, blended/shifted noise, cache/
+ * interpolation wrappers) remain on the CPU path in this cut; see docs/P2-gpu-notes.md.
+ */
+public final class NoiseGpuBridge {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger("coderyo-compute");
+    private static volatile ComputeBackend backend;
+    /** Diagnostic only: number of NormalNoise lattices dispatched to the GPU this session. */
+    private static final AtomicLong GPU_DISPATCHES = new AtomicLong();
+
+    private NoiseGpuBridge() {
+    }
+
+    private static ComputeBackend backend() {
+        ComputeBackend local = backend;
+        if (local == null) {
+            synchronized (NoiseGpuBridge.class) {
+                local = backend;
+                if (local == null) {
+                    local = ComputeBackendRegistry.get().select();
+                    backend = local;
+                }
+            }
+        }
+        return local;
+    }
+
+    /**
+     * Fill {@code output} with {@code NormalNoise.getValue(blockX*xzScale,
+     * blockY*yScale, blockZ*xzScale)} at every lattice point described by
+     * {@code contextProvider}. Always produces values identical to
+     * {@code contextProvider.fillAllDirectly(output, node)} (vanilla); only the
+     * compute engine differs, gated on the flag and selected backend.
+     *
+     * <p>Called from {@code DensityFunctions.Noise.fillArray}. The {@code node} is the
+     * Noise density node itself (so the upstream fall-back path is unchanged); the
+     * scalar accessors carry the live {@code NormalNoise} and the two scales.
+     */
+    public static void fillArray(final DensityFunction node,
+                                 final NormalNoise noise,
+                                 final double xzScale,
+                                 final double yScale,
+                                 final double[] output,
+                                 final DensityFunction.ContextProvider contextProvider) {
+        // Default & CPU path: byte-for-byte vanilla.
+        if (!ComputeConfig.isEnabled()) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+        final ComputeBackend active = backend();
+        if (active == null || "cpu".equals(active.name())) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+
+        final int count = output.length;
+        // Sub-threshold lattices stay on CPU (PCIe / launch overhead; §6.4). A null
+        // noise (NoiseHolder with no resolved NormalNoise → vanilla returns 0.0) is
+        // not offloaded; the exact upstream fill handles that case.
+        if (noise == null || count < ComputeConfig.batchThreshold()) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+
+        final NormalNoiseSpec spec = NormalNoiseSpec.from(noise, xzScale, yScale);
+        if (spec == null) {
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+
+        // Extract the lattice coordinates for the batch.
+        final int[] bx = new int[count];
+        final int[] by = new int[count];
+        final int[] bz = new int[count];
+        for (int i = 0; i < count; i++) {
+            final DensityFunction.FunctionContext ctx = contextProvider.forIndex(i);
+            bx[i] = ctx.blockX();
+            by[i] = ctx.blockY();
+            bz[i] = ctx.blockZ();
+        }
+
+        // CPU fallback / parity sampler: EXACTLY the vanilla Noise.compute arithmetic.
+        final NoiseJob.Sampler scalar = i ->
+            noise.getValue(bx[i] * xzScale, by[i] * yScale, bz[i] * xzScale);
+
+        final NoiseJob job = NoiseJob.normalNoise(count, bx, by, bz, spec, scalar);
+        final NoiseResult result;
+        try {
+            result = active.sampleNoise(job);
+        } catch (final Throwable t) {
+            // Defensive: registry already wraps GPU failures, but never let a compute
+            // error escape into worldgen — fall back to the exact upstream fill.
+            contextProvider.fillAllDirectly(output, node);
+            return;
+        }
+        final double[] raw = result.raw();
+        System.arraycopy(raw, 0, output, 0, count);
+
+        // One-time (and periodic) diagnostic so e2e can confirm the GPU NormalNoise
+        // path was actually exercised during real worldgen, not just at startup.
+        if (ComputeConfig.isDebug()) {
+            final long n = GPU_DISPATCHES.incrementAndGet();
+            if (n == 1L || (n % 1000L) == 0L) {
+                LOGGER.info("[compute] NormalNoise GPU offload active — dispatch #{} (lattice={}, octaves={}, backend={})",
+                    n, count, spec.octaveCount(), result.producedBy());
+            }
+        }
+    }
+}
