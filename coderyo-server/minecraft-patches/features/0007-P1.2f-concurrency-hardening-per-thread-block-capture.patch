@@ -24,7 +24,29 @@ public class SaplingBlock extends VegetationBlock implements BonemealableBlock {
     public static final IntegerProperty STAGE = BlockStateProperties.STAGE;
     private static final VoxelShape SHAPE = Block.column(12.0, 0.0, 12.0);
     protected final TreeGrower treeGrower;
-    public static org.bukkit.@org.jspecify.annotations.Nullable TreeType treeType; // CraftBukkit
+    // coderyoMC start - P1.2f: per-thread tree type (concurrency hazard, issue #8). This static
+    // is written by TreeGrower.setTreeType inside growTree (on the ticking thread) and read back
+    // after growTree. Under parallel region ticking two region workers growing trees concurrently
+    // would race this single static slot (wrong TreeType in a StructureGrowEvent). A ThreadLocal
+    // gives each ticking thread its own slot; single-threaded (region.enabled=false) it behaves
+    // exactly like the old static (one thread => one value). Access via the helpers below.
+    private static final ThreadLocal<org.bukkit.TreeType> TREE_TYPE = new ThreadLocal<>();
+
+    public static void coderyoSetTreeType(final org.bukkit.@org.jspecify.annotations.Nullable TreeType type) {
+        if (type == null) {
+            TREE_TYPE.remove();
+        } else {
+            TREE_TYPE.set(type);
+        }
+    }
+
+    /** Read-and-clear the calling thread's captured tree type (used after growTree). */
+    public static org.bukkit.@org.jspecify.annotations.Nullable TreeType coderyoTakeTreeType() {
