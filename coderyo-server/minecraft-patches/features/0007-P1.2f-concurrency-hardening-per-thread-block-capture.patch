--- a/net/minecraft/world/level/Level.java
+++ b/net/minecraft/world/level/Level.java
@@ -160,18 +160,70 @@ public abstract class Level implements LevelAccessor, AutoCloseable, ca.spottedl
     private final CraftWorld world;
     public org.bukkit.generator.@Nullable ChunkGenerator generator;
 
-    public boolean captureBlockStates = false;
-    public boolean captureTreeGeneration = false;
-    public Map<BlockPos, org.bukkit.craftbukkit.block.CraftBlockState> capturedBlockStates = new java.util.LinkedHashMap<>(); // Paper
-    public Map<BlockPos, BlockEntity> capturedBlockEntities = new java.util.LinkedHashMap<>(); // Paper - Retain block place order when capturing blockstates
+    // coderyoMC start - P1.2f: per-thread block-capture state (concurrency hazard, issue #8).
+    // Paper's block-state / tree-generation capture (captureBlockStates / captureTreeGeneration
+    // + the capturedBlockStates / capturedBlockEntities maps) is a SHARED per-level work area
+    // that setBlock / getBlockState / setBlockEntity read & write. Under parallel region ticking
+    // (region.enabled=true) two region workers can run setBlock-capturing work CONCURRENTLY on the
+    // SAME level -- e.g. SaplingBlock.randomTick growing two trees in two different regions, or a
+    // dispenser (block-entity tick) dispensing a sapling -- racing these maps (lost/cross-region
+    // tree blocks, ConcurrentModificationException). This is the SAME class of hazard as the
+    // CollectingNeighborUpdater work-stack fixed in P1.2e. Captures are strictly nested + drained
+    // before the worker returns (set true -> grow -> set false -> drain map), and the affected
+    // chunks are owned by the ticking region, so giving each ticking thread its OWN capture frame
+    // is correct -- and IDENTICAL to vanilla when single-threaded (region.enabled=false => only the
+    // orchestrator thread ever touches it => one CaptureState => byte-for-byte vanilla).
+    public static final class CaptureState {
+        public boolean captureBlockStates = false;
+        public boolean captureTreeGeneration = false;
+        public final Map<BlockPos, org.bukkit.craftbukkit.block.CraftBlockState> capturedBlockStates = new java.util.LinkedHashMap<>(); // Paper
+        public final Map<BlockPos, BlockEntity> capturedBlockEntities = new java.util.LinkedHashMap<>(); // Paper - Retain block place order when capturing blockstates
+    }
+
+    private final ThreadLocal<CaptureState> coderyoCapture = ThreadLocal.withInitial(CaptureState::new);
+
+    /** The calling thread's block-capture frame (per-region under parallel ticking; the single
+     *  orchestrator frame when region.enabled=false). */
+    public CaptureState coderyoCapture() {
+        return this.coderyoCapture.get();
+    }
+    // coderyoMC end - P1.2f
     @Nullable
     public List<net.minecraft.world.entity.item.ItemEntity> captureDrops;
     public final it.unimi.dsi.fastutil.objects.Object2LongOpenHashMap<SpawnCategory> ticksPerSpawnCategory = new it.unimi.dsi.fastutil.objects.Object2LongOpenHashMap<>();
     // Paper start - EAR 2
-    public int wakeupInactiveRemainingAnimals;
-    public int wakeupInactiveRemainingFlying;
-    public int wakeupInactiveRemainingMonsters;
-    public int wakeupInactiveRemainingVillagers;
+    // coderyoMC start - P1.2f: atomic EAR wakeup budgets (concurrency hazard, issue #8).
+    // These per-level counters are REFILLED once per tick on the orchestrator (ActivationRange
+    // .activateEntities, before region fan-out) and then DECREMENTED from ActivationRange
+    // .checkInactiveWakeup, which is reached via tickNonPassenger -> checkIfActive on a REGION
+    // WORKER thread. Under parallel region ticking many workers decrement the SAME counter
+    // concurrently -> a lost-update race on a non-atomic int (design-spec §4.5 "non-atomic
+    // counters"). Promoted to AtomicInteger with a bounded compare-and-set "consume" so the
+    // budget is never driven below 0 and no decrement is lost. region.enabled=false => only the
+    // orchestrator thread touches them => semantically identical to the old plain int.
+    public final java.util.concurrent.atomic.AtomicInteger wakeupInactiveRemainingAnimals = new java.util.concurrent.atomic.AtomicInteger();
+    public final java.util.concurrent.atomic.AtomicInteger wakeupInactiveRemainingFlying = new java.util.concurrent.atomic.AtomicInteger();
+    public final java.util.concurrent.atomic.AtomicInteger wakeupInactiveRemainingMonsters = new java.util.concurrent.atomic.AtomicInteger();
+    public final java.util.concurrent.atomic.AtomicInteger wakeupInactiveRemainingVillagers = new java.util.concurrent.atomic.AtomicInteger();
+
+    /** Refill a wakeup budget once per tick (orchestrator): {@code min(cur+1, cap)}. */
+    public static void coderyoRefillWakeup(final java.util.concurrent.atomic.AtomicInteger budget, final int cap) {
+        budget.updateAndGet(cur -> Math.min(cur + 1, cap));
+    }
+
+    /** Atomically consume one unit of a wakeup budget iff > 0 (region worker). Returns true if
+     *  a unit was consumed. Never drives the budget below 0, never loses a concurrent decrement. */
+    public static boolean coderyoTryConsumeWakeup(final java.util.concurrent.atomic.AtomicInteger budget) {
+        int cur;
+        do {
+            cur = budget.get();
+            if (cur <= 0) {
+                return false;
+            }
+        } while (!budget.compareAndSet(cur, cur - 1));
+        return true;
+    }
+    // coderyoMC end - P1.2f
     // Paper end - EAR 2
     public boolean populating;
     public final org.spigotmc.SpigotWorldConfig spigotConfig; // Spigot
