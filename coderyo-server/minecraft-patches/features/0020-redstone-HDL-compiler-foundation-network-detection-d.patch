+        put(level, 51, 100, 100, STONE);  put(level, 51, 101, 100, Blocks.JUKEBOX.defaultBlockState()); // analog source
+        put(level, 52, 100, 100, STONE);  put(level, 52, 101, 100, COMP_CMP_W); // faces WEST -> reads jukebox
