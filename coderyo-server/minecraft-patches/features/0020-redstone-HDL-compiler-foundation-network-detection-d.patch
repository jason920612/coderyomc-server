+/*
+ * coderyoMC — redstone HDL-compiler (Stream B). Clean-room independent implementation.
+ * MCHPRS studied as concept only (compile redstone to a logic graph); never copied.
+ */
+package com.coderyo.redstone;
+
+import it.unimi.dsi.fastutil.longs.Long2ObjectMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectOpenHashMap;
+import it.unimi.dsi.fastutil.longs.LongOpenHashSet;
+import it.unimi.dsi.fastutil.longs.LongSet;
+import java.util.ArrayDeque;
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.Deque;
+import java.util.List;
+import java.util.HashMap;
+import java.util.Map;
+import net.minecraft.core.BlockPos;
+import net.minecraft.core.Direction;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.world.level.block.Blocks;
+import net.minecraft.world.level.block.ComparatorBlock;
+import net.minecraft.world.level.block.DiodeBlock;
+import net.minecraft.world.level.block.ButtonBlock;
+import net.minecraft.world.level.block.ObserverBlock;
+import net.minecraft.world.level.block.RedStoneWireBlock;
+import net.minecraft.world.level.block.RedstoneLampBlock;
+import net.minecraft.world.level.block.RedstoneTorchBlock;
+import net.minecraft.world.level.block.TargetBlock;
+import net.minecraft.world.level.block.piston.MovingPistonBlock;
+import net.minecraft.world.level.block.piston.PistonBaseBlock;
+import net.minecraft.world.level.block.piston.PistonHeadBlock;
+import net.minecraft.world.level.block.entity.ComparatorBlockEntity;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.block.state.properties.BlockStateProperties;
+import net.minecraft.world.level.block.state.properties.ComparatorMode;
+import net.minecraft.world.level.block.state.properties.PistonType;
+import net.minecraft.world.level.material.PushReaction;
+import net.minecraft.world.level.redstone.Redstone;
+
+/**
+ * The compiled logic graph + discrete-event simulator for one redstone network.
+ *
+ * <p>Design: the network's blocks are snapshotted into a {@link VirtualRedstoneWorld}
+ * grid, so ALL signal propagation (wire connection geometry, strong/weak power,
+ * lever / redstone-block sources, conductor bridging) is evaluated with the EXACT
+ * vanilla {@code BlockState}/{@code SignalGetter} code — bit-identical by construction.
+ * This class only owns the parts vanilla expresses through the scheduled-tick system:
+ * <ul>
+ *   <li><b>Wire fixpoint</b> — vanilla settles wires synchronously via neighbour-update
+ *       recursion within a game tick; we compute the identical converged power field by
+ *       relaxation ({@link #recomputeWires}). Transcribed from
+ *       {@code DefaultRedstoneWireEvaluator.calculateTargetStrength} +
+ *       {@code RedstoneWireEvaluator.getIncomingWireSignal}.</li>
+ *   <li><b>Torch / repeater delayed commits</b> — transcribed from
+ *       {@code RedstoneTorchBlock.tick} (2-tick inversion + 8-toggle/60-tick burnout)
+ *       and {@code DiodeBlock.tick}/{@code checkTickOnNeighbor} (delay 2/4/6/8, locking,
+ *       VERY_HIGH/HIGH/EXTREMELY_HIGH priorities), driven by a {@link ScheduledEntry}
+ *       queue ordered exactly like {@code LevelTicks} (trigger, priority, insertion).</li>
+ * </ul>
+ *
+ * <p>MODELLED: redstone wire, torch, repeater, lever/redstone-block sources,
+ * <b>comparator</b> (compare/subtract analog, container/block-entity input, 2-tick
+ * delay) and <b>observer</b> (2-tick pulse on observed block-state change).
+ *
+ * <p>DEFERRED (not modelled — see RedstoneDiffTestHarness): pistons, dispensers/droppers,
+ * quasi-connectivity, 0-tick pulses, item frames in front of comparators, the EIGENCRAFT
+ * / ALTERNATE_CURRENT wire algorithms and the experimental wire flood.
+ */
+final class CompiledNetwork {
+
+    private enum Kind { TORCH, REPEATER, COMPARATOR, OBSERVER, LAMP, BUTTON, TARGET, PISTON }
+
+    /**
+     * One cell of an in-flight piston contraption — the compiled analogue of a vanilla
+     * {@link net.minecraft.world.level.block.piston.PistonMovingBlockEntity}. The grid cell
+     * itself holds {@code MOVING_PISTON}; this carries the data needed to (a) animate
+     * {@code progress} exactly like {@code PistonMovingBlockEntity.tick} and (b) place the
+     * final block on finalisation. Mutable because progress advances every tick.
+     */
+    static final class MovingBlock {
+        final BlockState movedState;
+        final Direction direction;
+        final boolean extending;
+        final boolean isSource;
+        float progress;
+        float progressO;
+
+        MovingBlock(final BlockState movedState, final Direction direction, final boolean extending, final boolean isSource) {
+            this.movedState = movedState;
+            this.direction = direction;
+            this.extending = extending;
+            this.isSource = isSource;
+        }
+    }
+
+    /** Mirrors {@code TickPriority} ordinals: lower drains earlier. */
+    private static final int P_EXTREMELY_HIGH = -3;
+    private static final int P_VERY_HIGH = -2;
+    private static final int P_HIGH = -1;
+    private static final int P_NORMAL = 0;
+
+    private record ScheduledEntry(long pos, Kind kind, long trigger, int priority, long sub) {
+    }
+
+    private static final Comparator<ScheduledEntry> DRAIN_ORDER =
+        Comparator.comparingLong(ScheduledEntry::trigger)
+            .thenComparingInt(ScheduledEntry::priority)
+            .thenComparingLong(ScheduledEntry::sub);
+
+    private static final BlockState AIR = Blocks.AIR.defaultBlockState();
+
+    private final VirtualRedstoneWorld vw = new VirtualRedstoneWorld();
+    private final RedStoneWireBlock wireBlock = (RedStoneWireBlock) Blocks.REDSTONE_WIRE;
+
+    private final LongSet wires = new LongOpenHashSet();
+    private final LongSet torches = new LongOpenHashSet();
+    private final LongSet repeaters = new LongOpenHashSet();
+    private final LongSet comparators = new LongOpenHashSet();
+    private final LongSet observers = new LongOpenHashSet();
+    private final LongSet lamps = new LongOpenHashSet();
+    private final LongSet buttons = new LongOpenHashSet();
+    private final LongSet targets = new LongOpenHashSet();
+    private final LongSet pistons = new LongOpenHashSet();
+
+    /** In-flight piston-moved cells (grid cell == MOVING_PISTON), keyed by packed pos. */
+    private final Long2ObjectMap<MovingBlock> moving = new Long2ObjectOpenHashMap<>();
+
+    /** The last observed {@link BlockState} of each observer's FACING target (change detector). */
+    private final Long2ObjectMap<BlockState> lastObserved = new Long2ObjectOpenHashMap<>();
+
+    /**
+     * The live server level — used ONLY to read the analog output of a static external
+     * analog-source input (a container the comparator faces) via vanilla's
+     * {@code getAnalogOutputSignal}, which takes a {@code Level} and reads the block
+     * entity's fullness. The container is a region-owned external input; its fullness is
+     * an input to the network, not part of the logic graph we simulate. All redstone
+     * signal propagation still runs entirely over the in-memory grid.
+     */
+    private ServerLevel level;
+
+    private final List<ScheduledEntry> queue = new ArrayList<>();
+    private long subCounter;
+
+    /** Burnout history, mirroring {@code Level.redstoneUpdateInfos}. */
+    private final Deque<long[]> toggleLog = new ArrayDeque<>(); // {posLong, gameTime}
+
+    private final BlockPos.MutableBlockPos m = new BlockPos.MutableBlockPos();
+
+    /** Seed the compiled grid from the live (settled) vanilla world. */
+    static CompiledNetwork compile(final ServerLevel level, final RedstoneNetwork network) {
+        final CompiledNetwork c = new CompiledNetwork();
+        c.level = level;
+        for (final long packed : network.footprint()) {
+            final BlockPos pos = BlockPos.of(packed);
+            final BlockState state = level.getBlockState(pos);
+            c.vw.set(packed, state);
+            if (state.is(Blocks.REDSTONE_WIRE)) {
+                c.wires.add(packed);
+            } else if (state.getBlock() instanceof RedstoneTorchBlock) {
+                c.torches.add(packed);
+            } else if (state.getBlock() instanceof ComparatorBlock) {
+                c.comparators.add(packed);
+                // Private analog-output block entity, seeded from the live comparator's BE.
+                final ComparatorBlockEntity be = new ComparatorBlockEntity(pos, state);
+                if (level.getBlockEntity(pos) instanceof ComparatorBlockEntity live) {
+                    be.setOutputSignal(live.getOutputSignal());
+                }
+                c.vw.setBlockEntity(packed, be);
+            } else if (state.getBlock() instanceof DiodeBlock) {
+                c.repeaters.add(packed);
+            } else if (state.getBlock() instanceof ObserverBlock) {
+                c.observers.add(packed);
+            } else if (state.getBlock() instanceof RedstoneLampBlock) {
+                c.lamps.add(packed);
+            } else if (state.getBlock() instanceof ButtonBlock) {
+                c.buttons.add(packed);
+            } else if (state.getBlock() instanceof TargetBlock) {
+                c.targets.add(packed);
+            } else if (state.getBlock() instanceof PistonBaseBlock) {
+                c.pistons.add(packed);
+            }
+        }
+        // A piston's quasi-connectivity (QC) power read samples the block ABOVE it and that
+        // block's neighbours; snapshot those external cells so getNeighborSignal evaluates
+        // QC bit-identically on the in-memory grid (the footprint already forces the lane).
+        for (final long packed : c.pistons) {
+            final BlockPos pos = BlockPos.of(packed);
+            c.snapshotExternal(level, pos.above());
+            for (final Direction dir : Direction.values()) {
+                c.snapshotExternal(level, pos.above().relative(dir));
+                c.snapshotExternal(level, pos.relative(dir));
+            }
+        }
+        // Auxiliary external inputs that live OUTSIDE the redstone footprint: a comparator's
+        // facing target (container / analog source, and the block beyond when it's a
+        // conductor) and an observer's observed block. Snapshot their block states (and live
+        // block entity, so getAnalogOutputSignal reads the real container fullness) so the
+        // in-memory grid evaluates inputs bit-identically.
+        for (final long packed : c.comparators) {
+            final BlockPos pos = BlockPos.of(packed);
+            final Direction facing = level.getBlockState(pos).getValue(BlockStateProperties.HORIZONTAL_FACING);
+            c.snapshotExternal(level, pos.relative(facing));
+            c.snapshotExternal(level, pos.relative(facing).relative(facing));
+        }
+        for (final long packed : c.observers) {
+            final BlockPos pos = BlockPos.of(packed);
+            final Direction facing = level.getBlockState(pos).getValue(BlockStateProperties.FACING);
+            final BlockPos observed = pos.relative(facing);
+            c.snapshotExternal(level, observed);
+            c.lastObserved.put(packed, level.getBlockState(observed));
+        }
+        c.recomputeWires();
+        return c;
+    }
+
+    /** Snapshot an external input cell (block state + live block entity) if not already present. */
+    private void snapshotExternal(final ServerLevel level, final BlockPos pos) {
+        final long packed = pos.asLong();
+        final BlockState state = level.getBlockState(pos);
+        this.vw.set(packed, state);
+        if (state.hasBlockEntity()) {
+            this.vw.setBlockEntity(packed, level.getBlockEntity(pos));
+        }
+    }
+
+    BlockState state(final long packed) {
+        return this.vw.getBlockState(BlockPos.of(packed));
+    }
+
+    /** The compiled comparator's stored analog output (-1 if not a comparator); for the harness. */
+    int comparatorOutputSignal(final long packed) {
+        final ComparatorBlockEntity be = this.comparatorBE(packed);
+        return be == null ? -1 : be.getOutputSignal();
+    }
+
+    /** Apply an external source change (lever toggle / redstone-block placement). */
+    void setSource(final BlockPos pos, final BlockState state) {
+        this.vw.set(pos, state);
+    }
+
+    /**
+     * Press a button (I/O input source): set its POWERED state into the grid and schedule
+     * the self-timed un-press exactly like {@code ButtonBlock.press} (which calls
+     * {@code scheduleTick(pos, this, ticksToStayPressed)} — 20 ticks stone / 30 wood). The
+     * un-press lands on {@code nowRel + ticks}, matching the real button's scheduled tick.
+     */
+    void pressButton(final BlockPos pos, final BlockState pressed, final int ticks, final long nowRel) {
+        this.vw.set(pos, pressed);
+        this.schedule(pos.asLong(), Kind.BUTTON, ticks, P_NORMAL, nowRel);
+    }
+
+    /**
+     * Apply a target-block hit (analog I/O input source): set its OUTPUT_POWER (BlockState
+     * POWER, 0-15) into the grid and schedule the decay-to-zero exactly like
+     * {@code TargetBlock.setOutputPower} ({@code scheduleTick(pos, this, duration)} —
+     * 20 ticks for arrows / 8 for other projectiles).
+     */
+    void hitTarget(final BlockPos pos, final BlockState hit, final int duration, final long nowRel) {
+        this.vw.set(pos, hit);
+        this.schedule(pos.asLong(), Kind.TARGET, duration, P_NORMAL, nowRel);
+    }
+
+    // ----------------------------------------------------------------- stepping
+
+    /** Advance the compiled model by exactly one game tick. */
+    void step(final long tick) {
+        this.currentTick = tick;
+        // Settle wires from any source change applied since the previous step, then let
+        // observers react to whatever the source change moved.
+        this.recomputeWires();
+        this.syncObservers();
+
+        // Collect-then-run, exactly like LevelTicks.tick: gather everything due this
+        // tick first, then run in drain order. Ticks scheduled during a run get a
+        // future trigger so they land in a later step.
+        final List<ScheduledEntry> due = new ArrayList<>();
+        for (int i = this.queue.size() - 1; i >= 0; i--) {
+            if (this.queue.get(i).trigger() <= tick) {
+                due.add(this.queue.remove(i));
+            }
+        }
+        due.sort(DRAIN_ORDER);
+        for (final ScheduledEntry e : due) {
+            this.run(e, tick);
+            this.recomputeWires(); // vanilla notifies neighbours synchronously per commit
+            this.syncObservers();  // each setBlock fires updateShape on a facing observer
+        }
+
+        // Re-evaluate downstream scheduling (mirrors neighborChanged / checkTickOnNeighbor).
+        this.rescan(tick);
+
+        // Advance in-flight piston contraptions LAST. Vanilla runs the moving-block-entity
+        // tick in the SAME server tick that the block event created the mover (block events
+        // and block-entity ticking both happen inside one ServerLevel.tick), so a mover gets
+        // its first progress step on its creation tick — advancing here, after the piston
+        // block events ran this step, reproduces that (progress 0 -> 0.5 on the fire tick).
+        this.advanceMovers();
+        this.recomputeWires();
+        this.syncObservers();
+    }
+
+    private void run(final ScheduledEntry e, final long tick) {
+        switch (e.kind()) {
+            case TORCH -> this.runTorch(e.pos(), tick);
+            case REPEATER -> this.runRepeater(e.pos());
+            case COMPARATOR -> this.runComparator(e.pos());
+            case OBSERVER -> this.runObserver(e.pos());
+            case LAMP -> this.runLamp(e.pos());
+            case BUTTON -> this.runButton(e.pos());
+            case TARGET -> this.runTarget(e.pos());
+            case PISTON -> this.runPistonEvent(e.pos());
+        }
+    }
+
+    private void rescan(final long tick) {
+        for (final long pos : this.torches) {
+            this.scheduleTorchIfNeeded(pos, tick);
+        }
+        for (final long pos : this.repeaters) {
+            this.updateRepeaterLock(pos);
+            this.scheduleRepeaterIfNeeded(pos, tick);
+        }
+        for (final long pos : this.comparators) {
+            this.scheduleComparatorIfNeeded(pos, tick);
+        }
+        for (final long pos : this.lamps) {
+            this.updateLamp(pos, tick);
+        }
+        for (final long pos : this.pistons) {
+            this.schedulePistonIfNeeded(pos, tick);
+        }
+    }
+
+    // ------------------------------------------------------------------- wires
+
+    /** Iterative relaxation to the same converged power field vanilla recursion reaches. */
+    private void recomputeWires() {
+        boolean changed = true;
+        int guard = 0;
+        while (changed && guard++ < 256) {
+            changed = false;
+            for (final long packed : this.wires) {
+                this.m.set(packed);
+                final BlockState state = this.vw.getBlockState(this.m);
+                if (!state.is(Blocks.REDSTONE_WIRE)) {
+                    continue;
+                }
+                final int current = state.getValue(BlockStateProperties.POWER);
+                final int target = this.calculateTargetStrength(this.m);
+                if (target != current) {
+                    this.vw.set(packed, state.setValue(BlockStateProperties.POWER, target));
+                    changed = true;
+                }
+            }
+        }
+    }
+
+    // Transcribed from DefaultRedstoneWireEvaluator.calculateTargetStrength.
+    private int calculateTargetStrength(final BlockPos pos) {
+        final int blockSignal = this.getBlockSignal(pos);
+        return blockSignal == 15 ? blockSignal : Math.max(blockSignal, this.getIncomingWireSignal(pos));
+    }
+
+    // Transcribed from RedStoneWireBlock.getBlockSignal (self-suppression via shouldSignal).
+    private int getBlockSignal(final BlockPos pos) {
+        this.wireBlock.shouldSignal = false;
+        final int s = this.vw.getBestNeighborSignal(pos);
+        this.wireBlock.shouldSignal = true;
+        return s;
+    }
+
+    // Transcribed from RedstoneWireEvaluator.getIncomingWireSignal (wire-climb geometry).
+    private int getIncomingWireSignal(final BlockPos pos) {
+        int wireSignal = 0;
+        final BlockPos above = pos.above();
+        final boolean aboveConductor = this.vw.getBlockState(above).isRedstoneConductor(this.vw, above);
+        for (final Direction dir : Direction.Plane.HORIZONTAL) {
+            final BlockPos neighbor = pos.relative(dir);
+            wireSignal = Math.max(wireSignal, this.getWireSignal(neighbor));
+            final boolean neighborConductor = this.vw.getBlockState(neighbor).isRedstoneConductor(this.vw, neighbor);
+            if (neighborConductor && !aboveConductor) {
+                wireSignal = Math.max(wireSignal, this.getWireSignal(neighbor.above()));
+            } else if (!neighborConductor) {
+                wireSignal = Math.max(wireSignal, this.getWireSignal(neighbor.below()));
+            }
+        }
+        return Math.max(0, wireSignal - 1);
+    }
+
+    private int getWireSignal(final BlockPos pos) {
+        final BlockState s = this.vw.getBlockState(pos);
+        return s.is(Blocks.REDSTONE_WIRE) ? s.getValue(BlockStateProperties.POWER) : 0;
+    }
+
+    // ------------------------------------------------------------------ torch
+
+    private boolean torchInput(final long pos) {
+        this.m.set(pos);
+        return this.vw.hasSignal(this.m.below(), Direction.DOWN);
+    }
+
+    // Transcribed from RedstoneTorchBlock.neighborChanged.
+    private void scheduleTorchIfNeeded(final long pos, final long tick) {
+        final boolean lit = this.state(pos).getValue(BlockStateProperties.LIT);
+        if (lit == this.torchInput(pos) && !this.willTick(pos, Kind.TORCH)) {
+            this.schedule(pos, Kind.TORCH, 2, P_NORMAL, tick);
+        }
+    }
+
+    // Transcribed from RedstoneTorchBlock.tick (inversion + burnout).
+    private void runTorch(final long pos, final long tick) {
+        final boolean input = this.torchInput(pos);
+        this.pruneToggleLog(tick);
+        final BlockState state = this.state(pos);
+        final boolean lit = state.getValue(BlockStateProperties.LIT);
+        if (lit) {
+            if (input) {
+                this.setLit(pos, false);
+                if (this.toggledTooFrequently(pos, tick, true)) {
+                    this.schedule(pos, Kind.TORCH, 160, P_NORMAL, tick); // burnout restart
+                }
+            }
+        } else if (!input && !this.toggledTooFrequently(pos, tick, false)) {
+            this.setLit(pos, true);
+        }
+    }
+
+    private void setLit(final long pos, final boolean lit) {
+        this.vw.set(pos, this.state(pos).setValue(BlockStateProperties.LIT, lit));
+    }
+
+    private void pruneToggleLog(final long tick) {
+        while (!this.toggleLog.isEmpty() && tick - this.toggleLog.peekFirst()[1] > 60L) {
+            this.toggleLog.removeFirst();
+        }
+    }
+
+    // Transcribed from RedstoneTorchBlock.isToggledTooFrequently.
+    private boolean toggledTooFrequently(final long pos, final long tick, final boolean add) {
+        if (add) {
+            this.toggleLog.addLast(new long[] {pos, tick});
+        }
+        int count = 0;
+        for (final long[] t : this.toggleLog) {
+            if (t[0] == pos && ++count >= 8) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    // --------------------------------------------------------------- repeater
+
+    private Direction repeaterFacing(final long pos) {
+        return this.state(pos).getValue(BlockStateProperties.HORIZONTAL_FACING);
+    }
+
+    private int repeaterDelay(final long pos) {
+        return this.state(pos).getValue(BlockStateProperties.DELAY) * 2;
+    }
+
+    // Transcribed from DiodeBlock.getInputSignal.
+    private boolean repeaterShouldTurnOn(final long pos) {
+        this.m.set(pos);
+        final Direction facing = this.repeaterFacing(pos);
+        final BlockPos back = this.m.relative(facing).immutable();
+        int input = this.vw.getSignal(back, facing);
+        if (input < 15) {
+            final BlockState bs = this.vw.getBlockState(back);
+            if (bs.is(Blocks.REDSTONE_WIRE)) {
+                input = Math.max(input, bs.getValue(BlockStateProperties.POWER));
+            }
+        }
+        return input > 0;
+    }
+
+    // Transcribed from DiodeBlock.getAlternateSignal / RepeaterBlock.isLocked.
+    private boolean repeaterLocked(final long pos) {
+        this.m.set(pos);
+        final Direction facing = this.repeaterFacing(pos);
+        final Direction cw = facing.getClockWise();
+        final Direction ccw = facing.getCounterClockWise();
+        final int alt = Math.max(
+            this.vw.getControlInputSignal(this.m.relative(cw).immutable(), cw, true),
+            this.vw.getControlInputSignal(this.m.relative(ccw).immutable(), ccw, true));
+        return alt > 0;
+    }
+
+    private void updateRepeaterLock(final long pos) {
+        final BlockState state = this.state(pos);
+        if (state.hasProperty(BlockStateProperties.LOCKED)) {
+            final boolean locked = this.repeaterLocked(pos);
+            if (state.getValue(BlockStateProperties.LOCKED) != locked) {
+                this.vw.set(pos, state.setValue(BlockStateProperties.LOCKED, locked));
+            }
+        }
+    }
+
+    private boolean repeaterPrioritize(final long pos) {
+        this.m.set(pos);
+        final Direction facing = this.repeaterFacing(pos);
+        final BlockState behind = this.vw.getBlockState(this.m.relative(facing.getOpposite()));
+        return behind.getBlock() instanceof DiodeBlock
+            && behind.hasProperty(BlockStateProperties.HORIZONTAL_FACING)
+            && behind.getValue(BlockStateProperties.HORIZONTAL_FACING) != facing;
+    }
+
+    // Transcribed from DiodeBlock.checkTickOnNeighbor.
+    private void scheduleRepeaterIfNeeded(final long pos, final long tick) {
+        if (this.repeaterLocked(pos)) {
+            return;
+        }
+        final boolean on = this.state(pos).getValue(BlockStateProperties.POWERED);
+        final boolean shouldOn = this.repeaterShouldTurnOn(pos);
+        if (on != shouldOn && !this.willTick(pos, Kind.REPEATER)) {
+            int priority = P_HIGH;
+            if (this.repeaterPrioritize(pos)) {
+                priority = P_EXTREMELY_HIGH;
+            } else if (on) {
+                priority = P_VERY_HIGH;
+            }
+            this.schedule(pos, Kind.REPEATER, this.repeaterDelay(pos), priority, tick);
+        }
+    }
+
+    // Transcribed from DiodeBlock.tick.
+    private void runRepeater(final long pos) {
+        if (this.repeaterLocked(pos)) {
+            return;
+        }
+        final boolean on = this.state(pos).getValue(BlockStateProperties.POWERED);
+        final boolean shouldOn = this.repeaterShouldTurnOn(pos);
+        if (on && !shouldOn) {
+            this.vw.set(pos, this.state(pos).setValue(BlockStateProperties.POWERED, false));
+        } else if (!on) {
+            this.vw.set(pos, this.state(pos).setValue(BlockStateProperties.POWERED, true));
+            if (!shouldOn) {
+                this.schedule(pos, Kind.REPEATER, this.repeaterDelay(pos), P_VERY_HIGH, /*tick*/ 0);
+            }
+        }
+    }
+
+    // ------------------------------------------------------------- comparator
+
+    private Direction comparatorFacing(final long pos) {
+        return this.state(pos).getValue(BlockStateProperties.HORIZONTAL_FACING);
+    }
+
+    private ComparatorMode comparatorMode(final long pos) {
+        return this.state(pos).getValue(ComparatorBlock.MODE);
+    }
+
+    private ComparatorBlockEntity comparatorBE(final long pos) {
+        return (ComparatorBlockEntity) this.vw.getBlockEntity(BlockPos.of(pos));
+    }
+
+    // Transcribed from ComparatorBlock.getInputSignal (analog rear/conductor read).
+    private int comparatorInputSignal(final long pos) {
+        this.m.set(pos);
+        final Direction facing = this.comparatorFacing(pos);
+        // super.getInputSignal (DiodeBlock): rear redstone signal + adjacent wire power.
+        BlockPos targetPos = this.m.relative(facing).immutable();
+        int resultSignal = this.vw.getSignal(targetPos, facing);
+        if (resultSignal < Redstone.SIGNAL_MAX) {
+            final BlockState bs = this.vw.getBlockState(targetPos);
+            if (bs.is(Blocks.REDSTONE_WIRE)) {
+                resultSignal = Math.max(resultSignal, bs.getValue(BlockStateProperties.POWER));
+            }
+        }
+        // Comparator analog override.
+        BlockState targetState = this.vw.getBlockState(targetPos);
+        if (targetState.hasAnalogOutputSignal()) {
+            resultSignal = targetState.getAnalogOutputSignal(this.level, targetPos, facing.getOpposite());
+        } else if (resultSignal < Redstone.SIGNAL_MAX && targetState.isRedstoneConductor(this.vw, targetPos)) {
+            targetPos = targetPos.relative(facing);
+            targetState = this.vw.getBlockState(targetPos);
+            // Item frames in front of a comparator are NOT modelled (no entities in the grid).
+            if (targetState.hasAnalogOutputSignal()) {
+                resultSignal = targetState.getAnalogOutputSignal(this.level, targetPos, facing.getOpposite());
+            }
+        }
+        return resultSignal;
+    }
+
+    // Transcribed from DiodeBlock.getAlternateSignal (comparator side input; NOT diodes-only).
+    private int comparatorAlternateSignal(final long pos) {
+        this.m.set(pos);
+        final Direction facing = this.comparatorFacing(pos);
+        final Direction cw = facing.getClockWise();
+        final Direction ccw = facing.getCounterClockWise();
+        return Math.max(
+            this.vw.getControlInputSignal(this.m.relative(cw).immutable(), cw, false),
+            this.vw.getControlInputSignal(this.m.relative(ccw).immutable(), ccw, false));
+    }
+
+    // Transcribed from ComparatorBlock.calculateOutputSignal.
+    private int comparatorOutput(final long pos) {
+        final int input = this.comparatorInputSignal(pos);
+        if (input == 0) {
+            return Redstone.SIGNAL_MIN;
+        }
+        final int alt = this.comparatorAlternateSignal(pos);
+        if (alt > input) {
+            return Redstone.SIGNAL_MIN;
+        }
+        return this.comparatorMode(pos) == ComparatorMode.SUBTRACT ? input - alt : input;
+    }
+
+    // Transcribed from ComparatorBlock.shouldTurnOn.
+    private boolean comparatorShouldTurnOn(final long pos) {
+        final int input = this.comparatorInputSignal(pos);
+        if (input == 0) {
+            return false;
+        }
+        final int side = this.comparatorAlternateSignal(pos);
+        return input > side || (input == side && this.comparatorMode(pos) == ComparatorMode.COMPARE);
+    }
+
+    // Transcribed from ComparatorBlock.checkTickOnNeighbor.
+    private void scheduleComparatorIfNeeded(final long pos, final long tick) {
+        if (this.willTick(pos, Kind.COMPARATOR)) {
+            return;
+        }
+        final int outputValue = this.comparatorOutput(pos);
+        final int oldValue = this.comparatorBE(pos).getOutputSignal();
+        final boolean powered = this.state(pos).getValue(BlockStateProperties.POWERED);
+        if (outputValue != oldValue || powered != this.comparatorShouldTurnOn(pos)) {
+            final int priority = this.diodePrioritize(pos) ? P_HIGH : P_NORMAL;
+            this.schedule(pos, Kind.COMPARATOR, 2, priority, tick);
+        }
+    }
+
+    // Transcribed from ComparatorBlock.refreshOutputState (invoked from tick()).
+    private void runComparator(final long pos) {
+        final int outputValue = this.comparatorOutput(pos);
+        final ComparatorBlockEntity be = this.comparatorBE(pos);
+        final int oldValue = be.getOutputSignal();
+        be.setOutputSignal(outputValue);
+        if (oldValue != outputValue || this.comparatorMode(pos) == ComparatorMode.COMPARE) {
+            final boolean sourceOn = this.comparatorShouldTurnOn(pos);
+            final boolean isOn = this.state(pos).getValue(BlockStateProperties.POWERED);
+            if (isOn && !sourceOn) {
+                this.vw.set(pos, this.state(pos).setValue(BlockStateProperties.POWERED, false));
+            } else if (!isOn && sourceOn) {
+                this.vw.set(pos, this.state(pos).setValue(BlockStateProperties.POWERED, true));
+            }
+        }
+    }
+
+    // DiodeBlock.shouldPrioritize: a diode behind us (opposite FACING) feeding crosswise.
+    private boolean diodePrioritize(final long pos) {
+        this.m.set(pos);
+        final Direction direction = this.comparatorFacing(pos).getOpposite();
+        final BlockState behind = this.vw.getBlockState(this.m.relative(direction));
+        return behind.getBlock() instanceof DiodeBlock
+            && behind.hasProperty(BlockStateProperties.HORIZONTAL_FACING)
+            && behind.getValue(BlockStateProperties.HORIZONTAL_FACING) != direction;
+    }
+
+    // -------------------------------------------------------------- observer
+
+    private Direction observerFacing(final long pos) {
+        return this.state(pos).getValue(BlockStateProperties.FACING);
+    }
+
+    /**
+     * Fire each observer that has just seen its observed block change state, EXACTLY like
+     * vanilla {@code ObserverBlock.updateShape}: a change schedules a 2-tick pulse, but only
+     * when the observer is not already powered and has no pending tick. Called after every
+     * grid mutation (matching vanilla's per-{@code setBlock} {@code updateShape} dispatch).
+     */
+    private void syncObservers() {
+        for (final long pos : this.observers) {
+            this.m.set(pos);
+            final BlockPos observed = this.m.relative(this.observerFacing(pos)).immutable();
+            final BlockState now = this.vw.getBlockState(observed);
+            final BlockState prev = this.lastObserved.get(pos);
+            if (now.equals(prev)) {
+                continue;
+            }
+            this.lastObserved.put(pos, now);
+            if (!this.state(pos).getValue(BlockStateProperties.POWERED) && !this.willTick(pos, Kind.OBSERVER)) {
+                this.schedule(pos, Kind.OBSERVER, 2, P_NORMAL, this.currentTick);
+            }
+        }
+    }
+
+    // Transcribed from ObserverBlock.tick (2-tick pulse: on, reschedule, off).
+    private void runObserver(final long pos) {
+        final BlockState state = this.state(pos);
+        if (state.getValue(BlockStateProperties.POWERED)) {
+            this.vw.set(pos, state.setValue(BlockStateProperties.POWERED, false));
+        } else {
+            this.vw.set(pos, state.setValue(BlockStateProperties.POWERED, true));
+            this.schedule(pos, Kind.OBSERVER, 2, P_NORMAL, this.currentTick);
+        }
+    }
+
+    // ------------------------------------------------------------------ lamp
+
+    // Transcribed from RedstoneLampBlock.neighborChanged: turn ON immediately when a
+    // neighbour signal appears; schedule a 4-tick OFF when the signal is lost.
+    private void updateLamp(final long pos, final long tick) {
+        this.m.set(pos);
+        final BlockState state = this.state(pos);
+        final boolean lit = state.getValue(BlockStateProperties.LIT);
+        final boolean hasSignal = this.vw.hasNeighborSignal(this.m.immutable());
+        if (lit == hasSignal) {
+            return;
+        }
+        if (lit) {
+            if (!this.willTick(pos, Kind.LAMP)) {
+                this.schedule(pos, Kind.LAMP, 4, P_NORMAL, tick);
+            }
+        } else {
+            this.vw.set(pos, state.setValue(BlockStateProperties.LIT, true));
+        }
+    }
+
+    // Transcribed from RedstoneLampBlock.tick.
+    private void runLamp(final long pos) {
+        this.m.set(pos);
+        final BlockState state = this.state(pos);
+        if (state.getValue(BlockStateProperties.LIT) && !this.vw.hasNeighborSignal(this.m.immutable())) {
+            this.vw.set(pos, state.setValue(BlockStateProperties.LIT, false));
+        }
+    }
+
+    // ---------------------------------------------------------------- button
+
+    // Transcribed from ButtonBlock.tick -> checkPressed: with no arrow present the button
+    // un-presses (POWERED -> false) when its scheduled tick fires.
+    private void runButton(final long pos) {
+        final BlockState state = this.state(pos);
+        if (state.getValue(BlockStateProperties.POWERED)) {
+            this.vw.set(pos, state.setValue(BlockStateProperties.POWERED, false));
+        }
+    }
+
+    // ---------------------------------------------------------------- target
+
+    // Transcribed from TargetBlock.tick: the analog OUTPUT_POWER decays back to 0 when the
+    // scheduled tick fires.
+    private void runTarget(final long pos) {
+        final BlockState state = this.state(pos);
+        if (state.getValue(BlockStateProperties.POWER) != 0) {
+            this.vw.set(pos, state.setValue(BlockStateProperties.POWER, 0));
+        }
+    }
+
+    // ----------------------------------------------------------------- piston
+    //
+    // The wall of the redstone compiler: a piston MOVES blocks, so firing one changes the
+    // world grid AND the network topology (a moved block makes/breaks connections, dust is
+    // pushed/destroyed). Everything below is transcribed from vanilla
+    // {@code PistonBaseBlock} / {@code PistonStructureResolver} / {@code PistonMovingBlockEntity}
+    // and applied to the in-memory grid, so the compiled contraption reproduces vanilla's
+    // exact block states + transient MOVING_PISTON progress every tick. Signal propagation
+    // after each grid mutation still runs through the shared vanilla SignalGetter code
+    // (recomputeWires / hasSignal), so topology re-detection is bit-identical by construction.
+    //
+    // QUASI-CONNECTIVITY (QC) is modelled EXACTLY: {@link #pistonHasSignal} is a line-for-line
+    // transcription of {@code PistonBaseBlock.getNeighborSignal} (direct neighbours except the
+    // push face, the block's own DOWN face, then the block ABOVE and its neighbours) evaluated
+    // through the grid's SignalGetter — so QC activation and the BUD behaviour that falls out
+    // of it are identical to vanilla.
+    //
+    // MODELLED: single/chain push, sticky pull, QC, AND slime/honey multi-block drag &
+    // recursive branching (full PistonStructureResolver — see GridStructureResolver below) plus
+    // the 0-tick / TRIGGER_DROP fast-retract path (an in-flight extend head finalised early on
+    // retract — see retract()).
+    // DEFERRED (NOT modelled — noted, not attempted): self-propelled flying machines / piston
+    // tape, observer-0-tick free-running engines (the harness snapshots block states but not the
+    // in-flight scheduled-tick phase, so a circuit already oscillating at snapshot can't be seeded).
+
+    /** The live {@link MovingBlock} for a cell (grid == MOVING_PISTON), or null; for the harness. */
+    MovingBlock movingAt(final long packed) {
+        return this.moving.get(packed);
+    }
+
+    private Direction pistonFacing(final long pos) {
+        return this.state(pos).getValue(BlockStateProperties.FACING);
+    }
+
+    private boolean pistonSticky(final long pos) {
+        return this.state(pos).is(Blocks.STICKY_PISTON);
+    }
+
+    // Transcribed verbatim from PistonBaseBlock.getNeighborSignal — the QC power read.
+    private boolean pistonHasSignal(final long pos, final Direction pushDirection) {
+        final BlockPos p = BlockPos.of(pos);
+        for (final Direction direction : Direction.values()) {
+            if (direction != pushDirection && this.vw.hasSignal(p.relative(direction), direction)) {
+                return true;
+            }
+        }
+        if (this.vw.hasSignal(p, Direction.DOWN)) {
+            return true;
+        }
+        final BlockPos above = p.above();
+        for (final Direction direction : Direction.values()) {
+            if (direction != Direction.DOWN && this.vw.hasSignal(above.relative(direction), direction)) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    // Transcribed from PistonBaseBlock.checkIfExtend: a state mismatch posts a block event.
+    // Vanilla posts the event during the neighbour-update that changed power; it runs in the
+    // NEXT level block-event phase, i.e. one tick later — so we schedule with delay 1.
+    private void schedulePistonIfNeeded(final long pos, final long tick) {
+        final BlockState st = this.state(pos);
+        if (!(st.getBlock() instanceof PistonBaseBlock)) {
+            return; // body is mid-retract (MOVING_PISTON); no checkIfExtend on it
+        }
+        final Direction dir = st.getValue(BlockStateProperties.FACING);
+        final boolean extend = this.pistonHasSignal(pos, dir);
+        final boolean extended = st.getValue(BlockStateProperties.EXTENDED);
+        if (this.willTick(pos, Kind.PISTON)) {
+            return;
+        }
+        if (extend && !extended) {
+            if (this.resolve(BlockPos.of(pos), dir, true) != null) {
+                this.schedule(pos, Kind.PISTON, 1, P_NORMAL, tick);
+            }
+        } else if (!extend && extended) {
+            this.schedule(pos, Kind.PISTON, 1, P_NORMAL, tick);
+        }
+    }
+
+    // Transcribed from PistonBaseBlock.triggerEvent (re-deriving the b0 guard from the live
+    // EXTENDED state, since the queued event type is recoverable from it: !extended => was an
+    // extend event; extended => was a contract event).
+    private void runPistonEvent(final long pos) {
+        final BlockState st = this.state(pos);
+        if (!(st.getBlock() instanceof PistonBaseBlock)) {
+            return;
+        }
+        final Direction dir = st.getValue(BlockStateProperties.FACING);
+        final boolean extended = st.getValue(BlockStateProperties.EXTENDED);
+        final boolean extend = this.pistonHasSignal(pos, dir);
+        if (extend == extended) {
+            // extend && extended: contract event but power returned -> stay extended (no-op,
+            // EXTENDED already true). !extend && !extended: extend event but power lost -> abort.
+            return;
+        }
+        if (extend) {
+            if (this.moveBlocks(BlockPos.of(pos), dir, true)) {
+                this.vw.set(pos, st.setValue(BlockStateProperties.EXTENDED, true));
+            }
+        } else {
+            this.retract(BlockPos.of(pos), dir, this.pistonSticky(pos));
+        }
+    }
+
+    private void setMoving(final BlockPos pos, final BlockState movedState, final Direction dir,
+                           final boolean extending, final boolean isSource, final boolean sticky) {
+        final BlockState grid = Blocks.MOVING_PISTON.defaultBlockState()
+            .setValue(MovingPistonBlock.FACING, dir)
+            .setValue(MovingPistonBlock.TYPE, sticky ? PistonType.STICKY : PistonType.DEFAULT);
+        this.vw.set(pos, grid);
+        this.moving.put(pos.asLong(), new MovingBlock(movedState, dir, extending, isSource));
+    }
+
+    // Transcribed from PistonBaseBlock.moveBlocks (extending path; non-slime). Pushes the
+    // resolved block line one cell along the push direction, leaving MOVING_PISTON + a head.
+    private boolean moveBlocks(final BlockPos pistonPos, final Direction dir, final boolean extending) {
+        // Vanilla clears the head BEFORE resolving (so the resolver does not see the immovable
+        // PISTON_HEAD in a retract pull's path). Order matters — resolving first would abort the pull.
+        final BlockPos armPos = pistonPos.relative(dir);
+        if (!extending && this.vw.getBlockState(armPos).is(Blocks.PISTON_HEAD)) {
+            this.vw.set(armPos, AIR);
+        }
+        final Resolve res = this.resolve(pistonPos, dir, extending);
+        if (res == null) {
+            return false;
+        }
+        // For extend the body is still a PistonBaseBlock, so its stickiness reads correctly;
+        // it is only needed for the head's TYPE (no head is created on a retract pull).
+        final boolean sticky = extending && this.pistonSticky(pistonPos.asLong());
+        final Direction pushDir = extending ? dir : dir.getOpposite();
+        // Snapshot the moved states before mutating, and seed the deleteAfterMove map exactly
+        // like vanilla PistonBaseBlock.moveBlocks: every toPush cell starts as "to be aired",
+        // and is removed from the map iff some moved block (or the head) lands on it. This is
+        // the collision-safe placement for a BRANCHING slime/honey structure — a moved block's
+        // destination cell is never re-aired, and only the trailing vacated cells become air,
+        // regardless of the (non-linear) order of toPush.
+        final List<BlockPos> toPush = res.toPush;
+        final BlockState[] shapes = new BlockState[toPush.size()];
+        final java.util.Map<Long, BlockState> deleteAfterMove = new HashMap<>();
+        for (int i = 0; i < toPush.size(); i++) {
+            shapes[i] = this.vw.getBlockState(toPush.get(i));
+            deleteAfterMove.put(toPush.get(i).asLong(), shapes[i]);
+        }
+        // Destroyed blocks (PushReaction.DESTROY, e.g. redstone dust) just vanish.
+        for (final BlockPos d : res.toDestroy) {
+            this.vw.set(d, AIR);
+        }
+        // Place every moved block as a MOVING_PISTON at its destination (far end first, matching
+        // vanilla's iteration order). Each destination is removed from deleteAfterMove so a cell
+        // occupied by a moved block is never cleared. Vanilla gives pushed blocks a TYPE=DEFAULT
+        // MOVING_PISTON (only the head/body carry the real piston type).
+        for (int i = toPush.size() - 1; i >= 0; i--) {
+            final BlockPos newPos = toPush.get(i).relative(pushDir);
+            deleteAfterMove.remove(newPos.asLong());
+            this.setMoving(newPos, shapes[i], dir, extending, false, false);
+        }
+        if (extending) {
+            final BlockState head = Blocks.PISTON_HEAD.defaultBlockState()
+                .setValue(PistonHeadBlock.FACING, dir)
+                .setValue(PistonHeadBlock.TYPE, sticky ? PistonType.STICKY : PistonType.DEFAULT);
+            deleteAfterMove.remove(armPos.asLong());
+            this.setMoving(armPos, head, dir, true, true, sticky);
+        }
+        // Air out every vacated cell that no moved block now occupies.
+        for (final long key : deleteAfterMove.keySet()) {
+            this.vw.set(key, AIR);
+        }
+        return true;
+    }
+
+    // Transcribed from PistonBaseBlock.triggerEvent contract branch (b0 == TRIGGER_CONTRACT /
+    // TRIGGER_DROP). The 0-tick / fast-retract path (b0 == TRIGGER_DROP) is the SAME contract
+    // code, distinguished only by an extend head still being in flight when the retract runs;
+    // vanilla finalises that in-flight mover EARLY via PistonMovingBlockEntity.finalTick() (a
+    // SOURCE mover resolves to AIR, dropping the block), which is what {@link #finalTickMover}
+    // does here.
+    private void retract(final BlockPos pistonPos, final Direction dir, final boolean sticky) {
+        final BlockPos head = pistonPos.relative(dir);
+        // Fast-retract: an extend head still animating at the arm cell is finalised early (-> AIR).
+        if (this.moving.containsKey(head.asLong())) {
+            this.finalTickMover(head.asLong());
+        }
+        // Body becomes a MOVING_PISTON source that animates back to a normal (unextended) piston.
+        final BlockState movedSource = (sticky ? Blocks.STICKY_PISTON : Blocks.PISTON)
+            .defaultBlockState().setValue(BlockStateProperties.FACING, dir);
+        this.setMoving(pistonPos, movedSource, dir, false, true, sticky);
+        if (sticky) {
+            final BlockPos twoPos = pistonPos.relative(dir, 2);
+            // A still-extending mover at twoPos (a same-tick extend head) is a "piston piece":
+            // finalise it early and do NOT pull (mirrors the pistonPiece branch).
+            final MovingBlock mbTwo = this.moving.get(twoPos.asLong());
+            boolean pistonPiece = false;
+            if (this.vw.getBlockState(twoPos).is(Blocks.MOVING_PISTON)
+                && mbTwo != null && mbTwo.direction == dir && mbTwo.extending) {
+                this.finalTickMover(twoPos.asLong());
+                pistonPiece = true;
+            }
+            if (!pistonPiece) {
+                final BlockState pulled = this.vw.getBlockState(twoPos);
+                final boolean canPull = !pulled.isAir()
+                    && isPushable(pulled, twoPos, dir.getOpposite(), false, dir)
+                    && !(pulled.getPistonPushReaction() != PushReaction.NORMAL
+                        && !pulled.is(Blocks.PISTON) && !pulled.is(Blocks.STICKY_PISTON));
+                if (canPull) {
+                    this.moveBlocks(pistonPos, dir, false); // pulls twoPos -> head cell
+                } else {
+                    this.vw.set(head, AIR);
+                }
+            }
+        } else {
+            this.vw.set(head, AIR);
+        }
+    }
+
+    // Transcribed from PistonMovingBlockEntity.finalTick (the EARLY finalise used when a new
+    // piston action interrupts an in-flight mover): a SOURCE piston resolves to AIR, any other
+    // moved block to its moved state. Distinct from finalizeMover (the normal tick() completion,
+    // which always places the moved state — e.g. a head completing into a real PISTON_HEAD).
+    private void finalTickMover(final long key) {
+        final MovingBlock mb = this.moving.remove(key);
+        if (mb == null) {
+            return;
+        }
+        final BlockPos pos = BlockPos.of(key);
+        if (!this.vw.getBlockState(pos).is(Blocks.MOVING_PISTON)) {
+            return;
+        }
+        this.vw.set(pos, mb.isSource ? AIR : mb.movedState);
+    }
+
+    // Transcribed from PistonMovingBlockEntity.tick (server branch): advance progress 0->0.5->1,
+    // finalising (placing the moved block) the tick AFTER progress first reaches 1.0.
+    private void advanceMovers() {
+        for (final long key : this.moving.keySet().toLongArray()) {
+            final MovingBlock mb = this.moving.get(key);
+            if (mb == null) {
+                continue;
+            }
+            mb.progressO = mb.progress;
+            if (mb.progressO >= 1.0F) {
+                this.finalizeMover(key);
+            } else {
+                mb.progress += 0.5F;
+                if (mb.progress >= 1.0F) {
+                    mb.progress = 1.0F;
+                }
+            }
+        }
+    }
+
+    private void finalizeMover(final long key) {
+        final MovingBlock mb = this.moving.remove(key);
+        if (mb == null) {
+            return;
+        }
+        final BlockPos pos = BlockPos.of(key);
+        if (!this.vw.getBlockState(pos).is(Blocks.MOVING_PISTON)) {
+            return;
+        }
+        // updateFromNeighbourShapes is a no-op for the corpus's solid blocks / piston / head,
+        // so the moved state is placed directly (connective-block reshaping is out of scope).
+        this.vw.set(pos, mb.movedState);
+    }
+
+    // ------------------------------------------------------- piston structure resolver
+    //
+    // {@link GridStructureResolver} below is a line-for-line transcription of vanilla
+    // {@code PistonStructureResolver} (INCLUDING the slime/honey sticky back-extension loop,
+    // {@code addBranchingBlocks} recursion, {@code canStickToEachOther} adhesion and
+    // {@code reorderListAtCollision}) evaluated over the in-memory grid via the shared
+    // {@link #isPushable}. So a slime/honey block drags its stuck neighbours in all 6
+    // directions, recursively branching, up to the 12-block limit — bit-identical to vanilla.
+
+    private record Resolve(List<BlockPos> toPush, List<BlockPos> toDestroy) {
+    }
+
+    private Resolve resolve(final BlockPos pistonPos, final Direction dir, final boolean extending) {
+        final GridStructureResolver r = new GridStructureResolver(this.vw, pistonPos, dir, extending);
+        if (!r.resolve()) {
+            return null;
+        }
+        return new Resolve(r.toPush, r.toDestroy);
+    }
+
+    /**
+     * The full vanilla {@code PistonStructureResolver}, transcribed verbatim onto the compiled
+     * grid (reads {@link VirtualRedstoneWorld} instead of {@code Level}). Carries the slime/honey
+     * multi-block drag: the sticky back-extension {@code while} loop in {@link #addBlockLine},
+     * the per-sticky-block {@link #addBranchingBlocks} recursion across the two perpendicular
+     * axes, {@link #canStickToEachOther} (with the slime↔honey non-stick rule) and the
+     * {@link #reorderListAtCollision} reordering — none re-derived, all transcribed.
+     */
+    private static final class GridStructureResolver {
+        private final VirtualRedstoneWorld level;
+        private final BlockPos pistonPos;
+        private final boolean extending;
+        private final BlockPos startPos;
+        private final Direction pushDirection;
+        private final List<BlockPos> toPush = new ArrayList<>();
+        private final List<BlockPos> toDestroy = new ArrayList<>();
+        private final Direction pistonDirection;
+
+        GridStructureResolver(final VirtualRedstoneWorld level, final BlockPos pistonPos,
+                              final Direction direction, final boolean extending) {
+            this.level = level;
+            this.pistonPos = pistonPos;
+            this.pistonDirection = direction;
+            this.extending = extending;
+            if (extending) {
+                this.pushDirection = direction;
+                this.startPos = pistonPos.relative(direction);
+            } else {
+                this.pushDirection = direction.getOpposite();
+                this.startPos = pistonPos.relative(direction, 2);
+            }
+        }
+
+        boolean resolve() {
+            this.toPush.clear();
+            this.toDestroy.clear();
+            final BlockState nextState = this.level.getBlockState(this.startPos);
+            if (!isPushable(nextState, this.startPos, this.pushDirection, false, this.pistonDirection)) {
+                if (this.extending && nextState.getPistonPushReaction() == PushReaction.DESTROY) {
+                    this.toDestroy.add(this.startPos);
+                    return true;
+                }
+                return false;
+            }
+            if (!this.addBlockLine(this.startPos, this.pushDirection)) {
+                return false;
+            }
+            for (int i = 0; i < this.toPush.size(); i++) {
+                final BlockPos pos = this.toPush.get(i);
+                if (isSticky(this.level.getBlockState(pos)) && !this.addBranchingBlocks(pos)) {
+                    return false;
+                }
+            }
+            return true;
+        }
+
+        private static boolean isSticky(final BlockState state) {
+            return state.is(Blocks.SLIME_BLOCK) || state.is(Blocks.HONEY_BLOCK);
+        }
+
+        private static boolean canStickToEachOther(final BlockState state1, final BlockState state2) {
+            return (!state1.is(Blocks.HONEY_BLOCK) || !state2.is(Blocks.SLIME_BLOCK))
+                && (!state1.is(Blocks.SLIME_BLOCK) || !state2.is(Blocks.HONEY_BLOCK))
+                && (isSticky(state1) || isSticky(state2));
+        }
+
+        private boolean addBlockLine(final BlockPos start, final Direction direction) {
+            BlockState nextState = this.level.getBlockState(start);
+            if (nextState.isAir()) {
+                return true;
+            }
+            if (!isPushable(nextState, start, this.pushDirection, false, direction)) {
+                return true;
+            }
+            if (start.equals(this.pistonPos)) {
+                return true;
+            }
+            if (this.toPush.contains(start)) {
+                return true;
+            }
+            int blockCount = 1;
+            if (blockCount + this.toPush.size() > MAX_PUSH_DEPTH) {
+                return false;
+            }
+            while (isSticky(nextState)) {
+                final BlockPos pos = start.relative(this.pushDirection.getOpposite(), blockCount);
+                final BlockState previousState = nextState;
+                nextState = this.level.getBlockState(pos);
+                if (nextState.isAir()
+                    || !canStickToEachOther(previousState, nextState)
+                    || !isPushable(nextState, pos, this.pushDirection, false, this.pushDirection.getOpposite())
+                    || pos.equals(this.pistonPos)) {
+                    break;
+                }
+                if (++blockCount + this.toPush.size() > MAX_PUSH_DEPTH) {
+                    return false;
+                }
+            }
+            int blocksAdded = 0;
+            for (int i = blockCount - 1; i >= 0; i--) {
+                this.toPush.add(start.relative(this.pushDirection.getOpposite(), i));
+                blocksAdded++;
+            }
+            int i = 1;
+            while (true) {
+                final BlockPos pos = start.relative(this.pushDirection, i);
+                final int collisionPos = this.toPush.indexOf(pos);
+                if (collisionPos > -1) {
+                    this.reorderListAtCollision(blocksAdded, collisionPos);
+                    for (int j = 0; j <= collisionPos + blocksAdded; j++) {
+                        final BlockPos blockPos = this.toPush.get(j);
+                        if (isSticky(this.level.getBlockState(blockPos)) && !this.addBranchingBlocks(blockPos)) {
+                            return false;
+                        }
+                    }
+                    return true;
+                }
+                nextState = this.level.getBlockState(pos);
+                if (nextState.isAir()) {
+                    return true;
+                }
+                if (!isPushable(nextState, pos, this.pushDirection, true, this.pushDirection) || pos.equals(this.pistonPos)) {
+                    return false;
+                }
+                if (nextState.getPistonPushReaction() == PushReaction.DESTROY) {
+                    this.toDestroy.add(pos);
+                    return true;
+                }
+                if (this.toPush.size() >= MAX_PUSH_DEPTH) {
+                    return false;
+                }
+                this.toPush.add(pos);
+                blocksAdded++;
+                i++;
+            }
+        }
+
+        private void reorderListAtCollision(final int blocksAdded, final int collisionPos) {
+            final List<BlockPos> head = new ArrayList<>();
+            final List<BlockPos> lastLineAdded = new ArrayList<>();
+            final List<BlockPos> collisionToLine = new ArrayList<>();
+            head.addAll(this.toPush.subList(0, collisionPos));
+            lastLineAdded.addAll(this.toPush.subList(this.toPush.size() - blocksAdded, this.toPush.size()));
+            collisionToLine.addAll(this.toPush.subList(collisionPos, this.toPush.size() - blocksAdded));
+            this.toPush.clear();
+            this.toPush.addAll(head);
+            this.toPush.addAll(lastLineAdded);
+            this.toPush.addAll(collisionToLine);
+        }
+
+        private boolean addBranchingBlocks(final BlockPos fromPos) {
+            final BlockState fromState = this.level.getBlockState(fromPos);
+            for (final Direction direction : Direction.values()) {
+                if (direction.getAxis() != this.pushDirection.getAxis()) {
+                    final BlockPos neighbourPos = fromPos.relative(direction);
+                    final BlockState neighbourState = this.level.getBlockState(neighbourPos);
+                    if (canStickToEachOther(neighbourState, fromState) && !this.addBlockLine(neighbourPos, direction)) {
+                        return false;
+                    }
+                }
+            }
+            return true;
+        }
+    }
+
+    private static final int MAX_PUSH_DEPTH = 12;
+
+    // Transcribed from PistonBaseBlock.isPushable (grid form; getDestroySpeed==-1 unbreakables
+    // are covered by the explicit obsidian family + PushReaction.BLOCK, sufficient for the corpus).
+    private static boolean isPushable(final BlockState state, final BlockPos pos, final Direction direction,
+                                      final boolean allowDestroyable, final Direction connectionDirection) {
+        if (pos.getY() < -64 || pos.getY() > 319) {
+            return false;
+        }
+        if (state.isAir()) {
+            return true;
+        }
+        if (state.is(Blocks.OBSIDIAN) || state.is(Blocks.CRYING_OBSIDIAN)
+            || state.is(Blocks.RESPAWN_ANCHOR) || state.is(Blocks.REINFORCED_DEEPSLATE)) {
+            return false;
+        }
+        if (direction == Direction.DOWN && pos.getY() == -64) {
+            return false;
+        }
+        if (direction == Direction.UP && pos.getY() == 319) {
+            return false;
+        }
+        if (!state.is(Blocks.PISTON) && !state.is(Blocks.STICKY_PISTON)) {
+            switch (state.getPistonPushReaction()) {
+                case BLOCK:
+                    return false;
+                case DESTROY:
+                    return allowDestroyable;
+                case PUSH_ONLY:
+                    return direction == connectionDirection;
+                default:
+                    break;
+            }
+        } else if (state.getValue(BlockStateProperties.EXTENDED)) {
+            return false;
+        }
+        return !state.hasBlockEntity();
+    }
+
+    // -------------------------------------------------------------- scheduling
+
+    private boolean willTick(final long pos, final Kind kind) {
+        for (final ScheduledEntry e : this.queue) {
+            if (e.pos() == pos && e.kind() == kind) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    private void schedule(final long pos, final Kind kind, final int delay, final int priority, final long baseTick) {
+        // de-dupe (UNIQUE_TICK_HASH): one pending tick per (pos, kind)
+        for (final ScheduledEntry e : this.queue) {
+            if (e.pos() == pos && e.kind() == kind) {
+                return;
+            }
+        }
+        final long trigger = (baseTick == 0 ? this.currentTick : baseTick) + delay;
+        this.queue.add(new ScheduledEntry(pos, kind, trigger, priority, this.subCounter++));
+    }
+
+    /** Tracks the tick we are currently stepping, for repeater off-edge reschedules. */
+    private long currentTick;
+}
diff --git a/com/coderyo/redstone/RedstoneCompileConfig.java b/com/coderyo/redstone/RedstoneCompileConfig.java
new file mode 100644
index 0000000000000000000000000000000000000000..ec9c5d745189d3ec1b62a75dbf740783166387bc
--- /dev/null
+++ b/com/coderyo/redstone/RedstoneCompileConfig.java
@@ -0,0 +1,85 @@
+/*
+ * coderyoMC — redstone HDL-compiler (Stream B). Clean-room independent
+ * implementation. MCHPRS studied as concept only (logic-graph idea), never copied.
+ */
+package com.coderyo.redstone;
+
+/**
+ * Dormancy switch for the redstone logic-graph compiler / differential harness
+ * (feature patch 0020). Mirrors {@code com.coderyo.region.RegionConfig}: the flag
+ * is read from a system property / environment variable and defaults to
+ * <strong>false</strong>, so with it off the server boots byte-for-byte
+ * vanilla-equivalent and NOTHING in this package executes.
+ *
+ * <pre>
+ *   -Dcoderyo.redstone.compile.enabled=true   (master switch; default false)
+ *   -Dcoderyo.redstone.difftest=true          (run the differential parity harness)
+ *   -Dcoderyo.redstone.difftest.maxTicks=400  (ticks to run each scenario; default 300)
+ * </pre>
+ *
+ * <p>The compiler NEVER replaces vanilla redstone in the live world in this
+ * increment. Even with the flag ON, the only effect is that the differential
+ * harness runs a parallel in-memory simulation and asserts bit-parity against the
+ * real vanilla world. Vanilla redstone remains the sole writer of world state.
+ */
+public final class RedstoneCompileConfig {
+
+    public static final String ENABLED_PROPERTY = "coderyo.redstone.compile.enabled";
+    public static final String ENABLED_ENV = "CODERYO_REDSTONE_COMPILE_ENABLED";
+
+    public static final String DIFFTEST_PROPERTY = "coderyo.redstone.difftest";
+    public static final String DIFFTEST_ENV = "CODERYO_REDSTONE_DIFFTEST";
+
+    public static final String MAXTICKS_PROPERTY = "coderyo.redstone.difftest.maxTicks";
+
+    public static final boolean DEFAULT_ENABLED = false;
+    public static final boolean DEFAULT_DIFFTEST = false;
+    public static final int DEFAULT_MAXTICKS = 300;
+
+    private static final boolean ENABLED = resolveBoolean(ENABLED_PROPERTY, ENABLED_ENV, DEFAULT_ENABLED);
+    private static final boolean DIFFTEST = resolveBoolean(DIFFTEST_PROPERTY, DIFFTEST_ENV, DEFAULT_DIFFTEST);
+    private static final int MAXTICKS = resolveInt(MAXTICKS_PROPERTY, DEFAULT_MAXTICKS);
+
+    private RedstoneCompileConfig() {
+    }
+
+    /** Master switch. Default false → whole subsystem dormant. */
+    public static boolean isEnabled() {
+        return ENABLED;
+    }
+
+    /** Whether the differential parity harness should run (requires {@link #isEnabled()}). */
+    public static boolean isDiffTest() {
+        return ENABLED && DIFFTEST;
+    }
+
+    /** Ticks to run each differential scenario before scoring it. */
+    public static int maxTicks() {
+        return MAXTICKS;
+    }
+
+    private static boolean resolveBoolean(final String property, final String env, final boolean fallback) {
+        final String prop = System.getProperty(property);
+        if (prop != null) {
+            return Boolean.parseBoolean(prop.trim());
+        }
+        final String envValue = System.getenv(env);
+        if (envValue != null) {
+            return Boolean.parseBoolean(envValue.trim());
+        }
+        return fallback;
+    }
+
+    private static int resolveInt(final String property, final int fallback) {
+        final String raw = System.getProperty(property);
+        if (raw == null) {
+            return fallback;
+        }
+        try {
+            final int parsed = Integer.parseInt(raw.trim());
+            return parsed >= 1 ? parsed : fallback;
+        } catch (final NumberFormatException ex) {
+            return fallback;
+        }
+    }
+}
diff --git a/com/coderyo/redstone/RedstoneDiffTestHarness.java b/com/coderyo/redstone/RedstoneDiffTestHarness.java
new file mode 100644
index 0000000000000000000000000000000000000000..ee38674b69e4a1829707c45c9be3a1bcd2126b9c
--- /dev/null
+++ b/com/coderyo/redstone/RedstoneDiffTestHarness.java
@@ -0,0 +1,880 @@
+/*
+ * coderyoMC — redstone HDL-compiler (Stream B). Clean-room independent implementation.
+ */
+package com.coderyo.redstone;
+
+import com.mojang.logging.LogUtils;
+import java.util.ArrayList;
+import java.util.List;
+import net.minecraft.core.BlockPos;
+import net.minecraft.core.Direction;
+import net.minecraft.server.MinecraftServer;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.world.Container;
+import net.minecraft.world.item.ItemStack;
+import net.minecraft.world.item.Items;
+import net.minecraft.world.level.block.Blocks;
+import net.minecraft.world.level.block.ComparatorBlock;
+import net.minecraft.world.level.block.DiodeBlock;
+import net.minecraft.world.level.block.ButtonBlock;
+import net.minecraft.world.level.block.ObserverBlock;
+import net.minecraft.world.level.block.RedstoneLampBlock;
+import net.minecraft.world.level.block.RedstoneTorchBlock;
+import net.minecraft.world.level.block.TargetBlock;
+import net.minecraft.world.level.block.piston.PistonBaseBlock;
+import net.minecraft.world.level.block.piston.PistonMovingBlockEntity;
+import net.minecraft.world.level.block.entity.ComparatorBlockEntity;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.block.state.properties.AttachFace;
+import net.minecraft.world.level.block.state.properties.BlockStateProperties;
+import net.minecraft.world.level.block.state.properties.ComparatorMode;
+import org.slf4j.Logger;
+
+/**
+ * The differential-testing harness — the safety mechanism for "full parity, no
+ * fallback". For each circuit in the corpus it builds the REAL circuit in the live
+ * world (so genuine vanilla redstone runs), compiles a parallel logic-graph model,
+ * then every server tick applies the same scripted stimulus to BOTH, advances the
+ * compiled model one tick, and asserts bit-identical block states (wire POWER, torch
+ * LIT, repeater POWERED/LOCKED). Any divergence is logged with the exact circuit,
+ * tick and cell — a compiler bug to FIX, never a reason to fall back.
+ *
+ * <p>Driven entirely off a single hook in {@code MinecraftServer.tickServer}; needs
+ * no command wiring. Gated behind {@code coderyo.redstone.difftest} (which itself
+ * requires the master {@code coderyo.redstone.compile.enabled}); with the flag off
+ * this method returns immediately and the server is byte-for-byte vanilla.
+ */
+public final class RedstoneDiffTestHarness {
+
+    private static final Logger LOG = LogUtils.getLogger();
+
+    private static final int PHASE_WAIT = 0;
+    private static final int PHASE_SETTLE = 1;
+    private static final int PHASE_RUN = 2;
+    private static final int PHASE_DONE = 3;
+
+    private static int phase = PHASE_WAIT;
+    private static boolean forced;
+    private static long ticks;
+    private static long settleUntil;
+    private static long runStart;
+    private static final List<Scenario> SCENARIOS = new ArrayList<>();
+
+    private RedstoneDiffTestHarness() {
+    }
+
+    public static void onServerTickEnd(final MinecraftServer server) {
+        if (!RedstoneCompileConfig.isDiffTest()) {
+            return;
+        }
+        ticks++;
+        final ServerLevel level = server.overworld();
+        switch (phase) {
+            case PHASE_WAIT -> {
+                if (!forced) {
+                    forced = true;
+                    for (int cx = -1; cx <= 5; cx++) {
+                        for (int cz = -1; cz <= 6; cz++) {
+                            level.setChunkForced(cx, cz, true);
+                        }
+                    }
+                    LOG.info("[redstone-difftest] forceloaded build-area chunks; waiting for load");
+                }
+                if (ticks > 40 && areaLoaded(level)) {
+                    buildCorpus(level);
+                    phase = PHASE_SETTLE;
+                    settleUntil = ticks + 10;
+                    LOG.info("[redstone-difftest] corpus built; settling vanilla redstone for 10 ticks");
+                }
+            }
+            case PHASE_SETTLE -> {
+                if (ticks >= settleUntil) {
+                    for (final Scenario s : SCENARIOS) {
+                        s.compile(level);
+                    }
+                    phase = PHASE_RUN;
+                    runStart = ticks;
+                    LOG.info("[redstone-difftest] ===== LOCKSTEP PARITY COMPARISON START =====");
+                }
+            }
+            case PHASE_RUN -> {
+                final int rel = (int) (ticks - runStart);
+                for (final Scenario s : SCENARIOS) {
+                    s.tick(level, rel);
+                }
+                if (rel >= RedstoneCompileConfig.maxTicks()) {
+                    phase = PHASE_DONE;
+                    summarize();
+                }
+            }
+            default -> {
+            }
+        }
+    }
+
+    private static boolean areaLoaded(final ServerLevel level) {
+        for (int cx = 0; cx <= 5; cx++) {
+            for (int cz = 0; cz <= 6; cz++) {
+                if (!level.getChunkSource().hasChunk(cx, cz)) {
+                    return false;
+                }
+            }
+            if (!level.getChunkSource().hasChunk(cx, -1)) {
+                return false;
+            }
+        }
+        return true;
+    }
+
+    private static void summarize() {
+        LOG.info("[redstone-difftest] ===== PARITY SUMMARY ({} ticks) =====", RedstoneCompileConfig.maxTicks());
+        boolean allPass = true;
+        for (final Scenario s : SCENARIOS) {
+            if (s.divergences == 0) {
+                LOG.info("[redstone-difftest]   PASS  {}  ({} cells, every tick bit-identical)", s.name, s.net.footprint().size());
+            } else {
+                allPass = false;
+                LOG.warn("[redstone-difftest]   FAIL  {}  ({} divergences; first @rel-tick {}: {})",
+                    s.name, s.divergences, s.firstDivergeTick, s.firstDetail);
+            }
+        }
+        LOG.info("[redstone-difftest] ===== VERDICT: {} =====", allPass ? "ALL CIRCUITS BIT-IDENTICAL" : "DIVERGENCE(S) FOUND");
+    }
+
+    // --------------------------------------------------------------- corpus
+
+    private static final BlockState STONE = Blocks.STONE.defaultBlockState();
+    private static final BlockState WIRE = Blocks.REDSTONE_WIRE.defaultBlockState();
+    private static final BlockState REDBLOCK = Blocks.REDSTONE_BLOCK.defaultBlockState();
+    private static final BlockState AIR = Blocks.AIR.defaultBlockState();
+    private static final BlockState TORCH = Blocks.REDSTONE_TORCH.defaultBlockState();
+    private static final BlockState REPEATER_W =
+        Blocks.REPEATER.defaultBlockState().setValue(BlockStateProperties.HORIZONTAL_FACING, Direction.WEST);
+    private static final BlockState LEVER_OFF = Blocks.LEVER.defaultBlockState()
+        .setValue(BlockStateProperties.ATTACH_FACE, AttachFace.WALL)
+        .setValue(BlockStateProperties.HORIZONTAL_FACING, Direction.NORTH)
+        .setValue(BlockStateProperties.POWERED, false);
+    private static final BlockState COMP_SUB_W =
+        Blocks.COMPARATOR.defaultBlockState()
+            .setValue(BlockStateProperties.HORIZONTAL_FACING, Direction.WEST)
+            .setValue(ComparatorBlock.MODE, ComparatorMode.SUBTRACT);
+    private static final BlockState COMP_CMP_W =
+        Blocks.COMPARATOR.defaultBlockState()
+            .setValue(BlockStateProperties.HORIZONTAL_FACING, Direction.WEST)
+            .setValue(ComparatorBlock.MODE, ComparatorMode.COMPARE);
+    private static final BlockState BARREL = Blocks.BARREL.defaultBlockState();
+    private static final BlockState LAMP = Blocks.REDSTONE_LAMP.defaultBlockState();
+    private static final BlockState OBS_W =
+        Blocks.OBSERVER.defaultBlockState().setValue(BlockStateProperties.FACING, Direction.WEST);
+    private static final BlockState REPEATER_E =
+        Blocks.REPEATER.defaultBlockState().setValue(BlockStateProperties.HORIZONTAL_FACING, Direction.EAST);
+    /** Wall lever attached (on its EAST face) to the block immediately to its east. */
+    private static final BlockState LEVER_W_OFF = Blocks.LEVER.defaultBlockState()
+        .setValue(BlockStateProperties.ATTACH_FACE, AttachFace.WALL)
+        .setValue(BlockStateProperties.HORIZONTAL_FACING, Direction.WEST)
+        .setValue(BlockStateProperties.POWERED, false);
+    /** Floor-mounted stone button (strongly powers the support block below; 20-tick stay). */
+    private static final BlockState STONE_BUTTON_OFF = Blocks.STONE_BUTTON.defaultBlockState()
+        .setValue(BlockStateProperties.ATTACH_FACE, AttachFace.FLOOR)
+        .setValue(BlockStateProperties.HORIZONTAL_FACING, Direction.NORTH)
+        .setValue(BlockStateProperties.POWERED, false);
+    private static final int STONE_BUTTON_TICKS = 20;  // vanilla BlockSetType.STONE
+    private static final BlockState TARGET = Blocks.TARGET.defaultBlockState();
+    private static final BlockState OBSIDIAN = Blocks.OBSIDIAN.defaultBlockState();
+    private static BlockState pistonE(final boolean sticky) {
+        return (sticky ? Blocks.STICKY_PISTON : Blocks.PISTON).defaultBlockState()
+            .setValue(BlockStateProperties.FACING, Direction.EAST)
+            .setValue(BlockStateProperties.EXTENDED, false);
+    }
+    private static final BlockState PISTON_E = pistonE(false);
+    private static final BlockState STICKY_E = pistonE(true);
+    private static final BlockState SLIME = Blocks.SLIME_BLOCK.defaultBlockState();
+    private static final BlockState HONEY = Blocks.HONEY_BLOCK.defaultBlockState();
+
+    private static void put(final ServerLevel level, final int x, final int y, final int z, final BlockState state) {
+        level.setBlockAndUpdate(new BlockPos(x, y, z), state);
+    }
+
+    private static void buildCorpus(final ServerLevel level) {
+        // ---- Circuit 1: wire power decay (15 wires off a redstone-block source) ----
+        for (int x = 1; x <= 15; x++) {
+            put(level, x, 100, 0, STONE);          // support
+            put(level, x, 101, 0, WIRE);
+        }
+        put(level, 0, 101, 0, REDBLOCK);           // constant source feeding wire @1
+        SCENARIOS.add(new Scenario("wire-decay", new BlockPos(8, 101, 0), (lvl, c, rel) -> {
+            if (rel == 40) {
+                setBoth(lvl, c, new BlockPos(0, 101, 0), AIR);       // cut source
+            } else if (rel == 90) {
+                setBoth(lvl, c, new BlockPos(0, 101, 0), REDBLOCK);  // restore source
+            }
+        }));
+
+        // ---- Circuit 2: redstone-torch inverter, lever source, strong power thru block ----
+        put(level, 26, 100, 0, STONE);             // input block B
+        put(level, 27, 100, 0, STONE);             // output support
+        put(level, 26, 100, -1, LEVER_OFF);        // wall lever on B's north face -> powers B
+        put(level, 26, 101, 0, TORCH);             // floor torch on B -> reads B
+        put(level, 27, 101, 0, WIRE);              // output wire east of torch
+        SCENARIOS.add(new Scenario("torch-inverter", new BlockPos(26, 101, 0), (lvl, c, rel) -> {
+            if (rel == 50) {
+                setLever(lvl, c, new BlockPos(26, 100, -1), new BlockPos(26, 100, 0), true);
+            } else if (rel == 120) {
+                setLever(lvl, c, new BlockPos(26, 100, -1), new BlockPos(26, 100, 0), false);
+            }
+        }));
+
+        // ---- Circuit 3: line of 2 repeaters (delay accumulation, redstone-block source) ----
+        for (int x = 41; x <= 45; x++) {
+            put(level, x, 100, 0, STONE);
+        }
+        put(level, 41, 101, 0, WIRE);
+        put(level, 42, 101, 0, REPEATER_W);        // input west(41), output east(43)
+        put(level, 43, 101, 0, WIRE);
+        put(level, 44, 101, 0, REPEATER_W);        // input west(43), output east(45)
+        put(level, 45, 101, 0, WIRE);
+        SCENARIOS.add(new Scenario("repeater-line", new BlockPos(43, 101, 0), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(40, 101, 0), REDBLOCK); // energise
+            } else if (rel == 110) {
