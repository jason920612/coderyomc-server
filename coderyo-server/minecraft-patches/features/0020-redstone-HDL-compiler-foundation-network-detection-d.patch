+    private static void buildCorpus(final ServerLevel level) {
+        // ---- Circuit 1: wire power decay (15 wires off a redstone-block source) ----
+        for (int x = 1; x <= 15; x++) {
+            put(level, x, 100, 0, STONE);          // support
+            put(level, x, 101, 0, WIRE);
+        }
+        put(level, 0, 101, 0, REDBLOCK);           // constant source feeding wire @1
+        SCENARIOS.add(new Scenario("wire-decay", new BlockPos(8, 101, 0), (lvl, c, rel) -> {
+            if (rel == 40) {
+                setBoth(lvl, c, new BlockPos(0, 101, 0), AIR);       // cut source
+            } else if (rel == 90) {
+                setBoth(lvl, c, new BlockPos(0, 101, 0), REDBLOCK);  // restore source
+            }
+        }));
+
+        // ---- Circuit 2: redstone-torch inverter, lever source, strong power thru block ----
+        put(level, 26, 100, 0, STONE);             // input block B
+        put(level, 27, 100, 0, STONE);             // output support
+        put(level, 26, 100, -1, LEVER_OFF);        // wall lever on B's north face -> powers B
+        put(level, 26, 101, 0, TORCH);             // floor torch on B -> reads B
+        put(level, 27, 101, 0, WIRE);              // output wire east of torch
+        SCENARIOS.add(new Scenario("torch-inverter", new BlockPos(26, 101, 0), (lvl, c, rel) -> {
+            if (rel == 50) {
+                setLever(lvl, c, new BlockPos(26, 100, -1), new BlockPos(26, 100, 0), true);
+            } else if (rel == 120) {
+                setLever(lvl, c, new BlockPos(26, 100, -1), new BlockPos(26, 100, 0), false);
+            }
+        }));
+
+        // ---- Circuit 3: line of 2 repeaters (delay accumulation, redstone-block source) ----
+        for (int x = 41; x <= 45; x++) {
+            put(level, x, 100, 0, STONE);
+        }
+        put(level, 41, 101, 0, WIRE);
+        put(level, 42, 101, 0, REPEATER_W);        // input west(41), output east(43)
+        put(level, 43, 101, 0, WIRE);
+        put(level, 44, 101, 0, REPEATER_W);        // input west(43), output east(45)
+        put(level, 45, 101, 0, WIRE);
+        SCENARIOS.add(new Scenario("repeater-line", new BlockPos(43, 101, 0), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(40, 101, 0), REDBLOCK); // energise
+            } else if (rel == 110) {
+                setBoth(lvl, c, new BlockPos(40, 101, 0), AIR);      // de-energise
+            }
+        }));
+
+        // ---- Circuit 4: comparator SUBTRACT-mode gate (analog 15 - sideInput) ----
+        // Comparator faces WEST: rear(51)=redstone-block (main input 15), south side(z=5)
+        // carries a wire whose power is toggled; output east -> wire line. SUBTRACT mode
+        // emits 15 - sideStrength, so toggling the side changes the analog output level.
+        put(level, 51, 101, 4, REDBLOCK);          // main (rear) input = 15
+        put(level, 52, 100, 4, STONE);
+        put(level, 52, 101, 4, COMP_SUB_W);        // comparator @ (52)
+        put(level, 53, 100, 4, STONE);
+        put(level, 53, 101, 4, WIRE);              // output wire
+        put(level, 54, 100, 4, STONE);
+        put(level, 54, 101, 4, WIRE);
+        put(level, 52, 100, 5, STONE);             // side-input wire (south of comparator)
+        put(level, 52, 101, 5, WIRE);
+        put(level, 52, 100, 6, STONE);
+        put(level, 52, 101, 6, WIRE);              // side feed wire
+        SCENARIOS.add(new Scenario("comparator-subtract", new BlockPos(52, 101, 4), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(52, 101, 7), REDBLOCK); // side on -> subtract ~14
+            } else if (rel == 90) {
+                setBoth(lvl, c, new BlockPos(52, 101, 7), AIR);      // side off -> output 15
+            }
+        }));
+
+        // ---- Circuit 5: comparator COMPARE-mode reading a CONTAINER (barrel BE) ----
+        // Comparator faces WEST at a partially-filled barrel (analog input = fullness via
+        // the block entity). A toggleable side input gates the compare. COMPARE emits the
+        // container level when input >= side, else 0.
+        put(level, 51, 100, 8, STONE);
+        put(level, 51, 101, 8, BARREL);            // rear container input
+        put(level, 52, 100, 8, STONE);
+        put(level, 52, 101, 8, COMP_CMP_W);        // comparator
+        put(level, 53, 100, 8, STONE);
+        put(level, 53, 101, 8, WIRE);              // output wire
+        put(level, 54, 100, 8, STONE);
+        put(level, 54, 101, 8, WIRE);
+        put(level, 52, 100, 9, STONE);             // side-input wire (south)
+        put(level, 52, 101, 9, WIRE);
+        fillBarrel(level, new BlockPos(51, 101, 8));
+        SCENARIOS.add(new Scenario("comparator-container", new BlockPos(52, 101, 8), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(52, 101, 10), REDBLOCK); // side high -> compare blocks -> 0
+            } else if (rel == 90) {
+                setBoth(lvl, c, new BlockPos(52, 101, 10), AIR);      // side off -> output = fullness
+            }
+        }));
+
+        // ---- Circuit 6: observer pulse driving a redstone lamp ----
+        // Observer faces WEST observing block @ (51); its 2-tick pulse exits the back (east)
+        // into a wire that lights a lamp. Toggling the observed block fires a pulse each edge.
+        put(level, 51, 101, 12, STONE);            // observed block (toggled)
+        put(level, 52, 101, 12, OBS_W);            // observer (floats, no support needed)
+        put(level, 53, 100, 12, STONE);
+        put(level, 53, 101, 12, WIRE);             // output wire behind observer
+        put(level, 54, 100, 12, STONE);
+        put(level, 54, 101, 12, LAMP);             // lamp lit by the pulse
+        SCENARIOS.add(new Scenario("observer-pulse", new BlockPos(52, 101, 12), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(51, 101, 12), AIR);    // observed change -> pulse
+            } else if (rel == 80) {
