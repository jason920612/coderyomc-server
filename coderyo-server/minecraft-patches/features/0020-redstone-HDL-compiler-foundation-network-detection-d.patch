+    private static void setBoth(final ServerLevel level, final CompiledNetwork c, final BlockPos pos, final BlockState state) {
+        level.setBlockAndUpdate(pos, state);
+        c.setSource(pos, state);
+    }
+
+    /** Toggle a wall lever in both worlds, replicating LeverBlock's support-block notify. */
+    private static void setLever(final ServerLevel level, final CompiledNetwork c,
+                                 final BlockPos leverPos, final BlockPos supportPos, final boolean on) {
+        final BlockState state = LEVER_OFF.setValue(BlockStateProperties.POWERED, on);
+        level.setBlockAndUpdate(leverPos, state);
+        level.updateNeighborsAt(supportPos, Blocks.LEVER, null);
