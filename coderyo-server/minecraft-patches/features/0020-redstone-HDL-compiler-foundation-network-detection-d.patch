+        put(level, 81, 101, 24, WIRE);             // relay dust
+        put(level, 82, 100, 24, STONE);
+        put(level, 82, 101, 24, LAMP);             // display load
+        SCENARIOS.add(new Scenario("component-on-charged-block", new BlockPos(80, 101, 24), (lvl, c, rel) -> {
