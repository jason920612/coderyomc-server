+    /** Spawn a non-marker armour stand (a LivingEntity -> triggers stone+wood+weighted plates,
+     *  tripwire) pinned at a fixed position with gravity off, so detection is deterministic. */
+    private static ArmorStand spawnStand(final ServerLevel level, final double x, final double y, final double z) {
+        final ArmorStand stand = new ArmorStand(level, x, y, z);
+        stand.setNoGravity(true);
+        stand.setDeltaMovement(Vec3.ZERO);
+        stand.setPos(x, y, z);
+        level.addFreshEntity(stand);
+        return stand;
+    }
+
+    /** Spawn a pinned dropped item (an Entity but NOT a LivingEntity -> triggers WOOD/weighted
+     *  plates but NOT a stone plate; demonstrates the stone=mobs / wood=everything sensitivity). */
+    private static ItemEntity spawnItem(final ServerLevel level, final double x, final double y, final double z) {
+        final ItemEntity item = new ItemEntity(level, x, y, z, new ItemStack(Items.STONE));
+        item.setNoGravity(true);
+        item.setDeltaMovement(Vec3.ZERO);
+        item.setPos(x, y, z);
+        item.setNoPickUpDelay();
+        level.addFreshEntity(item);
+        return item;
+    }
