+    /** Place a 5-page writable book in a lectern and open it to {@code pageIndex} (for the comparator). */
+    private static void configureLectern(final ServerLevel level, final BlockPos pos, final int pageIndex, final int pages) {
+        if (!(level.getBlockEntity(pos) instanceof LecternBlockEntity lectern)) {
+            return;
+        }
+        final List<Filterable<String>> content = new ArrayList<>();
+        for (int i = 0; i < pages; i++) {
+            content.add(Filterable.passThrough("page " + i));
+        }
+        final ItemStack book = new ItemStack(Items.WRITABLE_BOOK);
+        book.set(DataComponents.WRITABLE_BOOK_CONTENT, new WritableBookContent(content));
+        lectern.setBook(book);
+        lectern.setPage(pageIndex);
+        lectern.setChanged();
+    }
+
+    /** Set a chiseled bookshelf's last-interacted slot (its comparator output is slot + 1). */
+    private static void configureBookshelfSlot(final ServerLevel level, final BlockPos pos, final int slot) {
+        if (level.getBlockEntity(pos) instanceof ChiseledBookShelfBlockEntity shelf) {
+            shelf.lastInteractedSlot = slot;
+            shelf.setChanged();
+        }
+    }
+
+    /** Insert a music disc into a jukebox so its comparator output is the disc's fixed value. */
+    private static void configureJukeboxDisc(final ServerLevel level, final BlockPos pos) {
+        if (level.getBlockEntity(pos) instanceof JukeboxBlockEntity jukebox) {
+            jukebox.setTheItem(new ItemStack(Items.MUSIC_DISC_13));
+            jukebox.setChanged();
+        }
+    }
