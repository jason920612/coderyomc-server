+        put(level, 69, 101, 78, SLIME);            // slime head of the structure
+        for (int x = 70; x <= 80; x++) {           // 11 inline stones -> 12 in the straight line
+            put(level, x, 101, 78, STONE);
+        }
+        put(level, 69, 102, 78, STONE);            // branch on top of slime -> 13th block -> no fire
+        SCENARIOS.add(new Scenario("slime-push-limit", new BlockPos(68, 101, 78), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(68, 100, 78), REDBLOCK); // power, but must NOT fire
+            } else if (rel == 90) {
+                setBoth(lvl, c, new BlockPos(68, 100, 78), AIR);
+            }
+        }));
+
+        // ---- Circuit 24: 0-TICK fast-retract (sticky piston drops the block) ----
+        // A sticky piston is powered for a SHORT pulse: it extends (head + pushed block become
+        // in-flight movers) and is un-powered again before the extension finalises, so the retract
+        // catches the head mid-flight (TRIGGER_DROP). Vanilla finalises the in-flight head early
+        // (source -> AIR) and the pushed block is "dropped" at its mid position. Exercises the
+        // fast-retract path; a tight differential test of mover finalisation timing.
+        put(level, 68, 101, 82, STICKY_E);
+        put(level, 69, 101, 82, STONE);            // pushed then dropped block
+        SCENARIOS.add(new Scenario("piston-0tick-drop", new BlockPos(68, 101, 82), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(68, 100, 82), REDBLOCK); // power on
+            } else if (rel == 32) {
+                setBoth(lvl, c, new BlockPos(68, 100, 82), AIR);      // power off ~2 ticks later
+            }
+        }));
+    }
+
+    /** (rear, side) strength pairs swept across the analog range for the subtractor. */
+    private static final int[][] ANALOG_STEPS = {
+        {15, 0}, {15, 4}, {15, 8}, {15, 12}, {12, 0}, {12, 6}, {10, 0},
+        {10, 5}, {10, 10}, {8, 2}, {6, 0}, {6, 3}, {4, 0}, {3, 1},
+    };
+
+    /** Fill several slots of a barrel so its comparator (analog) output is a stable mid value. */
+    private static void fillBarrel(final ServerLevel level, final BlockPos pos) {
+        if (level.getBlockEntity(pos) instanceof Container container) {
+            for (int slot = 0; slot < 9 && slot < container.getContainerSize(); slot++) {
+                container.setItem(slot, new ItemStack(Items.STONE, 64));
+            }
+            container.setChanged();
+        }
+    }
+
+    private static void setBoth(final ServerLevel level, final CompiledNetwork c, final BlockPos pos, final BlockState state) {
+        level.setBlockAndUpdate(pos, state);
+        c.setSource(pos, state);
+    }
+
+    /** Toggle a wall lever in both worlds, replicating LeverBlock's support-block notify. */
+    private static void setLever(final ServerLevel level, final CompiledNetwork c,
+                                 final BlockPos leverPos, final BlockPos supportPos, final boolean on) {
+        final BlockState state = LEVER_OFF.setValue(BlockStateProperties.POWERED, on);
+        level.setBlockAndUpdate(leverPos, state);
+        level.updateNeighborsAt(supportPos, Blocks.LEVER, null);
+        c.setSource(leverPos, state);
+    }
+
+    /** Toggle a wall lever (given base orientation) in both worlds; notify its support block. */
+    private static void setLeverS(final ServerLevel level, final CompiledNetwork c, final BlockState base,
+                                  final BlockPos leverPos, final BlockPos supportPos, final boolean on) {
+        final BlockState state = base.setValue(BlockStateProperties.POWERED, on);
+        level.setBlockAndUpdate(leverPos, state);
+        level.updateNeighborsAt(supportPos, Blocks.LEVER, null);
+        c.setSource(leverPos, state);
+    }
+
+    /**
+     * Press a button in BOTH worlds: the real one via {@code ButtonBlock.press} (which sets
+     * POWERED, notifies neighbours and schedules its own {@code ticksToStayPressed} un-press),
+     * and the compiled model via {@link CompiledNetwork#pressButton} with the same duration.
+     */
+    private static void pressButton(final ServerLevel level, final CompiledNetwork c,
+                                    final BlockPos pos, final int ticks, final int rel) {
+        final BlockState cur = level.getBlockState(pos);
+        if (cur.getBlock() instanceof ButtonBlock btn && !cur.getValue(BlockStateProperties.POWERED)) {
+            btn.press(cur, level, pos, null);
+            c.pressButton(pos, cur.setValue(BlockStateProperties.POWERED, true), ticks, rel);
+        }
+    }
+
+    /**
+     * Apply a target-block hit in BOTH worlds: set the analog OUTPUT_POWER (BlockState POWER)
+     * and schedule the decay-to-zero, mirroring {@code TargetBlock.setOutputPower}.
+     */
+    private static void hitTarget(final ServerLevel level, final CompiledNetwork c,
+                                  final BlockPos pos, final int power, final int duration, final int rel) {
+        final BlockState on = level.getBlockState(pos).setValue(BlockStateProperties.POWER, power);
+        level.setBlockAndUpdate(pos, on);
+        level.scheduleTick(pos, on.getBlock(), duration);
+        c.hitTarget(pos, on, duration, rel);
+    }
+
+    // -------------------------------------------------------------- scenario
+
+    private interface Stim {
+        void apply(ServerLevel level, CompiledNetwork compiled, int rel);
+    }
+
+    private static final class Scenario {
+        final String name;
+        final BlockPos seed;
+        final Stim stim;
+        RedstoneNetwork net;
+        CompiledNetwork compiled;
+        int divergences;
+        int firstDivergeTick = -1;
+        String firstDetail = "";
+
+        Scenario(final String name, final BlockPos seed, final Stim stim) {
+            this.name = name;
+            this.seed = seed;
+            this.stim = stim;
+        }
+
+        void compile(final ServerLevel level) {
+            this.net = RedstoneNetwork.detect(level, this.seed);
+            this.compiled = CompiledNetwork.compile(level, this.net);
+            final boolean affinity = this.net.spansSingleRegion(level);
+            LOG.info("[redstone-difftest] compiled '{}': {} components, {} footprint cells, {} chunk(s); single-region affinity={}",
+                this.name, this.net.size(), this.net.footprint().size(), this.net.chunkKeys().size(), affinity);
+        }
+
+        void tick(final ServerLevel level, final int rel) {
+            if (this.stim != null) {
+                this.stim.apply(level, this.compiled, rel);
+            }
+            this.compiled.step(rel);
+            for (final long packed : this.net.footprint()) {
+                final BlockPos pos = BlockPos.of(packed);
+                String detail = diff(pos, level.getBlockState(pos), this.compiled.state(packed));
+                // Comparator analog output lives in the block entity, not the block state:
+                // assert the compiled simulator's stored analog value matches vanilla's.
+                if (detail == null && level.getBlockState(pos).getBlock() instanceof ComparatorBlock) {
+                    final int simOut = this.compiled.comparatorOutputSignal(packed);
+                    final int realOut = level.getBlockEntity(pos) instanceof ComparatorBlockEntity be
+                        ? be.getOutputSignal() : -1;
+                    if (simOut != realOut) {
+                        detail = pos.toShortString() + " COMPARATOR-OUT real=" + realOut + " sim=" + simOut;
+                    }
+                }
+                // A MOVING_PISTON cell's animation lives in its PistonMovingBlockEntity: assert the
+                // compiled mover matches vanilla's progress (0->0.5->1), extending/source flags and
+                // moved block-state every tick — the transient piston motion, bit-identical.
+                if (detail == null && level.getBlockState(pos).is(Blocks.MOVING_PISTON)) {
+                    final PistonMovingBlockEntity be = level.getBlockEntity(pos) instanceof PistonMovingBlockEntity p ? p : null;
+                    final CompiledNetwork.MovingBlock mb = this.compiled.movingAt(packed);
+                    if ((be == null) != (mb == null)) {
+                        detail = pos.toShortString() + " MOVING-BE real=" + (be != null) + " sim=" + (mb != null);
+                    } else if (be != null) {
+                        if (be.getProgress(0.0F) != mb.progressO) {
+                            detail = pos.toShortString() + " MOVING-PROGRESS real=" + be.getProgress(0.0F) + " sim=" + mb.progressO;
+                        } else if (be.isExtending() != mb.extending) {
+                            detail = pos.toShortString() + " MOVING-EXTENDING real=" + be.isExtending() + " sim=" + mb.extending;
+                        } else if (be.isSourcePiston() != mb.isSource) {
+                            detail = pos.toShortString() + " MOVING-SOURCE real=" + be.isSourcePiston() + " sim=" + mb.isSource;
+                        } else if (!be.getMovedState().equals(mb.movedState)) {
+                            detail = pos.toShortString() + " MOVING-STATE real=" + be.getMovedState() + " sim=" + mb.movedState;
+                        }
+                    }
+                }
+                if (detail != null) {
+                    this.divergences++;
+                    if (this.firstDivergeTick < 0) {
+                        this.firstDivergeTick = rel;
+                        this.firstDetail = detail;
+                    }
+                    if (this.divergences <= 8) {
+                        LOG.warn("[redstone-difftest] DIVERGENCE '{}' @rel-tick {} {}", this.name, rel, detail);
+                    }
+                }
+            }
+        }
+    }
+
+    /** Compare the parity-relevant property of a cell; null when identical. */
+    private static String diff(final BlockPos pos, final BlockState real, final BlockState sim) {
+        if (real.getBlock() != sim.getBlock()) {
+            return pos.toShortString() + " block real=" + real.getBlock() + " sim=" + sim.getBlock();
+        }
+        if (real.hasProperty(BlockStateProperties.POWER)) {
+            final int r = real.getValue(BlockStateProperties.POWER);
+            final int s = sim.getValue(BlockStateProperties.POWER);
+            return r == s ? null : pos.toShortString() + " POWER real=" + r + " sim=" + s;
+        }
+        if (real.getBlock() instanceof RedstoneTorchBlock) {
+            final boolean r = real.getValue(BlockStateProperties.LIT);
+            final boolean s = sim.getValue(BlockStateProperties.LIT);
+            return r == s ? null : pos.toShortString() + " LIT real=" + r + " sim=" + s;
+        }
+        if (real.getBlock() instanceof DiodeBlock) {
+            final boolean r = real.getValue(BlockStateProperties.POWERED);
+            final boolean s = sim.getValue(BlockStateProperties.POWERED);
+            if (r != s) {
+                return pos.toShortString() + " POWERED real=" + r + " sim=" + s;
+            }
+            if (real.hasProperty(BlockStateProperties.LOCKED)
+                && real.getValue(BlockStateProperties.LOCKED) != sim.getValue(BlockStateProperties.LOCKED)) {
+                return pos.toShortString() + " LOCKED real=" + real.getValue(BlockStateProperties.LOCKED)
+                    + " sim=" + sim.getValue(BlockStateProperties.LOCKED);
+            }
+            return null;
+        }
+        if (real.getBlock() instanceof ObserverBlock) {
+            final boolean r = real.getValue(BlockStateProperties.POWERED);
+            final boolean s = sim.getValue(BlockStateProperties.POWERED);
+            return r == s ? null : pos.toShortString() + " POWERED real=" + r + " sim=" + s;
+        }
+        if (real.getBlock() instanceof RedstoneLampBlock) {
+            final boolean r = real.getValue(BlockStateProperties.LIT);
+            final boolean s = sim.getValue(BlockStateProperties.LIT);
+            return r == s ? null : pos.toShortString() + " LIT real=" + r + " sim=" + s;
+        }
+        if (real.getBlock() instanceof ButtonBlock) {
+            final boolean r = real.getValue(BlockStateProperties.POWERED);
+            final boolean s = sim.getValue(BlockStateProperties.POWERED);
+            return r == s ? null : pos.toShortString() + " POWERED real=" + r + " sim=" + s;
+        }
+        if (real.getBlock() instanceof PistonBaseBlock) {
+            final boolean r = real.getValue(BlockStateProperties.EXTENDED);
+            final boolean s = sim.getValue(BlockStateProperties.EXTENDED);
+            return r == s ? null : pos.toShortString() + " EXTENDED real=" + r + " sim=" + s;
+        }
+        if (real.is(Blocks.PISTON_HEAD)) {
+            if (real.getValue(BlockStateProperties.FACING) != sim.getValue(BlockStateProperties.FACING)) {
+                return pos.toShortString() + " HEAD-FACING real=" + real.getValue(BlockStateProperties.FACING)
+                    + " sim=" + sim.getValue(BlockStateProperties.FACING);
+            }
+            return null;
+        }
+        return null;
+    }
+}
diff --git a/com/coderyo/redstone/RedstoneNetwork.java b/com/coderyo/redstone/RedstoneNetwork.java
new file mode 100644
index 0000000000000000000000000000000000000000..09309955ed71c89ce732294f0a9de7fc87990c88
--- /dev/null
+++ b/com/coderyo/redstone/RedstoneNetwork.java
@@ -0,0 +1,241 @@
+/*
+ * coderyoMC — redstone HDL-compiler (Stream B). Clean-room independent implementation.
+ */
+package com.coderyo.redstone;
+
+import it.unimi.dsi.fastutil.longs.LongLinkedOpenHashSet;
+import it.unimi.dsi.fastutil.longs.LongOpenHashSet;
+import it.unimi.dsi.fastutil.longs.LongSet;
+import java.util.ArrayDeque;
+import java.util.Deque;
+import net.minecraft.core.BlockPos;
+import net.minecraft.core.Direction;
+import net.minecraft.resources.ResourceKey;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.world.level.Level;
+import net.minecraft.world.level.block.Blocks;
+import net.minecraft.world.level.block.ButtonBlock;
+import net.minecraft.world.level.block.DiodeBlock;
+import net.minecraft.world.level.block.LeverBlock;
+import net.minecraft.world.level.block.ObserverBlock;
+import net.minecraft.world.level.block.RedStoneWireBlock;
+import net.minecraft.world.level.block.RedstoneTorchBlock;
+import net.minecraft.world.level.block.TargetBlock;
+import net.minecraft.world.level.block.piston.PistonBaseBlock;
+import net.minecraft.world.level.block.piston.PistonStructureResolver;
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.block.state.properties.BlockStateProperties;
+
+/**
+ * A connected redstone network: the set of electrically-connected redstone
+ * components (wire / torch / repeater / lever / redstone-block …) discovered by a
+ * flood from a seed position, together with the passive conductor blocks that
+ * transmit strong power between them (the simulation footprint).
+ *
+ * <p><b>Region / thread affinity.</b> {@link #spansSingleRegion} resolves the owning
+ * {@code RegionId} of every chunk the network touches via the live
+ * {@code com.coderyo.region.RegionIndex}. A connected network can only span adjacent
+ * chunks, and the region merge rule (any two loaded chunks within {@code mergeRadius}
+ * Chebyshev distance — min 1 — merge into ONE region) guarantees adjacent loaded
+ * chunks are co-owned; so a connected network is structurally confined to a single
+ * region and may be ticked by exactly one region worker (single-writer upheld). This
+ * method asserts that invariant rather than relying on it implicitly.
+ */
+public final class RedstoneNetwork {
+
+    /** Hard cap so a pathological flood can never run away. */
+    private static final int MAX_CELLS = 8192;
+
+    private final ResourceKey<Level> dimension;
+    /** Active components (wire/torch/repeater/lever/redstone-block). */
+    private final LongSet components;
+    /** Components + the passive conductor blocks between them (full sim footprint). */
+    private final LongSet footprint;
+    private final LongSet chunkKeys;
+
+    private RedstoneNetwork(final ResourceKey<Level> dimension, final LongSet components,
+                           final LongSet footprint, final LongSet chunkKeys) {
+        this.dimension = dimension;
+        this.components = components;
+        this.footprint = footprint;
+        this.chunkKeys = chunkKeys;
+    }
+
+    public ResourceKey<Level> dimension() {
+        return this.dimension;
+    }
+
+    public LongSet components() {
+        return this.components;
+    }
+
+    public LongSet footprint() {
+        return this.footprint;
+    }
+
+    public LongSet chunkKeys() {
+        return this.chunkKeys;
+    }
+
+    public int size() {
+        return this.components.size();
+    }
+
+    static boolean isComponent(final BlockState state) {
+        return state.is(Blocks.REDSTONE_WIRE)
+            || state.getBlock() instanceof RedstoneTorchBlock
+            || state.getBlock() instanceof DiodeBlock
+            || state.getBlock() instanceof ObserverBlock
+            || state.getBlock() instanceof LeverBlock
+            || state.getBlock() instanceof ButtonBlock
+            || state.getBlock() instanceof TargetBlock
+            || state.getBlock() instanceof PistonBaseBlock
+            || state.is(Blocks.REDSTONE_BLOCK);
+    }
+
+    /**
+     * Flood-fill a connected network from {@code seed}. Expands through redstone
+     * components and through conductor blocks that are adjacent to a component (those
+     * carry strong power between components, e.g. the block under a torch inverter).
+     */
+    public static RedstoneNetwork detect(final ServerLevel level, final BlockPos seed) {
+        final LongSet components = new LongLinkedOpenHashSet();
+        final LongSet footprint = new LongLinkedOpenHashSet();
+        final LongSet visited = new LongOpenHashSet();
+        // Cells FORCED into the footprint regardless of their (static) block: the travel
+        // region a piston can move blocks through, and a piston's QC sample neighbourhood.
+        // Forced cells also bridge the flood (treated like a conductor) so a redstone line
+        // that runs through / past a piston's push lane stays one connected network.
+        final LongSet forced = new LongOpenHashSet();
+        final Deque<BlockPos> frontier = new ArrayDeque<>();
+
+        frontier.add(seed.immutable());
+        visited.add(seed.asLong());
+
+        while (!frontier.isEmpty() && footprint.size() < MAX_CELLS) {
+            final BlockPos pos = frontier.poll();
+            final BlockState state = level.getBlockState(pos);
+            final boolean component = isComponent(state);
+            final boolean conductor = !component && state.isRedstoneConductor(level, pos);
+            final boolean force = forced.contains(pos.asLong());
+            if (!component && !conductor && !force) {
+                continue;
+            }
+            footprint.add(pos.asLong());
+            if (component) {
+                components.add(pos.asLong());
+            }
+
+            // A piston can move blocks; force its full push lane (up to MAX_PUSH_DEPTH + the
+            // head + the source cell behind on retract) and its QC sample cells into the
+            // footprint so every cell the contraption can ever occupy is detected & compared.
+            if (state.getBlock() instanceof PistonBaseBlock) {
+                final Direction f = state.getValue(BlockStateProperties.FACING);
+                for (int k = 1; k <= PistonStructureResolver.MAX_PUSH_DEPTH + 2; k++) {
+                    forceCell(forced, visited, frontier, pos.relative(f, k));
+                }
+                // QC: the block above the piston and its neighbours decide activation.
+                final BlockPos above = pos.above();
+                forceCell(forced, visited, frontier, above);
+                for (final Direction dir : Direction.values()) {
+                    forceCell(forced, visited, frontier, above.relative(dir));
+                }
+                // Slime/honey multi-block drag can pull blocks OFF the straight lane (branching
+                // in the two perpendicular axes). Run vanilla's real PistonStructureResolver on
+                // the LIVE world to discover the exact static structure this piston would move,
+                // and force every moved/destroyed cell AND its destination into the footprint so
+                // the whole dragged contraption is snapshotted into the compiled grid and
+                // differential-compared every tick. (Exact, structure-sized — no blind halo.)
+                final PistonStructureResolver r = new PistonStructureResolver(level, pos, f, true);
+                if (r.resolve()) {
+                    for (final BlockPos pushed : r.getToPush()) {
+                        forceCell(forced, visited, frontier, pushed);
+                        forceCell(forced, visited, frontier, pushed.relative(f));
+                    }
+                    for (final BlockPos destroyed : r.getToDestroy()) {
+                        forceCell(forced, visited, frontier, destroyed);
+                    }
+                }
+            }
+
+            final boolean bridge = conductor || force;
+            // Expand to the 6 face neighbours, plus the 8 vertical-diagonals so wire
+            // climbing up/down a block step stays connected.
+            for (final Direction dir : Direction.values()) {
+                enqueue(level, frontier, visited, components, bridge, pos.relative(dir));
+            }
+            for (final Direction dir : Direction.Plane.HORIZONTAL) {
+                enqueue(level, frontier, visited, components, bridge, pos.relative(dir).above());
+                enqueue(level, frontier, visited, components, bridge, pos.relative(dir).below());
+            }
+        }
+
+        final LongSet chunkKeys = new LongOpenHashSet();
+        final BlockPos.MutableBlockPos m = new BlockPos.MutableBlockPos();
+        for (final long packed : footprint) {
+            m.set(packed);
+            chunkKeys.add(ChunkPos.pack(m.getX() >> 4, m.getZ() >> 4));
+        }
+        return new RedstoneNetwork(level.dimension(), components, footprint, chunkKeys);
+    }
+
+    /** Force a cell into the footprint and enqueue it (even if it is plain air/solid). */
+    private static void forceCell(final LongSet forced, final LongSet visited,
+                                  final Deque<BlockPos> frontier, final BlockPos pos) {
+        forced.add(pos.asLong());
+        if (visited.add(pos.asLong())) {
+            frontier.add(pos.immutable());
+        }
+    }
+
+    private static void enqueue(final ServerLevel level, final Deque<BlockPos> frontier,
+                                final LongSet visited, final LongSet components,
+                                final boolean fromConductor, final BlockPos next) {
+        if (!visited.add(next.asLong())) {
+            return;
+        }
+        final BlockState state = level.getBlockState(next);
+        if (isComponent(state)) {
+            frontier.add(next.immutable());
+            return;
+        }
+        // Only step into a conductor if it is adjacent to a component (it bridges
+        // strong power); never flood across an open conductor plane indefinitely.
+        if (!fromConductor && state.isRedstoneConductor(level, next) && touchesComponent(level, next)) {
+            frontier.add(next.immutable());
+        }
+    }
+
+    private static boolean touchesComponent(final ServerLevel level, final BlockPos pos) {
+        for (final Direction dir : Direction.values()) {
+            if (isComponent(level.getBlockState(pos.relative(dir)))) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    /**
+     * True iff every chunk this network touches resolves to the same owning region
+     * (or no region has formed yet). Drives the single-writer affinity assertion.
+     */
+    public boolean spansSingleRegion(final ServerLevel level) {
+        Object owner = null;
+        boolean first = true;
+        for (final long chunkKey : this.chunkKeys) {
+            final Object region = com.coderyo.region.RegionLifecycle.index()
+                .regionOf(level.dimension(), chunkKey);
+            if (region == null) {
+                continue;
+            }
+            if (first) {
+                owner = region;
+                first = false;
+            } else if (!region.equals(owner)) {
+                return false;
+            }
+        }
+        return true;
+    }
+}
diff --git a/com/coderyo/redstone/VirtualRedstoneWorld.java b/com/coderyo/redstone/VirtualRedstoneWorld.java
new file mode 100644
index 0000000000000000000000000000000000000000..347735946425b4dd7e69f07baca14ada660d7b5e
--- /dev/null
+++ b/com/coderyo/redstone/VirtualRedstoneWorld.java
@@ -0,0 +1,100 @@
+/*
+ * coderyoMC — redstone HDL-compiler (Stream B). Clean-room independent implementation.
+ */
+package com.coderyo.redstone;
+
+import it.unimi.dsi.fastutil.longs.Long2ObjectMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectOpenHashMap;
+import net.minecraft.core.BlockPos;
+import net.minecraft.world.level.SignalGetter;
+import net.minecraft.world.level.block.Blocks;
+import net.minecraft.world.level.block.entity.BlockEntity;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.material.FluidState;
+import org.jspecify.annotations.Nullable;
+
+/**
+ * The in-memory substrate of the compiled redstone logic graph: a sparse
+ * {@code BlockPos -> BlockState} grid that implements {@link SignalGetter}.
+ *
+ * <p><b>Why this is the key to bit-parity.</b> All of vanilla's redstone signal
+ * propagation ({@code getSignal}, {@code getBestNeighborSignal}, {@code getDirectSignal},
+ * {@code getControlInputSignal}, wire connection geometry, {@code isRedstoneConductor})
+ * is expressed as {@link SignalGetter}/{@link net.minecraft.world.level.BlockGetter}
+ * default methods plus {@link BlockState} methods that only ever read neighbour block
+ * states. By backing those reads with our own grid we reuse the EXACT vanilla logic to
+ * evaluate the compiled circuit — no reimplementation of the propagation formulas, so
+ * the computed power levels are identical by construction. Only the discrete-event
+ * scheduling layer (which delays/commits torch & repeater state) lives in
+ * {@link CompiledNetwork}.
+ *
+ * <p>Positions outside the populated grid read as AIR (signal 0, non-conductor),
+ * matching an open-air circuit on a platform.
+ */
+final class VirtualRedstoneWorld implements SignalGetter {
+
+    private static final BlockState AIR = Blocks.AIR.defaultBlockState();
+
+    private final Long2ObjectMap<BlockState> states = new Long2ObjectOpenHashMap<>();
+    /**
+     * Block entities backing analog-output reads. Comparators get a private
+     * {@link net.minecraft.world.level.block.entity.ComparatorBlockEntity} that the
+     * compiled simulator writes their analog output into; static analog-source inputs
+     * (containers such as a barrel) get the live block entity reference, so vanilla's
+     * {@code getAnalogOutputSignal} reads the EXACT same fullness the real world reads.
+     */
