+        // the harness snapshots block states but not in-flight scheduled ticks, so a circuit
+        // that is already oscillating at snapshot cannot be seeded — see notes.)
+        put(level, 51, 101, 15, STONE);            // observed block (periodically toggled)
+        put(level, 52, 101, 15, OBS_W);            // observer
+        put(level, 53, 100, 15, STONE);
+        put(level, 53, 101, 15, WIRE);             // pulse wire
+        put(level, 54, 100, 15, STONE);
+        put(level, 54, 101, 15, REPEATER_W);       // repeater input west(53), output east(55)
+        put(level, 55, 100, 15, STONE);
+        put(level, 55, 101, 15, WIRE);             // output wire
+        SCENARIOS.add(new Scenario("observer-train", new BlockPos(52, 101, 15), (lvl, c, rel) -> {
+            // Toggle the observed block every 12 ticks to emit a pulse train.
+            if (rel >= 20 && rel < 140 && (rel - 20) % 12 == 0) {
+                final boolean stone = ((rel - 20) / 12) % 2 == 0;
+                setBoth(lvl, c, new BlockPos(51, 101, 15), stone ? AIR : STONE);
+            }
+        }));
+
+        // =================================================================
+        //  POWER-CARRYING-BLOCK COMPLETENESS (the classic redstone-sim trap)
+        // =================================================================
+
+        // ---- Circuit 8: power relayed THROUGH a solid block ----
+        // A repeater STRONGLY charges the solid block it faces; redstone dust on the FAR
+        // side of that block reads the strong charge (15) — power relayed through a block
+        // that is itself a node on the network. Exercises detection of the charged conductor.
+        put(level, 70, 100, 18, STONE);
+        put(level, 70, 101, 18, WIRE);             // repeater rear-input wire (west)
+        put(level, 71, 100, 18, STONE);
+        put(level, 71, 101, 18, REPEATER_E);       // repeater faces EAST -> charges block @72
+        put(level, 72, 100, 18, STONE);
+        put(level, 72, 101, 18, STONE);            // SOLID block strongly charged by repeater
+        put(level, 73, 100, 18, STONE);
+        put(level, 73, 101, 18, WIRE);             // far-side dust reads the charged block (15)
+        put(level, 74, 100, 18, STONE);
+        put(level, 74, 101, 18, WIRE);             // decays onward (14)
+        SCENARIOS.add(new Scenario("power-through-block", new BlockPos(71, 101, 18), (lvl, c, rel) -> {
+            if (rel == 30) {
+                setBoth(lvl, c, new BlockPos(69, 101, 18), REDBLOCK); // energise repeater rear
+            } else if (rel == 110) {
+                setBoth(lvl, c, new BlockPos(69, 101, 18), AIR);      // de-energise
+            }
+        }));
+
+        // ---- Circuit 9: redstone torch ATTACHED to a block, powering through/around it ----
+        // Floor torch sits on host block B (charged by a lever); the lit torch STRONGLY
+        // charges the block ABOVE it (-> top dust) and weakly powers the dust beside it.
+        // Charging B (the torch's host) inverts the torch, dropping both outputs. TWO
+        // power-carrying blocks: B below (lever->B->torch) and the block above (torch->dust).
+        put(level, 76, 100, 21, STONE);            // host block B (charged by lever)
+        put(level, 75, 100, 21, LEVER_W_OFF);      // wall lever attached to B's west face
+        put(level, 76, 101, 21, TORCH);            // floor torch on B
+        put(level, 76, 102, 21, STONE);            // block above torch (strongly charged when lit)
+        put(level, 76, 103, 21, WIRE);             // top dust reads the charged block above
+        put(level, 77, 100, 21, STONE);
+        put(level, 77, 101, 21, WIRE);             // side dust reads the torch weakly
+        SCENARIOS.add(new Scenario("torch-host-block", new BlockPos(76, 101, 21), (lvl, c, rel) -> {
