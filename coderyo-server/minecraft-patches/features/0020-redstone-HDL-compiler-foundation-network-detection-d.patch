+        // the decayed level — the count->analog-strength formula + analog propagation, bit-identical.
+        // (Weighted plate getPressedTime = 10, so a shorter deactivation delay than a stone plate.)
+        put(level, 2, 100, 106, STONE);  put(level, 2, 101, 106, GOLD_PLATE); // detection input
