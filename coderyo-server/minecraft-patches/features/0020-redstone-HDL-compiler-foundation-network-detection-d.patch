+    public static void onServerTickEnd(final MinecraftServer server) {
+        if (!RedstoneCompileConfig.isDiffTest()) {
+            return;
+        }
+        ticks++;
+        final ServerLevel level = server.overworld();
+        switch (phase) {
+            case PHASE_WAIT -> {
+                if (!forced) {
+                    forced = true;
+                    for (int cx = -1; cx <= 5; cx++) {
+                        for (int cz = -1; cz <= 6; cz++) {
+                            level.setChunkForced(cx, cz, true);
+                        }
+                    }
+                    // The entity-detection circuits use CONTROLLED entities (armour stands / a
+                    // dropped item / a minecart) as their only intended detection sources. Disable
+                    // natural mob spawning so stray mobs cannot wander onto a plate/tripwire and
+                    // perturb the detection corpus — keeps the whole difftest deterministic and
+                    // reproducible (the boundary inputs are exactly our controlled entities).
+                    level.getGameRules().set(net.minecraft.world.level.gamerules.GameRules.SPAWN_MOBS, false, level);
+                    level.getGameRules().set(net.minecraft.world.level.gamerules.GameRules.SPAWN_MONSTERS, false, level);
+                    // FREEZE the world clock so the daylight-sensor circuit reads a STABLE sky-light
+                    // level (its analog POWER is computed by vanilla and copied live into the compiled
+                    // grid each tick — a fixed light keeps the input, and thus the parity, constant).
+                    level.getGameRules().set(net.minecraft.world.level.gamerules.GameRules.ADVANCE_TIME, false, level);
+                    LOG.info("[redstone-difftest] forceloaded build-area chunks; mob-spawning OFF; world clock frozen; waiting for load");
+                }
+                if (ticks > 40 && areaLoaded(level)) {
+                    buildCorpus(level);
+                    phase = PHASE_SETTLE;
+                    settleUntil = ticks + 10;
+                    LOG.info("[redstone-difftest] corpus built; settling vanilla redstone for 10 ticks");
+                }
+            }
+            case PHASE_SETTLE -> {
+                if (ticks >= settleUntil) {
+                    for (final Scenario s : SCENARIOS) {
+                        s.compile(level);
+                    }
+                    phase = PHASE_RUN;
+                    runStart = ticks;
+                    LOG.info("[redstone-difftest] ===== LOCKSTEP PARITY COMPARISON START =====");
+                }
+            }
+            case PHASE_RUN -> {
+                final int rel = (int) (ticks - runStart);
+                for (final Scenario s : SCENARIOS) {
+                    s.tick(level, rel);
+                }
+                if (rel >= RedstoneCompileConfig.maxTicks()) {
+                    phase = PHASE_DONE;
+                    summarize();
+                }
+            }
+            default -> {
+            }
+        }
+    }
+
+    private static boolean areaLoaded(final ServerLevel level) {
+        for (int cx = 0; cx <= 5; cx++) {
+            for (int cz = 0; cz <= 6; cz++) {
+                if (!level.getChunkSource().hasChunk(cx, cz)) {
+                    return false;
+                }
+            }
+            if (!level.getChunkSource().hasChunk(cx, -1)) {
+                return false;
+            }
+        }
+        return true;
+    }
+
+    private static void summarize() {
+        LOG.info("[redstone-difftest] ===== PARITY SUMMARY ({} ticks) =====", RedstoneCompileConfig.maxTicks());
+        boolean allPass = true;
+        for (final Scenario s : SCENARIOS) {
+            if (s.divergences == 0) {
+                final String det = s.peakDetection >= 0
+                    ? ", detection peak-output=" + s.peakDetection + " (entity tripped vanilla detection)"
+                    : "";
+                LOG.info("[redstone-difftest]   PASS  {}  ({} cells, every tick bit-identical{})", s.name, s.net.footprint().size(), det);
+            } else {
+                allPass = false;
+                LOG.warn("[redstone-difftest]   FAIL  {}  ({} divergences; first @rel-tick {}: {})",
+                    s.name, s.divergences, s.firstDivergeTick, s.firstDetail);
+            }
+        }
+        LOG.info("[redstone-difftest] ===== VERDICT: {} =====", allPass ? "ALL CIRCUITS BIT-IDENTICAL" : "DIVERGENCE(S) FOUND");
+    }
