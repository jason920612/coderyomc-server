+    /** Seed the first {@code slots} slots of a live container with {@code count} of {@code item}. */
+    private static void fillSlots(final ServerLevel level, final BlockPos pos,
+                                  final net.minecraft.world.item.Item item, final int count, final int slots) {
+        if (level.getBlockEntity(pos) instanceof Container container) {
+            for (int s = 0; s < slots && s < container.getContainerSize(); s++) {
+                container.setItem(s, new ItemStack(item, count));
+            }
+            container.setChanged();
+        }
+    }
