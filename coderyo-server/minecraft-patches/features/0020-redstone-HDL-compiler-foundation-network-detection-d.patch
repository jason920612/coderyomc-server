new file mode 100644
index 0000000..2164e40
--- /dev/null
+++ b/com/coderyo/redstone/VirtualRedstoneWorld.java
@@ -0,0 +1,84 @@
+/*
+ * coderyoMC — redstone HDL-compiler (Stream B). Clean-room independent implementation.
+ */
+package com.coderyo.redstone;
+
+import it.unimi.dsi.fastutil.longs.Long2ObjectMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectOpenHashMap;
+import net.minecraft.core.BlockPos;
+import net.minecraft.world.level.SignalGetter;
+import net.minecraft.world.level.block.Blocks;
+import net.minecraft.world.level.block.entity.BlockEntity;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.material.FluidState;
+import org.jspecify.annotations.Nullable;
+
+/**
+ * The in-memory substrate of the compiled redstone logic graph: a sparse
+ * {@code BlockPos -> BlockState} grid that implements {@link SignalGetter}.
+ *
+ * <p><b>Why this is the key to bit-parity.</b> All of vanilla's redstone signal
+ * propagation ({@code getSignal}, {@code getBestNeighborSignal}, {@code getDirectSignal},
+ * {@code getControlInputSignal}, wire connection geometry, {@code isRedstoneConductor})
+ * is expressed as {@link SignalGetter}/{@link net.minecraft.world.level.BlockGetter}
+ * default methods plus {@link BlockState} methods that only ever read neighbour block
+ * states. By backing those reads with our own grid we reuse the EXACT vanilla logic to
+ * evaluate the compiled circuit — no reimplementation of the propagation formulas, so
+ * the computed power levels are identical by construction. Only the discrete-event
+ * scheduling layer (which delays/commits torch & repeater state) lives in
+ * {@link CompiledNetwork}.
+ *
+ * <p>Positions outside the populated grid read as AIR (signal 0, non-conductor),
+ * matching an open-air circuit on a platform.
+ */
+final class VirtualRedstoneWorld implements SignalGetter {
+
+    private static final BlockState AIR = Blocks.AIR.defaultBlockState();
+
+    private final Long2ObjectMap<BlockState> states = new Long2ObjectOpenHashMap<>();
+
+    void set(final BlockPos pos, final BlockState state) {
+        this.states.put(pos.asLong(), state);
+    }
+
+    void set(final long packed, final BlockState state) {
+        this.states.put(packed, state);
+    }
+
+    @Override
+    public BlockState getBlockState(final BlockPos pos) {
+        return this.states.getOrDefault(pos.asLong(), AIR);
+    }
+
+    @Nullable
+    @Override
+    public BlockState getBlockStateIfLoaded(final BlockPos pos) {
+        return this.getBlockState(pos);
+    }
+
+    @Override
+    public FluidState getFluidState(final BlockPos pos) {
+        return this.getBlockState(pos).getFluidState();
+    }
+
+    @Nullable
+    @Override
+    public FluidState getFluidIfLoaded(final BlockPos pos) {
+        return this.getFluidState(pos);
+    }
+
+    @Override
+    public @Nullable BlockEntity getBlockEntity(final BlockPos pos) {
+        return null; // no block entities in the redstone logic-graph substrate (comparators deferred)
+    }
+
+    @Override
+    public int getHeight() {
+        return 384;
+    }
+
+    @Override
+    public int getMinY() {
+        return -64;
+    }
+}
