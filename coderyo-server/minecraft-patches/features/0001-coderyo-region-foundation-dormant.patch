diff --git a/com/coderyo/region/Region.java b/com/coderyo/region/Region.java
new file mode 100644
index 0000000000000000000000000000000000000000..4db7cc1b969aa27bb6502a699498c07db7afecfa
--- /dev/null
+++ b/com/coderyo/region/Region.java
@@ -0,0 +1,169 @@
+/*
+ * coderyoMC — regionized multithreading core. Clean-room independent
+ * implementation; Folia (GPL-3.0) studied as concept only, never copied.
+ */
+package com.coderyo.region;
+
+import it.unimi.dsi.fastutil.longs.LongOpenHashSet;
+import it.unimi.dsi.fastutil.longs.LongSet;
+import it.unimi.dsi.fastutil.longs.LongSets;
+import java.util.concurrent.atomic.AtomicLong;
+import java.util.concurrent.atomic.AtomicReference;
+import net.minecraft.resources.ResourceKey;
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.Level;
+
+/**
+ * A region: the single-writer tick unit (design-spec §4.1).
+ *
+ * <p>Owns a connected set of loaded chunks within ONE dimension, plus an inbound
+ * lock-free {@link RegionizedTaskQueue}. While a region is being ticked, exactly
+ * one thread owns it, giving intra-region game-state logic lock-free access
+ * (single-writer-per-region invariant).
+ *
+ * <p>Chunk membership is stored as packed {@link ChunkPos#longKey() long keys}
+ * (matching {@link ChunkPos#pack(int, int)}). Mutations to the chunk set go through
+ * the {@link com.coderyo.region.merge merge/split} subsystem, which guarantees the
+ * region is quiescent (not ticking) during structural changes.
+ *
+ * <p>P1.1: working data structure + hooks. NOT yet wired into the live tick loop;
+ * with {@code region.enabled=false} no Region is ever constructed at runtime.
+ */
+public final class Region {
+
+    private final RegionId id;
+    private final ResourceKey<Level> dimension;
+
+    /** Packed chunk keys owned by this region. Guarded by the merge/split subsystem. */
+    private final LongOpenHashSet chunks = new LongOpenHashSet();
+
+    private final RegionizedTaskQueue inbound = new RegionizedTaskQueue();
+
+    /** Owning thread while this region is mid-tick; null when idle. Enforces single-writer. */
+    private final AtomicReference<Thread> tickOwner = new AtomicReference<>(null);
+
+    private final AtomicLong lastTickNanos = new AtomicLong(0L);
+
+    public Region(final RegionId id, final ResourceKey<Level> dimension) {
+        this.id = id;
+        this.dimension = dimension;
+    }
+
+    public RegionId id() {
+        return this.id;
+    }
+
+    public ResourceKey<Level> dimension() {
+        return this.dimension;
+    }
+
+    /** Lock-free inbound queue: cross-region tasks are posted here, drained at tick start. */
+    public RegionizedTaskQueue inbound() {
+        return this.inbound;
+    }
+
+    /** A region is active (worth scheduling) when it owns at least one chunk. */
+    public boolean isActive() {
+        synchronized (this.chunks) {
+            return !this.chunks.isEmpty();
+        }
+    }
+
+    /** Number of chunks currently owned by this region. */
+    public int chunkCount() {
+        synchronized (this.chunks) {
+            return this.chunks.size();
+        }
+    }
+
+    /** Whether this region owns the given packed chunk key. */
+    public boolean ownsChunk(final long packedChunkKey) {
+        synchronized (this.chunks) {
+            return this.chunks.contains(packedChunkKey);
+        }
+    }
+
+    /** Whether this region owns the given chunk position. */
+    public boolean ownsChunk(final ChunkPos pos) {
+        return this.ownsChunk(pos.longKey());
+    }
+
+    /** Read-only snapshot of owned chunk keys (defensive copy; safe for cross-thread reads). */
+    public LongSet chunkKeysSnapshot() {
+        synchronized (this.chunks) {
+            return LongSets.unmodifiable(new LongOpenHashSet(this.chunks));
+        }
+    }
+
+    // --- structural mutation: only the com.coderyo.region.merge subsystem should call these.
+    //     (public because the merge subsystem lives in a sub-package; treat as internal API.) ---
+
+    /** Internal: add a chunk to this region. Merge-subsystem only. */
+    public void addChunkInternal(final long packedChunkKey) {
+        synchronized (this.chunks) {
+            this.chunks.add(packedChunkKey);
+        }
+    }
+
+    /** Internal: remove a chunk from this region. Merge-subsystem only. */
+    public boolean removeChunkInternal(final long packedChunkKey) {
+        synchronized (this.chunks) {
+            return this.chunks.remove(packedChunkKey);
+        }
+    }
+
+    /** Internal: absorb all chunks of {@code other} into this region (merge). Merge-subsystem only. */
+    public void absorbInternal(final Region other) {
+        synchronized (this.chunks) {
+            synchronized (other.chunks) {
+                this.chunks.addAll(other.chunks);
+                other.chunks.clear();
+            }
+        }
+    }
+
+    /** Last per-region tick wall-time in nanos (per-region TPS accounting, design-spec §4.2). */
+    public long lastTickNanos() {
+        return this.lastTickNanos.get();
+    }
+
+    /**
+     * Executes one region tick: claim single-writer ownership, drain inbound tasks,
+     * run the body, release ownership, and record timing.
+     *
+     * <p>P1.1: {@code body} is a no-op-friendly hook — the real per-region game logic
+     * (entity/block-entity/scheduled-tick decomposition mapped in P1-integration-notes.md
+     * S3-S6) is wired in P1.2. This method is NOT yet called by the server.
+     *
+     * @throws IllegalStateException if another thread already owns this region tick
+     *         (single-writer-per-region invariant violation — fail loud, never silent).
+     */
+    public void tick(final Runnable body) {
+        final Thread self = Thread.currentThread();
+        if (!this.tickOwner.compareAndSet(null, self)) {
+            throw new IllegalStateException(
+                "single-writer-per-region invariant violated: region " + this.id
+                    + " already owned by " + this.tickOwner.get());
+        }
+        final long start = System.nanoTime();
+        try {
+            this.inbound.drain();
+            if (body != null) {
+                body.run();
+            }
+        } finally {
+            this.lastTickNanos.set(System.nanoTime() - start);
+            this.tickOwner.set(null);
+        }
+    }
+
+    /** True if the current thread is mid-tick owner of this region (thread-check helper). */
+    public boolean isOwnedByCurrentThread() {
+        return this.tickOwner.get() == Thread.currentThread();
+    }
+
+    @Override
+    public String toString() {
+        return "Region[" + this.id + " dim=" + this.dimension.identifier() + " chunks=" + this.chunkCount() + "]";
+    }
+}
diff --git a/com/coderyo/region/RegionConfig.java b/com/coderyo/region/RegionConfig.java
