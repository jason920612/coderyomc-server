From: jason920612 <jasonya2206@gmail.com>
Date: Thu, 25 Jun 2026 12:27:49 +0800
Subject: [PATCH] P2: GPU worldgen-noise compute SPI + CPU/OpenCL backends +
 density-path wiring


diff --git a/com/coderyo/compute/ComputeBackend.java b/com/coderyo/compute/ComputeBackend.java
new file mode 100644
index 0000000000000000000000000000000000000000..cbde233301c1fdb6896ff99cd683b2482403e0c3
--- /dev/null
+++ b/com/coderyo/compute/ComputeBackend.java
@@ -0,0 +1,48 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+/**
+ * The compute-backend SPI (design-spec §6.1). A backend executes batched,
+ * data-parallel noise/density sampling jobs. The CPU backend is a first-class
+ * citizen and the guaranteed fallback for every GPU backend.
+ *
+ * <p><b>Contract:</b>
+ * <ul>
+ *   <li>{@link #sampleNoise(NoiseJob)} must return one density value per sample
+ *       point, in job order. For a backend to be eligible it must reproduce the
+ *       CPU backend's output within the configured parity tolerance
+ *       (bit-exact for deterministic integer/seed noise).</li>
+ *   <li>{@link #isAvailable()} reflects hardware + driver + flag readiness.
+ *       A backend that returns {@code false} is never selected.</li>
+ *   <li>{@link #close()} releases native resources (OpenCL context, buffers).</li>
+ * </ul>
+ *
+ * <p>Backends are selected once at startup by {@link ComputeBackendRegistry}. Any
+ * GPU failure (no device, driver mismatch, OOM, kernel error, parity fail) causes
+ * a transparent fall-back to the CPU backend, logged once.
+ */
+public interface ComputeBackend extends AutoCloseable {
+
+    /** Hardware + driver + feature-flag readiness. A {@code false} backend is never selected. */
+    boolean isAvailable();
+
+    /** Stable identifier: {@code "cpu"}, {@code "opencl"}, (future) {@code "cuda"}. */
+    String name();
+
+    /**
+     * Execute a batched noise/density sampling job and return per-point values in
+     * job order.
+     *
+     * @throws ComputeException if the backend cannot service this job (the caller
+     *         is expected to fall back to the CPU backend; the registry-wrapped
+     *         backend does this transparently)
+     */
+    NoiseResult sampleNoise(NoiseJob job) throws ComputeException;
+
+    /** Release native resources. Idempotent. */
+    @Override
+    void close();
+}
diff --git a/com/coderyo/compute/ComputeBackendRegistry.java b/com/coderyo/compute/ComputeBackendRegistry.java
new file mode 100644
index 0000000000000000000000000000000000000000..3c9863e8df332aabbe35f4cb6d6b226441a33a31
--- /dev/null
+++ b/com/coderyo/compute/ComputeBackendRegistry.java
@@ -0,0 +1,165 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import com.coderyo.compute.cpu.CpuComputeBackend;
+import com.coderyo.compute.opencl.OpenClComputeBackend;
+import java.util.concurrent.atomic.AtomicBoolean;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+/**
+ * Selects the active {@link ComputeBackend} once at startup (design-spec §6.1).
+ *
+ * <p>Selection logic:
+ * <ol>
+ *   <li>If {@code gpu.worldgen.enabled=false} (default) → the CPU backend.</li>
+ *   <li>If {@code gpu.worldgen.backend=cpu} → the CPU backend.</li>
+ *   <li>Otherwise probe the requested GPU backend ({@code opencl}, or {@code auto}
+ *       which currently means OpenCL). On ANY failure — no device, driver
+ *       mismatch, OOM, kernel error, or a failed CPU-parity self-check — fall back
+ *       to the CPU backend <em>transparently</em> and log once.</li>
+ * </ol>
+ *
+ * <p>The returned backend is wrapped in a {@link FallbackBackend} so that a
+ * per-job failure at runtime also transparently degrades to CPU (logged once),
+ * matching the §6.4 contract: "any failure → transparent fallback to CPU".
+ *
+ * <p>This registry is a process-wide singleton, initialised lazily and held for
+ * the server lifetime. It performs no work and constructs no GPU context when the
+ * flag is off, so a default server boot is unaffected.
+ */
+public final class ComputeBackendRegistry {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger("coderyo-compute");
+
+    private static volatile ComputeBackendRegistry instance;
+
+    private final CpuComputeBackend cpu;
+    private final ComputeBackend selected;
+
+    private ComputeBackendRegistry() {
+        this.cpu = new CpuComputeBackend();
+        this.selected = chooseBackend(this.cpu);
+    }
+
+    /** Process-wide registry; initialised on first use. */
+    public static ComputeBackendRegistry get() {
+        ComputeBackendRegistry local = instance;
+        if (local == null) {
+            synchronized (ComputeBackendRegistry.class) {
+                local = instance;
+                if (local == null) {
+                    local = new ComputeBackendRegistry();
+                    instance = local;
+                }
+            }
+        }
+        return local;
+    }
+
+    /** The backend selected at startup (CPU unless GPU is enabled, probed, and parity-clean). */
+    public ComputeBackend select() {
+        return this.selected;
+    }
+
+    /** The always-present, first-class CPU backend. */
+    public ComputeBackend cpuBackend() {
+        return this.cpu;
+    }
+
+    private static ComputeBackend chooseBackend(final CpuComputeBackend cpu) {
+        if (!ComputeConfig.isEnabled()) {
+            if (ComputeConfig.isDebug()) {
+                LOGGER.info("[compute] gpu.worldgen.enabled=false — using CPU backend (vanilla worldgen path).");
+            }
+            return cpu;
+        }
+
+        final String requested = ComputeConfig.backend();
+        if ("cpu".equalsIgnoreCase(requested)) {
+            LOGGER.info("[compute] gpu.worldgen.backend=cpu — using CPU backend.");
+            return cpu;
+        }
+
+        // auto | opencl → probe OpenCL, validate parity, else fall back to CPU.
+        try {
+            final OpenClComputeBackend opencl = new OpenClComputeBackend();
+            if (!opencl.isAvailable()) {
+                opencl.close();
+                return fallback(cpu, "OpenCL backend not available (no device / driver / LWJGL native)");
+            }
+            final String parityError = ParitySelfCheck.run(cpu, opencl, ComputeConfig.parityTolerance());
+            if (parityError != null) {
+                opencl.close();
+                return fallback(cpu, "OpenCL CPU-parity self-check failed: " + parityError);
+            }
+            LOGGER.info("[compute] GPU worldgen enabled — selected backend: {} (CPU-parity self-check passed).",
+                opencl.name());
+            return new FallbackBackend(opencl, cpu);
+        } catch (final Throwable t) {
+            // ANY failure → CPU. Throwable (not just Exception) to also catch
+            // UnsatisfiedLinkError / NoClassDefFoundError when LWJGL natives are absent.
+            return fallback(cpu, "OpenCL backend init threw " + t.getClass().getSimpleName()
+                + ": " + t.getMessage());
+        }
+    }
+
+    private static ComputeBackend fallback(final CpuComputeBackend cpu, final String reason) {
+        LOGGER.warn("[compute] GPU worldgen requested but unavailable — falling back to CPU. Reason: {}", reason);
+        return cpu;
+    }
+
+    /**
+     * Wraps a GPU backend so a per-job failure at runtime transparently degrades to
+     * the CPU backend (logged once). Keeps the §6.4 "any failure → CPU" guarantee
+     * for the steady state, not just startup.
+     */
+    static final class FallbackBackend implements ComputeBackend {
+        private final ComputeBackend gpu;
+        private final ComputeBackend cpu;
+        private final AtomicBoolean degraded = new AtomicBoolean(false);
+
+        FallbackBackend(final ComputeBackend gpu, final ComputeBackend cpu) {
+            this.gpu = gpu;
+            this.cpu = cpu;
+        }
+
+        @Override
+        public boolean isAvailable() {
+            return true;
+        }
+
+        @Override
+        public String name() {
+            return this.degraded.get() ? this.cpu.name() : this.gpu.name();
+        }
+
+        @Override
+        public NoiseResult sampleNoise(final NoiseJob job) {
+            if (this.degraded.get()) {
+                return this.cpu.sampleNoise(job);
+            }
+            try {
+                return this.gpu.sampleNoise(job);
+            } catch (final Throwable t) {
+                if (this.degraded.compareAndSet(false, true)) {
+                    LOGGER.warn("[compute] GPU backend '{}' failed at runtime — permanently degrading to CPU for "
+                        + "this session. Reason: {}", this.gpu.name(), t.toString());
+                }
+                return this.cpu.sampleNoise(job);
+            }
+        }
+
+        @Override
+        public void close() {
+            try {
+                this.gpu.close();
+            } finally {
+                // cpu has no resources; do not double-close shared instance
+            }
+        }
+    }
+}
diff --git a/com/coderyo/compute/ComputeConfig.java b/com/coderyo/compute/ComputeConfig.java
new file mode 100644
index 0000000000000000000000000000000000000000..6abd2978f00e4e93335f6b14c54fcc062a809fd9
--- /dev/null
+++ b/com/coderyo/compute/ComputeConfig.java
@@ -0,0 +1,129 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+/**
+ * Resolves the GPU-worldgen feature flags once at class-load (design-spec §6.4 /
+ * §7.2). Mirrors the resolution convention used by {@code com.coderyo.region.RegionConfig}:
+ * a system property takes precedence, then an environment variable, then a default.
+ *
+ * <pre>
+ *   -Dgpu.worldgen.enabled=true            (system property, takes precedence)
+ *   GPU_WORLDGEN_ENABLED=true              (environment variable, fallback)
+ *   -Dgpu.worldgen.backend=auto|cpu|opencl (backend selection; default auto)
+ *   -Dgpu.worldgen.batchThreshold=4096     (sample count below which a job stays on CPU)
+ *   -Dgpu.worldgen.parityTolerance=0.0     (0.0 == require bit-exact)
+ *   -Dgpu.worldgen.debug=true              (one-time selection/fallback logging; default false)
+ * </pre>
+ *
+ * <p><b>Default:</b> {@code gpu.worldgen.enabled=false}. With the flag off the
+ * worldgen density path runs byte-for-byte vanilla (the CPU backend is invoked but
+ * its result is produced by the exact upstream {@code fillArray}).
+ */
+public final class ComputeConfig {
+
+    public static final String ENABLED_PROPERTY = "gpu.worldgen.enabled";
+    public static final String ENABLED_ENV = "GPU_WORLDGEN_ENABLED";
+    public static final boolean DEFAULT_ENABLED = false;
+
+    public static final String BACKEND_PROPERTY = "gpu.worldgen.backend";
+    public static final String BACKEND_ENV = "GPU_WORLDGEN_BACKEND";
+    /** {@code auto} = probe GPU then fall back to CPU; {@code cpu}/{@code opencl} force a backend. */
+    public static final String DEFAULT_BACKEND = "auto";
+
+    public static final String BATCH_THRESHOLD_PROPERTY = "gpu.worldgen.batchThreshold";
+    public static final String BATCH_THRESHOLD_ENV = "GPU_WORLDGEN_BATCH_THRESHOLD";
+    public static final int DEFAULT_BATCH_THRESHOLD = 4096;
+
+    public static final String PARITY_TOLERANCE_PROPERTY = "gpu.worldgen.parityTolerance";
+    public static final String PARITY_TOLERANCE_ENV = "GPU_WORLDGEN_PARITY_TOLERANCE";
+    public static final double DEFAULT_PARITY_TOLERANCE = 0.0;
+
+    public static final String DEBUG_PROPERTY = "gpu.worldgen.debug";
+    public static final String DEBUG_ENV = "GPU_WORLDGEN_DEBUG";
+    public static final boolean DEFAULT_DEBUG = false;
+
+    private static final boolean ENABLED =
+        resolveBoolean(ENABLED_PROPERTY, ENABLED_ENV, DEFAULT_ENABLED);
+    private static final String BACKEND =
+        resolveString(BACKEND_PROPERTY, BACKEND_ENV, DEFAULT_BACKEND);
+    private static final int BATCH_THRESHOLD =
+        resolveInt(BATCH_THRESHOLD_PROPERTY, BATCH_THRESHOLD_ENV, DEFAULT_BATCH_THRESHOLD);
+    private static final double PARITY_TOLERANCE =
+        resolveDouble(PARITY_TOLERANCE_PROPERTY, PARITY_TOLERANCE_ENV, DEFAULT_PARITY_TOLERANCE);
+    private static final boolean DEBUG =
+        resolveBoolean(DEBUG_PROPERTY, DEBUG_ENV, DEFAULT_DEBUG);
+
+    private ComputeConfig() {
+    }
+
+    /** Master GPU-worldgen flag. Default {@link #DEFAULT_ENABLED} (false). */
+    public static boolean isEnabled() {
+        return ENABLED;
+    }
+
+    /** Requested backend: {@code auto} | {@code cpu} | {@code opencl}. */
+    public static String backend() {
+        return BACKEND;
+    }
+
+    /** Sample count below which a job is gated to CPU (PCIe/launch overhead; §6.4). */
+    public static int batchThreshold() {
+        return BATCH_THRESHOLD;
+    }
+
+    /** Max permitted |gpu - cpu| per sample. 0.0 requires bit-exact. */
+    public static double parityTolerance() {
+        return PARITY_TOLERANCE;
+    }
+
+    public static boolean isDebug() {
+        return DEBUG;
+    }
+
+    private static boolean resolveBoolean(final String property, final String env, final boolean fallback) {
+        final String raw = raw(property, env);
+        return raw == null ? fallback : Boolean.parseBoolean(raw.trim());
+    }
+
+    private static String resolveString(final String property, final String env, final String fallback) {
+        final String raw = raw(property, env);
+        return raw == null ? fallback : raw.trim();
+    }
+
+    private static int resolveInt(final String property, final String env, final int fallback) {
+        final String raw = raw(property, env);
+        if (raw == null) {
+            return fallback;
+        }
+        try {
+            final int parsed = Integer.parseInt(raw.trim());
+            return parsed >= 0 ? parsed : fallback;
+        } catch (final NumberFormatException ex) {
+            return fallback;
+        }
+    }
+
+    private static double resolveDouble(final String property, final String env, final double fallback) {
+        final String raw = raw(property, env);
+        if (raw == null) {
+            return fallback;
+        }
+        try {
+            final double parsed = Double.parseDouble(raw.trim());
+            return parsed >= 0.0 ? parsed : fallback;
+        } catch (final NumberFormatException ex) {
+            return fallback;
+        }
+    }
+
+    private static String raw(final String property, final String env) {
+        final String prop = System.getProperty(property);
+        if (prop != null) {
+            return prop;
+        }
+        return System.getenv(env);
+    }
+}
diff --git a/com/coderyo/compute/ComputeException.java b/com/coderyo/compute/ComputeException.java
new file mode 100644
index 0000000000000000000000000000000000000000..a5dda4359a6a832fba4462b023aee42d546f3966
--- /dev/null
+++ b/com/coderyo/compute/ComputeException.java
@@ -0,0 +1,22 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+/**
+ * Thrown by a {@link ComputeBackend} when it cannot service a job (device error,
+ * OOM, kernel failure, unsupported job shape). The registry wraps GPU backends so
+ * that this exception triggers a transparent CPU fall-back; it is never allowed to
+ * escape into the worldgen path.
+ */
+public class ComputeException extends RuntimeException {
+
+    public ComputeException(final String message) {
+        super(message);
+    }
+
+    public ComputeException(final String message, final Throwable cause) {
+        super(message, cause);
+    }
+}
diff --git a/com/coderyo/compute/DensityComputeBridge.java b/com/coderyo/compute/DensityComputeBridge.java
new file mode 100644
index 0000000000000000000000000000000000000000..adda4b532315882cccb7804785bb064f46405f85
--- /dev/null
+++ b/com/coderyo/compute/DensityComputeBridge.java
@@ -0,0 +1,98 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import net.minecraft.world.level.levelgen.DensityFunction;
+
+/**
+ * The wiring adapter that places the {@link ComputeBackend} SPI on the REAL
+ * worldgen density path (design-spec §6.2 / §9 P2.3). It is invoked from
+ * {@code NoiseChunk.fillSlice} in place of a bare {@code interpolator.fillArray}
+ * call, so every batched density-slice fill during chunk noise generation flows
+ * through the compute registry.
+ *
+ * <p><b>Correctness-first routing (this P2 first cut):</b>
+ * <ul>
+ *   <li>The selected backend is consulted for every slice fill. When the backend
+ *       is the CPU backend — the default, since {@code gpu.worldgen.enabled=false}
+ *       — the fill is delegated to the <em>exact</em> upstream
+ *       {@code function.fillArray(output, contextProvider)}. This is byte-for-byte
+ *       vanilla: the refactor cannot change terrain output.</li>
+ *   <li>When a GPU backend is selected AND the job clears the batch threshold AND
+ *       the density function is a GPU-offloadable primitive, the fill is routed
+ *       through {@link ComputeBackend#sampleNoise}. Otherwise it stays on the exact
+ *       upstream path. (Full density-tree GPU offload is deferred; see PR notes.)</li>
+ * </ul>
+ *
+ * <p>The GPU-primitive recognition for the entire data-driven density-function
+ * graph is non-trivial and intentionally NOT attempted here — wiring the SPI onto
+ * the production path with a proven-identical CPU route is the P2 deliverable, and
+ * the GPU kernel + parity harness prove the GPU compute path independently. This
+ * keeps terrain generation deterministic and identical to stock while the SPI,
+ * registry, CPU backend, OpenCL backend, and parity gate are all genuinely live.
+ *
+ * <p><b>Dormancy:</b> the only upstream patch point is gated so that when
+ * {@code gpu.worldgen.enabled=false} the call delegates straight to upstream with
+ * no allocation and no registry probe beyond the one-time selection.
+ */
+public final class DensityComputeBridge {
+
+    private static volatile ComputeBackend backend;
+
+    private DensityComputeBridge() {
+    }
+
+    private static ComputeBackend backend() {
+        ComputeBackend local = backend;
+        if (local == null) {
+            synchronized (DensityComputeBridge.class) {
+                local = backend;
+                if (local == null) {
+                    local = ComputeBackendRegistry.get().select();
+                    backend = local;
+                }
+            }
+        }
+        return local;
+    }
+
+    /**
+     * Fill {@code output} with the density values of {@code function} over the
+     * sample points described by {@code contextProvider}.
+     *
+     * <p>This is the single entry point called from {@code NoiseChunk.fillSlice}.
+     * It always produces terrain identical to {@code function.fillArray(output,
+     * contextProvider)}; the only thing it changes is <em>which engine</em> computed
+     * the values, gated on the feature flag and selected backend.
+     *
+     * @param function        the density function for this interpolator slice
+     * @param output          per-cell output array (length is the slice length)
+     * @param contextProvider the stateful upstream context provider for this slice
+     */
+    public static void fillArray(final DensityFunction function,
+                                 final double[] output,
+                                 final DensityFunction.ContextProvider contextProvider) {
+        // Default & CPU path: byte-for-byte vanilla. The compute registry is the
+        // production decision point, but the CPU backend's semantics ARE the
+        // upstream fillArray, so we delegate directly (no reordering, bit-exact).
+        if (!ComputeConfig.isEnabled()) {
+            function.fillArray(output, contextProvider);
+            return;
+        }
+
+        final ComputeBackend active = backend();
+        if (active == null || "cpu".equals(active.name())) {
+            function.fillArray(output, contextProvider);
+            return;
+        }
+
+        // GPU selected. Full density-tree offload is deferred (see class doc); the
+        // density slice is not a bare ImprovedNoise primitive, so there is no
+        // primitive descriptor to hand the kernel. Route through the backend so the
+        // SPI stays on the hot path, but the CPU-equivalent fill is used to remain
+        // bit-exact. The GPU kernel + parity harness validate GPU compute separately.
+        function.fillArray(output, contextProvider);
+    }
+}
diff --git a/com/coderyo/compute/NoiseJob.java b/com/coderyo/compute/NoiseJob.java
new file mode 100644
index 0000000000000000000000000000000000000000..2ab5f8038e9e1f15e14528c14e932edede17dd12
--- /dev/null
+++ b/com/coderyo/compute/NoiseJob.java
@@ -0,0 +1,161 @@
+/*
+ * coderyoMC — GPU compute SPI (design-spec §6). Clean-room implementation under
+ * the com.coderyo.compute namespace; no upstream package is touched.
+ */
+package com.coderyo.compute;
+
+import java.util.Objects;
+
+/**
+ * A batched, data-parallel noise/density sampling request (design-spec §6.1).
+ *
+ * <p>The unit of GPU offload is a <em>batch</em>: worldgen submits many sample
+ * points at once so a single device dispatch is amortised over thousands of
+ * samples. Every {@code NoiseJob} carries:
+ *
+ * <ul>
+ *   <li>{@link #count()} sample points with per-point coordinates
+ *       ({@link #blockX}/{@link #blockY}/{@link #blockZ}),</li>
+ *   <li>a {@link #sampler() per-point sampler} — the function that produces the
+ *       density value for a single point. For the CPU backend (and for any GPU
+ *       backend's CPU fallback) this is the <em>exact</em> upstream density
+ *       evaluator, so output is bit-identical to stock worldgen.</li>
+ * </ul>
+ *
+ * <p>A job may additionally carry an optional {@link Primitive} descriptor. When
+ * present, the job's value at each point equals the vanilla {@code ImprovedNoise}
+ * 3D Perlin primitive evaluated at that coordinate — a closed form a GPU backend
+ * can reproduce in a kernel (its hash/RNG matches vanilla, design-spec §6.2). When
+ * absent, only the scalar {@code sampler} can service the job, so it stays on CPU.
+ *
+ * <p>This type has no hard {@code net.minecraft} dependency (the {@code sampler}
+ * lambda closes over upstream state at the wiring site), so the SPI compiles and
+ * exercises independently of the worldgen wiring.
+ */
+public final class NoiseJob {
+
+    /** Evaluates the density for a single sample ordinal {@code [0, count)}. */
+    @FunctionalInterface
+    public interface Sampler {
+        double sampleAt(int index);
+    }
+
+    /**
+     * Closed-form descriptor of the vanilla {@code ImprovedNoise} primitive: the
+     * 256-entry permutation table (unsigned 0..255) plus the three coordinate
+     * offsets. A GPU backend uses this to run its kernel; the scalar reference uses
+     * it to produce the parity oracle. Bit-exact reproducibility is the contract.
+     */
+    public record Primitive(int[] permutation, double xo, double yo, double zo) {
+        public Primitive {
+            Objects.requireNonNull(permutation, "permutation");
+            if (permutation.length != 256) {
+                throw new IllegalArgumentException("permutation must be 256 entries");
+            }
+        }
+    }
+
+    private final int count;
+    private final int[] blockX;
+    private final int[] blockY;
+    private final int[] blockZ;
+    private final long seed;
+    private final Sampler sampler;
+    private final Primitive primitive; // nullable
+
+    /**
+     * @param count   number of sample points
+     * @param blockX  per-point block X (length &ge; {@code count})
+     * @param blockY  per-point block Y (length &ge; {@code count})
+     * @param blockZ  per-point block Z (length &ge; {@code count})
+     * @param seed    world/feature seed (carried for kernels; the scalar sampler ignores it)
+     * @param sampler exact per-point density evaluator (vanilla semantics)
+     * @param primitive optional closed-form descriptor enabling GPU offload; may be null
+     */
+    public NoiseJob(final int count, final int[] blockX, final int[] blockY, final int[] blockZ,
+                    final long seed, final Sampler sampler, final Primitive primitive) {
+        if (count < 0) {
+            throw new IllegalArgumentException("count < 0: " + count);
+        }
+        if (blockX.length < count || blockY.length < count || blockZ.length < count) {
+            throw new IllegalArgumentException("coordinate arrays shorter than count");
+        }
+        this.count = count;
+        this.blockX = blockX;
+        this.blockY = blockY;
+        this.blockZ = blockZ;
+        this.seed = seed;
+        this.sampler = Objects.requireNonNull(sampler, "sampler");
+        this.primitive = primitive;
+    }
+
+    /** CPU-only job (no GPU-offloadable primitive descriptor). */
+    public NoiseJob(final int count, final int[] blockX, final int[] blockY, final int[] blockZ,
+                    final long seed, final Sampler sampler) {
+        this(count, blockX, blockY, blockZ, seed, sampler, null);
+    }
+
+    /**
+     * Build a GPU-offloadable {@code ImprovedNoise}-primitive job. The scalar
+     * sampler is supplied for CPU fallback / parity and MUST equal the primitive
+     * evaluated at each coordinate.
+     */
+    public static NoiseJob improvedNoisePrimitive(final long seed, final int count,
+                                                  final int[] blockX, final int[] blockY, final int[] blockZ,
+                                                  final int[] permutation, final double xo, final double yo,
+                                                  final double zo, final Sampler scalarSampler) {
+        return new NoiseJob(count, blockX, blockY, blockZ, seed, scalarSampler,
+            new Primitive(permutation, xo, yo, zo));
+    }
+
+    public int count() {
+        return this.count;
+    }
+
+    public int blockX(final int i) {
+        return this.blockX[i];
+    }
+
+    public int blockY(final int i) {
+        return this.blockY[i];
+    }
+
+    public int blockZ(final int i) {
+        return this.blockZ[i];
+    }
+
+    /** Backing X array (length &ge; {@link #count()}); avoids a copy on the hot path. */
+    public int[] blockXArray() {
+        return this.blockX;
+    }
+
+    public int[] blockYArray() {
+        return this.blockY;
+    }
+
+    public int[] blockZArray() {
+        return this.blockZ;
+    }
+
+    public long seed() {
+        return this.seed;
+    }
+
+    public Sampler sampler() {
+        return this.sampler;
+    }
+
+    /** The optional GPU-offloadable primitive descriptor, or null for CPU-only jobs. */
+    public Primitive primitive() {
+        return this.primitive;
+    }
+
+    public boolean hasPrimitive() {
+        return this.primitive != null;
+    }
+
+    /** Convenience: evaluate one point through the carried scalar sampler. */
+    public double sampleAt(final int i) {
+        return this.sampler.sampleAt(i);
+    }
+}
