+    // coderyoMC start - P1.2d: per-region scheduled block/fluid ticks + per-region random ticks.
+    // These run on a region worker thread restricted to chunks the region owns, using the
+    // region's OWN RNG (never the shared thread-unsafe Level.random / ServerChunkCache fields).
+    // ONLY invoked when region.enabled=true.
+
+    /** Whether scheduled-tick / random-tick draining should run at all this tick (matches the
+     *  {@code !isDebug() && runs} gate that guards the vanilla drains in tick()). */
+    public boolean coderyoScheduledTicksRun() {
+        return !this.isDebug() && this.tickRateManager().runsNormally();
+    }
+
+    /** The level's shared optimised random-tick RNG (orchestrator-thread fallback only). */
+    public ca.spottedleaf.moonrise.common.util.SimpleThreadUnsafeRandom coderyoSimpleRandom() {
+        return this.simpleRandom;
+    }
+
+    /**
+     * Orchestrator-thread fallback when NO region has formed yet: drain scheduled block/fluid
+     * ticks and run random block ticks over EVERY loaded chunk, so the suppressed vanilla drains
+     * miss nothing. Runs single-threaded on the orchestrator, so it uses the level's own shared
+     * RNG (no concurrency). Equivalent to the vanilla level-global drains for this transient.
+     */
+    public void coderyoTickScheduledAndRandomFallbackAll() {
+        final long tick = this.getGameTime();
+        this.blockTicks.tick(tick, paperConfig().environment.maxBlockTicks, this::tickBlock);
+        this.fluidTicks.tick(tick, paperConfig().environment.maxFluidTicks, this::tickFluid);
+        // Random ticks: defer to the chunk source's own iteration (already skipped above only
+        // when regions exist; here no region exists so re-run the level-global random ticks).
+        this.getChunkSource().coderyoIterateTickingChunksFallback();
+    }
+
+    /**
+     * Drain this region's scheduled block ticks then fluid ticks (vanilla order), restricted to
+     * {@code ownedChunkKeys}, on the calling region worker thread. Uses {@code regionRandom} for
+     * block-tick randomness instead of the shared {@code Level.random}.
+     */
+    public int coderyoTickRegionScheduledTicks(final it.unimi.dsi.fastutil.longs.LongSet ownedChunkKeys,
+                                               final net.minecraft.util.RandomSource regionRandom) {
+        final long tick = this.getGameTime();
+        int ran = this.blockTicks.coderyoTickRegion(tick, paperConfig().environment.maxBlockTicks,
+            ownedChunkKeys, (pos, type) -> this.coderyoTickBlock(pos, type, regionRandom));
+        ran += this.fluidTicks.coderyoTickRegion(tick, paperConfig().environment.maxFluidTicks,
+            ownedChunkKeys, this::coderyoTickFluid);
+        return ran;
+    }
+
+    /** Exact vanilla {@link #tickBlock} body, but with a region-supplied RNG (no shared
+     *  {@code Level.random}) and without the shared mid-tick-task counter. */
+    private void coderyoTickBlock(final BlockPos pos, final Block type, final net.minecraft.util.RandomSource regionRandom) {
+        BlockState state = this.getBlockState(pos);
+        if (state.is(type)) {
+            state.tick(this, pos, regionRandom);
+        }
+    }
+
+    /** Exact vanilla {@link #tickFluid} body (fluid ticks take no RNG), without the shared
+     *  mid-tick-task counter. */
+    private void coderyoTickFluid(final BlockPos pos, final Fluid type) {
+        BlockState blockState = this.getBlockState(pos);
+        FluidState fluidState = blockState.getFluidState();
+        if (fluidState.is(type)) {
+            fluidState.tick(this, pos, blockState);
+        }
+    }
+
+    /**
+     * Run per-chunk random block ticks for this region's entity-ticking, loaded, owned chunks,
+     * on the calling region worker thread, using {@code regionRandom} instead of the shared
+     * {@code ServerLevel.simpleRandom}. Mirrors {@code ServerChunkCache.iterateTickingChunksFaster}
+     * scoped to owned chunks.
+     *
+     * <p>Deliberately partitions ONLY the pure, region-local random-tick slice
+     * ({@code tickChunk} → {@code optimiseRandomTick} + ice/snow precipitation). Natural mob
+     * spawning, thunder (both create entities and share spawn-state / {@code Level.randValue}),
+     * inhabited-time accounting, and chunk-broadcast stay on the orchestrator inside
+     * {@code chunkSource.tick}. So this covers random block ticks only; see P1-integration-notes
+     * §10 for the documented fallback boundary.
+     */
+    public void coderyoTickRegionRandomTicks(final it.unimi.dsi.fastutil.longs.LongSet ownedChunkKeys,
+                                             final ca.spottedleaf.moonrise.common.util.SimpleThreadUnsafeRandom regionRandom) {
+        final int randomTickSpeed = this.getGameRules().get(GameRules.RANDOM_TICK_SPEED);
+        final net.minecraft.server.level.ServerChunkCache cache = this.getChunkSource();
+        final it.unimi.dsi.fastutil.longs.LongIterator it = ownedChunkKeys.iterator();
+        while (it.hasNext()) {
+            final long chunkKey = it.nextLong();
+            final LevelChunk chunk = cache.getChunkAtIfLoadedImmediately(ChunkPos.getX(chunkKey), ChunkPos.getZ(chunkKey));
+            if (chunk == null) {
+                continue;
+            }
+            // Only entity-ticking-ready chunks random-tick in vanilla; shouldTickBlocksAt gates
+            // the same readiness used by iterateTickingChunksFaster's entity-ticking chunk list.
+            if (!this.shouldTickBlocksAt(chunkKey)) {
+                continue;
+            }
+            this.coderyoTickChunkRandom(chunk, randomTickSpeed, regionRandom);
+        }
+    }
+
+    /** Vanilla {@link #tickChunk} body (ice/snow precipitation + random block ticks) with a
+     *  region-supplied {@link ca.spottedleaf.moonrise.common.util.SimpleThreadUnsafeRandom}
+     *  instead of the shared {@code this.simpleRandom}. */
+    private void coderyoTickChunkRandom(final LevelChunk chunk, final int tickSpeed,
+                                        final ca.spottedleaf.moonrise.common.util.SimpleThreadUnsafeRandom regionRandom) {
+        ChunkPos chunkPos = chunk.getPos();
+        int minX = chunkPos.getMinBlockX();
+        int minZ = chunkPos.getMinBlockZ();
+        if (!this.paperConfig().environment.disableIceAndSnow) {
+            for (int i = 0; i < tickSpeed; i++) {
+                if (regionRandom.nextInt(48) == 0) {
+                    this.tickPrecipitation(this.getBlockRandomPos(minX, 0, minZ, 15, regionRandom));
+                }
+            }
+        }
+        if (tickSpeed > 0) {
+            this.coderyoOptimiseRandomTick(chunk, tickSpeed, regionRandom);
+        }
+    }
+
+    /** Vanilla {@code optimiseRandomTick} body with a region-supplied RNG (no shared
+     *  {@code this.simpleRandom}); the per-region single-writer worker owns this chunk. */
+    private void coderyoOptimiseRandomTick(final LevelChunk chunk, final int tickSpeed,
+                                           final ca.spottedleaf.moonrise.common.util.SimpleThreadUnsafeRandom regionRandom) {
+        final LevelChunkSection[] sections = chunk.getSections();
+        final int minSection = ca.spottedleaf.moonrise.common.util.WorldUtil.getMinSection((ServerLevel)(Object)this);
+        final boolean doubleTickFluids = !ca.spottedleaf.moonrise.common.PlatformHooks.get().configFixMC224294();
+
+        final ChunkPos cpos = chunk.getPos();
+        final int offsetX = cpos.x() << 4;
+        final int offsetZ = cpos.z() << 4;
+
+        for (int sectionIndex = 0, sectionsLen = sections.length; sectionIndex < sectionsLen; sectionIndex++) {
+            final int offsetY = (sectionIndex + minSection) << 4;
+            final LevelChunkSection section = sections[sectionIndex];
+            final net.minecraft.world.level.chunk.PalettedContainer<net.minecraft.world.level.block.state.BlockState> states = section.getStates();
+            if (!section.isRandomlyTickingBlocks()) {
+                continue;
+            }
+
+            final ca.spottedleaf.moonrise.common.list.ShortList tickList = ((ca.spottedleaf.moonrise.patches.block_counting.BlockCountingChunkSection)section).moonrise$getTickingBlockList();
+
+            for (int i = 0; i < tickSpeed; ++i) {
+                final int tickingBlocks = tickList.size();
+                final int index = regionRandom.nextInt() & ((16 * 16 * 16) - 1);
+
+                if (index >= tickingBlocks) {
+                    continue;
+                }
+
+                final int location = (int)tickList.getRaw(index) & 0xFFFF;
+                final BlockState state = states.get(location);
+
+                final BlockPos pos = new BlockPos((location & 15) | offsetX, ((location >>> (4 + 4)) & 15) | offsetY, ((location >>> 4) & 15) | offsetZ);
+
+                state.randomTick((ServerLevel)(Object)this, pos, regionRandom);
+                if (doubleTickFluids) {
+                    final FluidState fluidState = state.getFluidState();
+                    if (fluidState.isRandomlyTicking()) {
+                        fluidState.randomTick((ServerLevel)(Object)this, pos, regionRandom);
+                    }
+                }
+            }
+        }
+    }
+    // coderyoMC end - P1.2d
+
     @Override
