index bc72869223352e4e5ebc185b90587098b5df2f50..1c32616475e1524877a205839eb15fdb6858d8d3 100644
--- a/net/minecraft/world/entity/ai/navigation/PathNavigation.java
+++ b/net/minecraft/world/entity/ai/navigation/PathNavigation.java
@@ -224,6 +224,27 @@ public abstract class PathNavigation {
