+    /**
+     * A per-thread set of OpenCL dispatch resources: one command queue and one of each
+     * kernel object. Because {@code clSetKernelArg} mutates the kernel object, giving
+     * each worker thread its own kernels (and queue) lets concurrent chunk-gen threads
+     * dispatch in parallel with NO shared mutable state — no lock, no race (GPU #14c).
+     */
+    private static final class DispatchContext {
+        final long queue;
+        final long improvedKernel;
+        final long normalKernel;
+        final long blendedKernel;
+        /** When true this context is shared by overflow threads and must be locked per dispatch. */
+        volatile boolean shared;
+
+        DispatchContext(final long queue, final long improvedKernel,
+                        final long normalKernel, final long blendedKernel) {
+            this.queue = queue;
+            this.improvedKernel = improvedKernel;
+            this.normalKernel = normalKernel;
+            this.blendedKernel = blendedKernel;
+        }
+    }
+
+    /** Build a fresh command queue + kernel trio for the calling thread. */
+    private DispatchContext newContext() {
+        try (MemoryStack stack = MemoryStack.stackPush()) {
+            final IntBuffer err = stack.mallocInt(1);
+            final long q = clCreateCommandQueue(this.context, this.device, 0L, err);
+            checkCl(err.get(0), "clCreateCommandQueue(ctx)");
+            final long k = clCreateKernel(this.program, "improved_noise", err);
+            checkCl(err.get(0), "clCreateKernel(improved,ctx)");
+            final long nk = clCreateKernel(this.normalProgram, "normal_noise", err);
+            checkCl(err.get(0), "clCreateKernel(normal,ctx)");
+            final long bk = clCreateKernel(this.blendedProgram, "blended_noise", err);
+            checkCl(err.get(0), "clCreateKernel(blended,ctx)");
+            final DispatchContext c = new DispatchContext(q, k, nk, bk);
+            this.contexts.add(c);
+            this.queuesCreated.incrementAndGet();
+            return c;
+        } catch (final Throwable t) {
+            throw new ComputeException("OpenCL dispatch-context creation failed: " + t, t);
+        }
+    }
+
+    /**
+     * Lazily acquire this thread's dispatch context. Up to {@link #MAX_CONTEXTS} distinct
+     * per-thread contexts are created (one command queue each); beyond that, threads share
+     * a single fallback context guarded by a lock (degrades gracefully to the #14b behaviour
+     * only for the overflow threads — in practice the chunk-gen pool is well under the cap).
+     */
+    private DispatchContext acquireContext() {
+        if (this.contextCount.incrementAndGet() <= MAX_CONTEXTS) {
+            return newContext();
+        }
+        DispatchContext s = this.sharedContext;
+        if (s == null) {
+            synchronized (this.sharedContextLock) {
+                s = this.sharedContext;
+                if (s == null) {
+                    s = newContext();
+                    s.shared = true;
+                    this.sharedContext = s;
+                }
+            }
+        }
+        return s;
+    }
