             this.lastServerStatus = nano;
             this.status = this.buildServerStatus();
diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 1530810cdb74810e37e3e22ce4fcda4ee7511055..d5f9c39daec582c5f8ae4d42e5aa5278faedd1b8 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -280,6 +280,12 @@ public abstract class Entity
     public float yRotO;
     public float xRotO;
     private AABB bb = INITIAL_AABB;
+    // coderyoMC - per-entity neighbor-scan sharing (query elimination): the once-per-tick
+    // shared superset neighbor list + the box it covers + the game-tick it was built on.
