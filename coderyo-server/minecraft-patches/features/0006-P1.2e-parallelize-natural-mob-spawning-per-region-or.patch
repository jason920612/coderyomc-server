+    // coderyoMC start - P1.2e: per-region natural mob spawning.
+    /**
+     * Region-thread variant of {@link #spawnForChunk}. Identical spawn rules, but:
+     * <ul>
+     *   <li>uses {@code regionRandom} (the region's own RNG) everywhere {@code level.random}
+     *       would be used — the shared {@code Level.random} is a thread-unsafe RNG and MUST NOT
+     *       be touched off the orchestrator (design-spec §4.5);</li>
+     *   <li>the single shared {@code state} (SpawnState cookie) carries the GLOBAL mob cap +
+     *       per-player counts. Its mutating critical section ({@code canSpawn}/{@code afterSpawn},
+     *       the {@code PotentialCalculator}, the {@code LocalMobCapCalculator}, and the per-player
+     *       {@code mobCounts}/{@code mobBackoffCounts} maps reached via the spawn callbacks) is
+     *       serialized across regions by holding {@code synchronized(state)} for the whole
+     *       per-chunk spawn attempt. So multiple regions spawning in parallel collectively never
+     *       exceed the world's mob cap, and never race the cookie's non-thread-safe internals.</li>
+     * </ul>
+     * The actual mob {@code finalizeSpawn}/{@code addFreshEntity} runs inside that critical
+     * section; the lock is leaf-level (region workers only, never nested with another region's
+     * cookie) so it cannot deadlock. Spawning is a small fraction of the tick, so serializing it
+     * keeps the global cap exact while entity/block/scheduled/random ticking stays fully parallel.
+     */
+    public static void coderyoSpawnForChunk(
+        final ServerLevel level, final LevelChunk chunk, final NaturalSpawner.SpawnState state,
+        final List<MobCategory> spawningCategories, final net.minecraft.util.RandomSource regionRandom
+    ) {
+        // Serialize the whole per-chunk spawn attempt on the shared cookie so the global cap, the
+        // potential calculator, and the per-player counters are mutated atomically across regions.
+        synchronized (state) {
+            for (MobCategory mobCategory : spawningCategories) {
+                final boolean canSpawn;
+                int maxSpawns = Integer.MAX_VALUE;
+                if (level.paperConfig().entities.spawning.perPlayerMobSpawns) {
+                    int limit = mobCategory.getMaxInstancesPerChunk();
+                    org.bukkit.entity.SpawnCategory spawnCategory = org.bukkit.craftbukkit.util.CraftSpawnCategory.toBukkit(mobCategory);
+                    if (org.bukkit.craftbukkit.util.CraftSpawnCategory.isValidForLimits(spawnCategory)) {
+                        limit = level.getWorld().getSpawnLimit(spawnCategory);
+                    }
+                    int minDiff = Integer.MAX_VALUE;
+                    final ca.spottedleaf.moonrise.common.list.ReferenceList<net.minecraft.server.level.ServerPlayer> inRange =
+                        level.moonrise$getNearbyPlayers().getPlayers(chunk.getPos(), ca.spottedleaf.moonrise.common.misc.NearbyPlayers.NearbyMapType.TICK_VIEW_DISTANCE);
+                    if (inRange != null) {
+                        final net.minecraft.server.level.ServerPlayer[] backingSet = inRange.getRawDataUnchecked();
+                        for (int k = 0, len = inRange.size(); k < len; k++) {
+                            minDiff = Math.min(limit - level.getChunkSource().chunkMap.getMobCountNear(backingSet[k], mobCategory), minDiff);
+                        }
+                    }
+                    maxSpawns = (minDiff == Integer.MAX_VALUE) ? 0 : minDiff;
+                    canSpawn = maxSpawns > 0;
+                } else {
+                    canSpawn = state.canSpawnForCategoryLocal(mobCategory, chunk.getPos());
+                }
+                if (canSpawn) {
+                    coderyoSpawnCategoryForChunk(mobCategory, level, chunk, state::canSpawn, state::afterSpawn,
+                        maxSpawns, level.paperConfig().entities.spawning.perPlayerMobSpawns ? level.getChunkSource().chunkMap::updatePlayerMobTypeMap : null,
+                        regionRandom);
+                }
+            }
+        }
+    }
+
+    /** Region-RNG variant of {@link #spawnCategoryForChunk} (the maxSpawns/trackEntity overload). */
+    private static void coderyoSpawnCategoryForChunk(
+        final MobCategory mobCategory, final ServerLevel level, final LevelChunk chunk,
+        final NaturalSpawner.SpawnPredicate extraTest, final NaturalSpawner.AfterSpawnCallback spawnCallback,
+        final int maxSpawns, final @Nullable Consumer<Entity> trackEntity,
+        final net.minecraft.util.RandomSource regionRandom
+    ) {
+        BlockPos start = coderyoGetRandomPosWithin(level, chunk, regionRandom);
+        if (start.getY() >= level.getMinY() + 1) {
+            spawnCategoryForPosition(mobCategory, level, chunk, start, extraTest, spawnCallback, maxSpawns, trackEntity, regionRandom);
+        }
+    }
+
+    /** Region-RNG variant of {@link #getRandomPosWithin}. */
+    private static BlockPos coderyoGetRandomPosWithin(final Level level, final LevelChunk chunk, final net.minecraft.util.RandomSource regionRandom) {
+        ChunkPos pos = chunk.getPos();
+        int x = pos.getMinBlockX() + regionRandom.nextInt(16);
+        int z = pos.getMinBlockZ() + regionRandom.nextInt(16);
+        int topEmptyY = chunk.getHeight(Heightmap.Types.WORLD_SURFACE, x, z) + 1;
+        int y = Mth.randomBetweenInclusive(regionRandom, level.getMinY(), topEmptyY);
+        return new BlockPos(x, y, z);
+    }
+    // coderyoMC end - P1.2e
