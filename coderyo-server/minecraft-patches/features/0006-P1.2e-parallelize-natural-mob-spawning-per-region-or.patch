+    // coderyoMC start - P1.2e: per-region natural mob spawning.
+    /**
+     * Orchestrator-side slice of {@code tickSpawningChunk}: thunder strike + inhabited-time
+     * accounting only (NO mob spawning). Thunder creates entities and reads the shared
+     * {@code Level.randValue}, so it stays on the orchestrator; the spawning slice is deferred
+     * to the region phase.
+     */
+    private void coderyoTickThunderAndInhabited(final LevelChunk chunk, final long timeDiff) {
+        chunk.incrementInhabitedTime(timeDiff);
+        this.level.tickThunder(chunk);
+    }
+
+    /**
+     * Per-region natural mob spawning: run {@code NaturalSpawner.spawnForChunk} for the given
+     * (already-collected, world-border-checked) chunk on the calling region worker thread, using
+     * {@code regionRandom} instead of the shared {@code Level.random}, sharing the single global
+     * {@code spawnCookie} (its mutators serialized via {@code synchronized(spawnCookie)} in the
+     * spawn body so the GLOBAL mob cap and per-player caps stay exact across regions).
+     *
+     * @return number of spawning-eligible chunks processed (diagnostic count).
+     */
+    public int coderyoSpawnForRegion(final LongSet ownedChunkKeys,
+                                     final net.minecraft.util.RandomSource regionRandom) {
+        final ServerLevel level = this.level;
+        final java.util.List<LevelChunk> chunks = level.coderyoStashedSpawningChunks();
+        if (chunks == null || chunks.isEmpty()) {
+            return 0;
+        }
+        final java.util.List<net.minecraft.world.entity.MobCategory> categories = level.coderyoStashedSpawningCategories();
+        final NaturalSpawner.SpawnState cookie = level.coderyoStashedSpawnCookie();
+        if (categories == null || categories.isEmpty() || cookie == null) {
+            return 0;
+        }
+        int processed = 0;
+        for (final LevelChunk chunk : chunks) {
+            final ChunkPos cp = chunk.getPos();
+            if (!ownedChunkKeys.contains(cp.longKey())) {
+                continue;
+            }
+            if (level.getWorldBorder().isWithinBounds(cp)) {
+                NaturalSpawner.coderyoSpawnForChunk(level, chunk, cookie, categories, regionRandom);
+                processed++;
+            }
+        }
+        return processed;
+    }
+    // coderyoMC end - P1.2e
+
     public ServerChunkCache(
