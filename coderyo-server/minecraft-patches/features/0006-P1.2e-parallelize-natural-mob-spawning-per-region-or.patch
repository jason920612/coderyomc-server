+            // coderyoMC start - P1.2e: when region.enabled, natural mob spawning is run PER-REGION
+            // on worker threads (partitioned by owned chunk, region RNG), sharing the single global
+            // SpawnState cookie (its mutators serialized) so the GLOBAL mob cap is respected.
+            // Thunder + inhabited-time still run here on the orchestrator per chunk (thunder creates
+            // entities and reads the shared Level.randValue). Mob spawning is DEFERRED to the region
+            // phase: the orchestrator stashes the cookie/categories/chunks for the regions to drain.
+            // region.enabled=false => coderyoIsParallelTickActive() is false => vanilla path runs.
+            if (this.level.coderyoIsParallelTickActive()) {
+                for (LevelChunk chunk : spawningChunks) {
+                    // orchestrator: thunder + inhabited-time only (NO spawning).
+                    this.coderyoTickThunderAndInhabited(chunk, timeDiff);
+                }
+                // Stash the spawn budget + spawning chunks for the per-region spawn phase. The
+                // regions share this ONE cookie (mutators serialized => exact global cap).
+                this.level.coderyoStashSpawnPhase(spawnCookie, spawningCategories, new ObjectArrayList<>(spawningChunks));
+            } else {
             for (LevelChunk chunk : spawningChunks) {
                 this.tickSpawningChunk(chunk, timeDiff, spawningCategories, spawnCookie);
             }
+            } // coderyoMC end - P1.2e
         } finally {
             spawningChunks.clear();
         }
