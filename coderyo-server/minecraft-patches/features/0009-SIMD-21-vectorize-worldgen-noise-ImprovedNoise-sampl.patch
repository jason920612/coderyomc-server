From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: jason920612 <jasonya2206@gmail.com>
Date: Thu, 25 Jun 2026 20:42:49 +0800
Subject: [PATCH] SIMD #21: vectorize worldgen noise (ImprovedNoise
 sampleAndLerp) via FMA/AVX2, flag-gated default-off


diff --git a/com/coderyo/worldgen/WorldgenSimdConfig.java b/com/coderyo/worldgen/WorldgenSimdConfig.java
new file mode 100644
index 0000000000000000000000000000000000000000..aa2960bed050bb73baaa26e22f09ac819e46bd9b
--- /dev/null
+++ b/com/coderyo/worldgen/WorldgenSimdConfig.java
@@ -0,0 +1,76 @@
+/*
+ * coderyoMC — worldgen noise SIMD acceleration (issue #21).
+ *
+ * Independent implementation. Vectorizes the hot per-cell noise math by tightening the
+ * gradient-dot + trilinear-lerp inner loop into fused-multiply-add (FMA) form, which the
+ * JIT lowers to AVX2 {@code vfmadd} instructions. This is the data-parallel work that LOST
+ * on GPU (PCIe transfer + dispatch overhead) but WINS in-register on the CPU's vector ALU.
+ */
+package com.coderyo.worldgen;
+
+/**
+ * Flag for the worldgen noise SIMD (FMA) acceleration (design-spec §6, issue #21).
+ *
+ * <p>The accelerated path tightens the hot {@code ImprovedNoise.sampleAndLerp} gradient-dot +
+ * trilinear lerp into fused-multiply-add form (HotSpot lowers {@link Math#fma} to AVX2
+ * {@code vfmadd}). In an <em>isolated</em> microbenchmark of that method it is ~1.4x faster and
+ * stays within tolerance of the scalar path (relErr ~1e-10, far below the ~1e-5 worldgen
+ * tolerance; worldgen is already non-deterministic run-to-run via Moonrise, issue #8).
+ *
+ * <p><strong>Default OFF.</strong> The end-to-end worldgen benchmark (real chunk pregeneration,
+ * port 15565) showed the per-method win does <em>not</em> carry to whole-chunk generation —
+ * chunk-gen is dominated by biomes/structures/carvers/surface/lighting/IO, not raw noise, so
+ * accelerating the noise inner loop yields no net chunks/sec gain (measured ~0.9x, i.e. a slight
+ * regression from the extra method indirection). The path is therefore kept as a documented,
+ * opt-in experiment rather than enabled by default. See {@code docs/simd-notes.md}.
+ *
+ * <p>When OFF — the default — the original scalar path runs, byte-for-byte identical to stock
+ * Paper. Turn it ON only to A/B the FMA noise path: {@code -Dcoderyo.worldgen.simd.enabled=true}.
+ *
+ * <p>Resolved once at class-load from a system property / environment variable, mirroring
+ * {@code com.coderyo.region.RegionConfig}:
+ * <pre>
+ *   -Dcoderyo.worldgen.simd.enabled=false   (system property, takes precedence)
+ *   CODERYO_WORLDGEN_SIMD_ENABLED=false      (environment variable, fallback)
+ * </pre>
+ *
+ * <p><b>Operator note:</b> this path uses scalar {@link Math#fma} (hardware FMA), NOT the
+ * {@code jdk.incubator.vector} Vector API, so it needs <em>no</em> {@code --add-modules} JVM
+ * flag and no extra launch wiring. It is independent of {@code region.enabled} — worldgen
+ * runs regardless of whether regionized ticking is active.
+ */
+public final class WorldgenSimdConfig {
+
+    /** System property key. */
+    public static final String PROPERTY = "coderyo.worldgen.simd.enabled";
+    /** Environment variable key. */
+    public static final String ENV = "CODERYO_WORLDGEN_SIMD_ENABLED";
+
+    /** {@code worldgen.simd.enabled} default — OFF (per-method win does not carry to E2E worldgen). */
+    public static final boolean DEFAULT_ENABLED = false;
+
+    private static final boolean ENABLED = resolveEnabled();
+
+    private WorldgenSimdConfig() {
+    }
+
+    private static boolean resolveEnabled() {
+        final String prop = System.getProperty(PROPERTY);
+        if (prop != null) {
+            return Boolean.parseBoolean(prop.trim());
+        }
+        final String env = System.getenv(ENV);
+        if (env != null) {
+            return Boolean.parseBoolean(env.trim());
+        }
+        return DEFAULT_ENABLED;
+    }
+
+    /**
+     * Whether the worldgen noise SIMD/FMA path is enabled. Resolved once at class-load.
+     * Default {@link #DEFAULT_ENABLED} (true). When false the scalar stock path runs.
+     */
+    public static boolean isEnabled() {
+        return ENABLED;
+    }
+}
diff --git a/net/minecraft/world/level/levelgen/synth/ImprovedNoise.java b/net/minecraft/world/level/levelgen/synth/ImprovedNoise.java
index ef8f2a00945a3d240a23ca73f138960ee0fe8742..c55cf5886f6736ea47abe644667b8d6b97b04b96 100644
--- a/net/minecraft/world/level/levelgen/synth/ImprovedNoise.java
+++ b/net/minecraft/world/level/levelgen/synth/ImprovedNoise.java
@@ -6,6 +6,21 @@ import net.minecraft.util.RandomSource;
 
 public final class ImprovedNoise {
     private static final float SHIFT_UP_EPSILON = 1.0E-7F;
+    // coderyoMC #21: flattened gradient table (gx/gy/gz indexed by hash & 15) so the SIMD/FMA
+    // path avoids the int[][] indirection of SimplexNoise.GRADIENT in the hot dot product.
+    private static final double[] GRAD_X = new double[16];
+    private static final double[] GRAD_Y = new double[16];
+    private static final double[] GRAD_Z = new double[16];
+
+    static {
+        for (int i = 0; i < 16; i++) {
+            final int[] g = SimplexNoise.GRADIENT[i];
+            GRAD_X[i] = g[0];
+            GRAD_Y[i] = g[1];
+            GRAD_Z[i] = g[2];
+        }
+    }
+
     private final byte[] p;
     public final double xo;
     public final double yo;
@@ -83,6 +98,18 @@ public final class ImprovedNoise {
     }
 
     private double sampleAndLerp(final int x, final int y, final int z, final double xr, final double yr, final double zr, final double yrOriginal) {
+        // coderyoMC #21: flag-gated SIMD/FMA path (default OFF). This is the hot inner loop of
+        // worldgen noise (BlendedNoise + PerlinNoise + every density function hammer it). The
+        // accelerated path tightens the 8 gradient dots + trilinear lerp into fused-multiply-add
+        // form, which the JIT lowers to AVX2 vfmadd; ~1.4x faster *in an isolated microbench* of
+        // this method, relErr ~1e-10 (within tolerance). HOWEVER the real E2E worldgen benchmark
+        // showed no net chunks/sec win (chunk-gen is biome/structure/carver/lighting/IO bound,
+        // not noise bound) — so it is default OFF / opt-in. See docs/simd-notes.md and
+        // com.coderyo.worldgen.WorldgenSimdConfig. When OFF (default) the original scalar path
+        // below runs, byte-identical to stock Paper.
+        if (com.coderyo.worldgen.WorldgenSimdConfig.isEnabled()) {
+            return this.sampleAndLerpSimd(x, y, z, xr, yr, zr, yrOriginal);
+        }
         int x0 = this.p(x);
         int x1 = this.p(x + 1);
         int xy00 = this.p(x0 + y);
@@ -103,6 +130,47 @@ public final class ImprovedNoise {
         return Mth.lerp3(xAlpha, yAlpha, zAlpha, d000, d100, d010, d110, d001, d101, d011, d111);
     }
 
+    // coderyoMC #21: FMA-tight twin of sampleAndLerp. The permutation lookups (this.p) stay
+    // scalar — they are a data-dependent gather into a 256-byte table that AVX2 cannot speed
+    // up — but every floating-point multiply-add between them is fused (Math.fma -> vfmaddsd),
+    // and the gradient comes from the flattened GRAD_* tables (no int[][] indirection). This is
+    // the realistic CPU-SIMD-ALU win on gather-bound noise: the GPU-loser becomes a CPU winner.
+    private double sampleAndLerpSimd(final int x, final int y, final int z, final double xr, final double yr, final double zr, final double yrOriginal) {
+        final int x0 = this.p(x);
+        final int x1 = this.p(x + 1);
+        final int xy00 = this.p(x0 + y);
+        final int xy01 = this.p(x0 + y + 1);
+        final int xy10 = this.p(x1 + y);
+        final int xy11 = this.p(x1 + y + 1);
+        final double xm = xr - 1.0;
+        final double ym = yr - 1.0;
+        final double zm = zr - 1.0;
+        final double d000 = gradDotFma(this.p(xy00 + z), xr, yr, zr);
+        final double d100 = gradDotFma(this.p(xy10 + z), xm, yr, zr);
+        final double d010 = gradDotFma(this.p(xy01 + z), xr, ym, zr);
+        final double d110 = gradDotFma(this.p(xy11 + z), xm, ym, zr);
+        final double d001 = gradDotFma(this.p(xy00 + z + 1), xr, yr, zm);
+        final double d101 = gradDotFma(this.p(xy10 + z + 1), xm, yr, zm);
+        final double d011 = gradDotFma(this.p(xy01 + z + 1), xr, ym, zm);
+        final double d111 = gradDotFma(this.p(xy11 + z + 1), xm, ym, zm);
+        final double xAlpha = Mth.smoothstep(xr);
+        final double yAlpha = Mth.smoothstep(yrOriginal);
+        final double zAlpha = Mth.smoothstep(zr);
+        // trilinear interpolation in FMA form: lerp(a, p0, p1) == fma(a, p1 - p0, p0)
+        final double l00 = Math.fma(xAlpha, d100 - d000, d000);
+        final double l01 = Math.fma(xAlpha, d110 - d010, d010);
+        final double l10 = Math.fma(xAlpha, d101 - d001, d001);
+        final double l11 = Math.fma(xAlpha, d111 - d011, d011);
+        final double lo = Math.fma(yAlpha, l01 - l00, l00);
+        final double hi = Math.fma(yAlpha, l11 - l10, l10);
+        return Math.fma(zAlpha, hi - lo, lo);
+    }
+
+    private static double gradDotFma(final int hash, final double x, final double y, final double z) {
+        final int h = hash & 15;
+        return Math.fma(GRAD_X[h], x, Math.fma(GRAD_Y[h], y, GRAD_Z[h] * z));
+    }
+
     private double sampleWithDerivative(final int x, final int y, final int z, final double xr, final double yr, final double zr, final double[] derivativeOut) {
         int x0 = this.p(x);
         int x1 = this.p(x + 1);
