--- /dev/null
+++ b/com/coderyo/compat/SideEffectTripwire.java
@@ -1,0 +_,49 @@
+/*
+ * coderyoMC — plugin compatibility layer. Clean-room independent implementation;
+ * Folia (GPL-3.0) studied as concept only, never copied. See design-spec §5 and
+ * ADR-0001 (the LOCKED tier model).
+ */
+package com.coderyo.compat;
+
+/**
+ * Tier-1.5 enforcement hook (design-spec §5.3 / §5.5): aborts speculation the instant a
+ * speculating handler performs an <em>irreversible</em> side effect (the conservation-of-
+ * irreversibility law, §5.1).
+ *
+ * <p><b>P3.1 status: STUB / interface only.</b> The speculative fast-lane (Tier 1.5) is a
+ * <b>phase 3+</b> deliverable and is NOT built in P3.1 — the always-correct serialized
+ * legacy region (Tier 2) is the baseline. This interface (and the {@link EffectKind} taxonomy)
+ * is scaffolded now so the later speculative tier slots in without reshaping the router; the
+ * default {@link #NO_OP} implementation never aborts (correct for Tier 0 / Tier 2, where no
+ * speculation is in flight).
+ */
+public interface SideEffectTripwire {
+
+    /** A no-op tripwire: never aborts. Correct while no speculation is in flight (P3.1). */
+    SideEffectTripwire NO_OP = kind -> { /* no speculation active — nothing to abort */ };
+
+    /**
+     * The kinds of irreversible operation that must abort a speculating handler. Mirrors the
+     * §5.1 enumeration (no compensator exists for any of these).
+     */
+    enum EffectKind {
+        /** chat / packet send to a client. */
+        NETWORK_SEND,
+        /** fresh cross-plugin call needing an immediate return value (Vault / LuckPerms / ...). */
+        CROSS_PLUGIN_RETURN,
+        /** file / DB / HTTP IO. */
+        EXTERNAL_IO,
+        /** synchronously-handled {@code callEvent}. */
+        SYNC_EVENT,
+        /** plugin self-state mutation visible outside the handler. */
+        PLUGIN_STATE_MUTATION
+    }
+
+    /**
+     * Called by instrumented API entry points while a handler is speculating. Must throw
+     * {@code AbortSpeculationException} (handled internally by the speculative tier) on any
+     * irreversible op. The P3.1 {@link #NO_OP} implementation does nothing because P3.1 never
+     * speculates.
+     */
+    void guard(EffectKind kind);
+}
