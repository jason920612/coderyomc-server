-            treeType = SaplingBlock.treeType;
-            SaplingBlock.treeType = null;
+            treeType = SaplingBlock.coderyoTakeTreeType(); // coderyoMC - P1.2f
         }
 
         if (!capturedBlockStates.isEmpty()) {
