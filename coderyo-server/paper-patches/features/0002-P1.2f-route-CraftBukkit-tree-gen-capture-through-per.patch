Subject: [PATCH] P1.2f: route CraftBukkit tree-gen capture through per-thread
 frame (issue #8)


diff --git a/src/main/java/org/bukkit/craftbukkit/CraftWorld.java b/src/main/java/org/bukkit/craftbukkit/CraftWorld.java
index faa57d7a4dc75a4c8d5c3feba7ae0b1b1fc72547..5b944a76ca1057fff5666f458f497f850420a695 100644
--- a/src/main/java/org/bukkit/craftbukkit/CraftWorld.java
+++ b/src/main/java/org/bukkit/craftbukkit/CraftWorld.java
@@ -738,18 +738,21 @@ public class CraftWorld extends CraftRegionAccessor implements World {
 
     @Override
     public boolean generateTree(Location loc, TreeType type, BlockChangeDelegate delegate) {
-        this.world.captureTreeGeneration = true;
-        this.world.captureBlockStates = true;
+        // coderyoMC start - P1.2f: per-thread capture frame (issue #8)
+        final net.minecraft.world.level.Level.CaptureState coderyoCap = this.world.coderyoCapture();
+        coderyoCap.captureTreeGeneration = true;
+        coderyoCap.captureBlockStates = true;
+        // coderyoMC end - P1.2f
         List<org.bukkit.craftbukkit.block.CraftBlockState> capturedBlockStates;
         boolean grownTree;
         try {
             grownTree = this.generateTree(loc, type);
         } finally {
-            this.world.captureTreeGeneration = false;
-            this.world.captureBlockStates = false;
+            coderyoCap.captureTreeGeneration = false; // coderyoMC - P1.2f
+            coderyoCap.captureBlockStates = false; // coderyoMC - P1.2f
 
-            capturedBlockStates = new ArrayList<>(this.world.capturedBlockStates.values());
-            this.world.capturedBlockStates.clear();
+            capturedBlockStates = new ArrayList<>(coderyoCap.capturedBlockStates.values()); // coderyoMC - P1.2f
+            coderyoCap.capturedBlockStates.clear(); // coderyoMC - P1.2f
         }
         if (grownTree) { // Copy block data to delegate
             for (CraftBlockState snapshot : capturedBlockStates) {
